@model IEnumerable<SE_Academic_Affairs_Support_System.Models.RegistrationPeriod>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Đợt đăng ký đề tài";
}


<div class="rg-page-title">
    <h2>Đợt Đăng Ký Đề Tài</h2>
    <p>Các đợt đăng ký đề tài học phần đang diễn ra</p>
</div>

<partial name="_Alerts" />

@if (!Model.Any())
{
    <div class="text-center py-5" style="color:#9ca3af;">
        <p style="font-size:16px; font-weight:600; margin-bottom:8px; color:#374151;">Hiện không có đợt đăng ký nào đang diễn ra.</p>
        <p style="font-size:14px;">Vui lòng quay lại sau hoặc liên hệ giáo vụ khoa để biết thêm thông tin.</p>
        <a href="/" class="btn btn-outline-primary mt-2">Về trang chủ</a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var item in Model)
        {
            <div class="col-md-6">
                <div class="period-card">
                    <div class="period-card-head">
                        <h5>@item.Name</h5>
                    </div>
                    <div class="period-card-body">
                        <div class="period-meta">
                            <div class="period-meta-row">
                                <span class="period-meta-lbl">Học phần</span>
                                <span class="period-meta-val">@item.CourseName</span>
                            </div>
                            <div class="period-meta-row">
                                <span class="period-meta-lbl">Hạn cuối</span>
                                <span class="period-meta-val" style="color:#dc2626; font-weight:600;">
                                    @item.EndDate.ToString("dd/MM/yyyy HH:mm")
                                </span>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-2 period-actions">
                            <a asp-area="Student" asp-controller="Registration" asp-action="TopicList"
                               class="btn-period-primary">
                                Xem &amp; Đăng ký đề tài
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
