@model SE_Academic_Affairs_Support_System.ViewModels.MyRegistrationsViewModel
@using SE_Academic_Affairs_Support_System.Models
@{
    ViewData["Title"] = "Đăng ký của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0"><i class="bi bi-list-check text-primary me-2"></i>Đăng ký của tôi</h2>
        @if (Model.HasActivePeriod)
        {
            <a asp-action="TopicList" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i> Đăng ký thêm
            </a>
        }
    </div>

    <partial name="_Alerts" />

    @if (!Model.Registrations.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox display-4"></i>
            <p class="mt-3">Bạn chưa có đăng ký nào.</p>
            @if (Model.HasActivePeriod)
            {
                <a asp-action="TopicList" class="btn btn-primary mt-2">Xem danh sách đề tài</a>
            }
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var reg in Model.Registrations)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <div class="col-md-6">
                                    <h6 class="fw-bold mb-1">@reg.TopicTitle</h6>
                                    <div class="text-muted small">
                                        <i class="bi bi-person me-1"></i>@reg.LecturerName
                                        <span class="ms-3"><i class="bi bi-calendar3 me-1"></i>@reg.PeriodName</span>
                                    </div>
                                </div>
                                <div class="col-md-3 mt-2 mt-md-0">
                                    <span class="badge @reg.StatusCssClass fs-6 px-3 py-2">
                                        @reg.StatusLabel
                                    </span>
                                    <div class="text-muted small mt-1">
                                        @reg.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                </div>
                                <div class="col-md-3 mt-2 mt-md-0 text-md-end">
                                    @if (reg.CanRevise)
                                    {
                                        <a asp-action="ReviseProposal" asp-route-id="@reg.RegistrationId"
                                           class="btn btn-warning btn-sm me-1">
                                            <i class="bi bi-pencil me-1"></i> Sửa đề xuất
                                        </a>
                                    }
                                    @if (reg.CanCancel)
                                    {
                                        <form asp-action="Cancel" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="registrationId" value="@reg.RegistrationId" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm"
                                                    onclick="return confirm('Xác nhận hủy đăng ký này?')">
                                                <i class="bi bi-x-lg"></i> Hủy
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(reg.LecturerNote))
                            {
                                <div class="mt-3 p-2 rounded bg-light border-start border-4
                                    @(reg.Status == RegistrationStatus.REVISION_REQUIRED ? "border-warning" : "border-secondary")">
                                    <small class="text-muted fw-semibold">
                                        <i class="bi bi-chat-left-text me-1"></i>Ghi chú giảng viên:
                                    </small>
                                    <div class="small mt-1">@reg.LecturerNote</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
