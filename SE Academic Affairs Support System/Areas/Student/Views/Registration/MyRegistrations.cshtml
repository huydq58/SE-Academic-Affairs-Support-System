@model SE_Academic_Affairs_Support_System.ViewModels.MyRegistrationsViewModel
@using SE_Academic_Affairs_Support_System.Models
@{
    ViewData["Title"] = "Đăng ký của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .reg-card { border:1px solid #e5e7eb; border-radius:10px; background:#fff; overflow:hidden; margin-bottom:14px; transition:box-shadow .15s; }
    .reg-card:hover { box-shadow:0 4px 16px rgba(37,99,235,.08); }
    .reg-card-head { background:#eff6ff; border-bottom:1px solid #bfdbfe; padding:12px 18px; }
    .reg-card-title { font-size:15px; font-weight:700; color:#1e3a8a; margin:0; }
    .reg-card-body { padding:14px 18px; }
    .reg-meta { display:flex; flex-wrap:wrap; gap:6px 24px; font-size:13px; color:#6b7280; margin-bottom:14px; }
    .reg-meta span { display:flex; align-items:center; gap:5px; }
    .reg-meta-lbl { font-weight:600; color:#9ca3af; font-size:11px; text-transform:uppercase; }
    .reg-actions { display:flex; flex-wrap:wrap; gap:8px; align-items:center; }

    .note-box { margin-top:12px; padding:12px 14px; border-radius:8px; border-left:4px solid; font-size:13px; }
    .note-box.warning { background:#fefce8; border-color:#eab308; }
    .note-box.info    { background:#f0f9ff; border-color:#93c5fd; }
    .note-lbl { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.04em; color:#9ca3af; margin-bottom:4px; }
    .note-text { color:#374151; line-height:1.6; }

    .btn-revise { display:inline-block; padding:6px 16px; background:#d97706; color:#fff; border-radius:7px; font-size:13px; font-weight:700; text-decoration:none; transition:background .15s; }
    .btn-revise:hover { background:#b45309; color:#fff; }
    .btn-cancel { display:inline-flex; align-items:center; padding:6px 14px; background:#fff; color:#dc2626; border:1px solid #fecaca; border-radius:7px; font-size:13px; font-weight:600; cursor:pointer; transition:all .15s; }
    .btn-cancel:hover { background:#fee2e2; border-color:#fca5a5; }

    .date-small { font-size:12px; color:#9ca3af; }
</style>

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div class="rg-page-title mb-0">
        <h2>Đăng Ký Của Tôi</h2>
        <p>Lịch sử và trạng thái các lượt đăng ký đề tài</p>
    </div>
    @if (Model.HasActivePeriod)
    {
        <a asp-action="TopicList" class="btn btn-primary flex-shrink-0">Đăng ký thêm</a>
    }
</div>

<partial name="_Alerts" />

@if (!Model.Registrations.Any())
{
    <div class="text-center py-5" style="color:#9ca3af;">
        <p style="font-size:16px; font-weight:600; margin-bottom:8px; color:#374151;">Bạn chưa có đăng ký nào.</p>
        @if (Model.HasActivePeriod)
        {
            <a asp-action="TopicList" class="btn btn-primary mt-2">Xem danh sách đề tài</a>
        }
    </div>
}
else
{
    @foreach (var reg in Model.Registrations)
    {
        <div class="reg-card">
            <div class="reg-card-head">
                <p class="reg-card-title">@reg.TopicTitle</p>
            </div>
            <div class="reg-card-body">
                <div class="reg-meta">
                    <span>
                        <span class="reg-meta-lbl">Giảng viên</span>
                        <span style="color:#374151; font-weight:500;">@reg.LecturerName</span>
                    </span>
                    <span>
                        <span class="reg-meta-lbl">Đợt</span>
                        <span style="color:#374151;">@reg.PeriodName</span>
                    </span>
                    <span>
                        <span class="reg-meta-lbl">Ngày đăng ký</span>
                        <span class="date-small">@reg.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    </span>
                </div>

                <div class="reg-actions">
                    <span class="sb @(reg.Status == RegistrationStatus.APPROVED ? "sb-green" : reg.Status == RegistrationStatus.REJECTED ? "sb-red" : reg.Status == RegistrationStatus.PENDING ? "sb-amber" : reg.Status == RegistrationStatus.REVISION_REQUIRED ? "sb-blue" : "sb-gray")">@reg.StatusLabel</span>

                    @if (reg.CanRevise)
                    {
                        <a asp-action="ReviseProposal" asp-route-id="@reg.RegistrationId"
                           class="btn-revise">Chỉnh sửa đề xuất</a>
                    }
                    @if (reg.CanCancel)
                    {
                        <form asp-action="Cancel" method="post" style="margin:0" hx-boost="false">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="registrationId" value="@reg.RegistrationId" />
                            <button type="submit" class="btn-cancel"
                                    onclick="return confirm('Xác nhận hủy đăng ký này?')">
                                Hủy đăng ký
                            </button>
                        </form>
                    }
                </div>

                @if (!string.IsNullOrEmpty(reg.LecturerNote))
                {
                    <div class="note-box @(reg.Status == RegistrationStatus.REVISION_REQUIRED ? "warning" : "info")">
                        <div class="note-lbl">Ghi chú từ giảng viên</div>
                        <div class="note-text">@reg.LecturerNote</div>
                    </div>
                }
            </div>
        </div>
    }
}
