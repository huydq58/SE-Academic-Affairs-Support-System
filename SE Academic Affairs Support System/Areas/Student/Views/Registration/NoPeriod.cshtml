@{
    ViewData["Title"] = "Chưa có đợt đăng ký";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .empty-state { text-align:center; padding:60px 20px; }
    .empty-state-box { display:inline-block; background:#eff6ff; border:1px solid #bfdbfe; border-radius:12px; padding:40px 48px; max-width:480px; }
    .empty-state-title { font-size:17px; font-weight:700; color:#1e3a8a; margin-bottom:10px; }
    .empty-state-desc  { font-size:14px; color:#6b7280; line-height:1.7; margin-bottom:24px; }
    @@media (max-width:600px) {
        .empty-state-box { padding:28px 20px; }
    }
</style>

<div class="empty-state">
    <div class="empty-state-box">
        <div class="empty-state-title">Chưa có đợt đăng ký nào đang mở</div>
        <p class="empty-state-desc">
            Hiện tại không có đợt đăng ký đề tài nào đang diễn ra.<br>
            Vui lòng quay lại sau hoặc liên hệ giáo vụ khoa để biết thêm thông tin.
        </p>
        <a href="/" class="btn btn-primary px-4">Về trang chủ</a>
    </div>
</div>
