@model SE_Academic_Affairs_Support_System.ViewModels.TopicListViewModel
@{
    ViewData["Title"] = "Danh sách đề tài";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .period-badge { display:inline-block; background:#eff6ff; border:1px solid #bfdbfe; color:#1d4ed8; border-radius:20px; padding:4px 14px; font-size:12px; font-weight:700; }

    .filter-bar { background:#f8fafc; border:1px solid #e5e7eb; border-radius:10px; padding:16px; margin-bottom:24px; }

    .topic-card { border:1px solid #dbeafe; border-radius:10px; background:#fff; overflow:hidden; display:flex; flex-direction:column; height:100%; transition:box-shadow .15s, transform .15s; }
    .topic-card:hover { box-shadow:0 4px 16px rgba(37,99,235,.1); transform:translateY(-2px); }
    .topic-card.full { opacity:.75; }
    .topic-card-head { background:#eff6ff; border-bottom:1px solid #bfdbfe; padding:13px 16px; }
    .topic-card-title { font-size:14px; font-weight:700; color:#1e3a8a; margin:0; line-height:1.4; }
    .topic-card-body { padding:14px 16px; flex:1; display:flex; flex-direction:column; gap:10px; }
    .topic-desc { font-size:13px; color:#6b7280; line-height:1.6; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; flex:1; }
    .topic-tech-wrap { display:flex; flex-wrap:wrap; gap:5px; }
    .topic-meta { display:flex; justify-content:space-between; align-items:center; font-size:12px; color:#6b7280; }
    .topic-lecturer { font-weight:600; color:#374151; }
    .slot-info { display:flex; align-items:center; gap:4px; }

    .slot-bar { height:3px; background:#e5e7eb; border-radius:2px; margin-top:auto; }
    .slot-bar-fill { height:100%; border-radius:2px; background:#2563eb; }
    .slot-bar-fill.full { background:#dc2626; }

    .topic-card-foot { padding:12px 16px; border-top:1px solid #f1f5f9; background:#fafbfc; }

    .btn-register { display:block; width:100%; padding:9px; background:#2563eb; color:#fff; border:none; border-radius:7px; font-size:13px; font-weight:700; cursor:pointer; transition:background .15s; }
    .btn-register:hover { background:#1d4ed8; }
    .btn-register-done { display:block; width:100%; padding:9px; background:#dcfce7; color:#166534; border:1px solid #bbf7d0; border-radius:7px; font-size:13px; font-weight:700; cursor:default; }
    .btn-register-full { display:block; width:100%; padding:9px; background:#f1f5f9; color:#9ca3af; border:1px solid #e2e8f0; border-radius:7px; font-size:13px; font-weight:700; cursor:default; }

    @@media (max-width:600px) {
        .filter-row { flex-direction:column; }
    }
</style>

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
    <div class="rg-page-title mb-0">
        <h2>Đăng Ký Đề Tài</h2>
        <p>
            <span class="period-badge">@Model.Period.CourseName</span>
            &nbsp;@Model.Period.Name &mdash; Hạn: <strong>@Model.Period.EndDate.ToString("dd/MM/yyyy")</strong>
        </p>
    </div>
    <a asp-action="ProposeNew" class="btn btn-outline-primary flex-shrink-0">Đề xuất đề tài mới</a>
</div>

<partial name="_Alerts" />

<div class="filter-bar">
    <form method="get" class="d-flex flex-wrap gap-2 filter-row">
        <div class="flex-grow-1" style="min-width:180px;">
            <input type="text" name="keyword" value="@Model.SearchKeyword"
                   class="form-control" placeholder="Tìm tên đề tài, mô tả..." />
        </div>
        <div style="min-width:200px; flex:1;">
            <select name="lecturerId" class="form-select">
                <option value="">Tất cả giảng viên</option>
                @foreach (var lec in Model.Lecturers)
                {
                    <option value="@lec.Id" selected="@(Model.FilterLecturerId == lec.Id)">
                        @lec.FullName (@lec.LecturerCode)
                    </option>
                }
            </select>
        </div>
        <button type="submit" class="btn btn-primary px-4">Lọc</button>
    </form>
</div>

@if (!Model.Topics.Any())
{
    <div class="text-center py-5" style="color:#9ca3af;">
        <p style="font-size:15px; font-weight:600; color:#374151; margin-bottom:6px;">Không tìm thấy đề tài nào phù hợp.</p>
        <p style="font-size:13px;">Thử thay đổi từ khóa hoặc bộ lọc giảng viên.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var topic in Model.Topics)
        {
            <div class="col-md-6 col-lg-4">
            @{
                int pct = topic.MaxStudents > 0
                    ? (int)((double)topic.RegisteredCount / topic.MaxStudents * 100)
                    : 100;
                bool isFull = !topic.CanRegister && !topic.AlreadyRegistered;
            }
                <div class="topic-card @(isFull ? "full" : "")">
                    <div class="topic-card-head">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <p class="topic-card-title">@topic.Title</p>
                            @if (topic.AlreadyRegistered)
                            {
                                <span class="sb sb-green flex-shrink-0">Đã đăng ký</span>
                            }
                            else if (isFull)
                            {
                                <span class="sb sb-gray flex-shrink-0">Hết chỗ</span>
                            }
                        </div>
                    </div>
                    <div class="topic-card-body">
                        <p class="topic-desc">@topic.Description</p>

                        @if (!string.IsNullOrEmpty(topic.Technologies))
                        {
                            <div class="topic-tech-wrap">
                                @foreach (var tech in topic.Technologies.Split(','))
                                {
                                    <span class="tech-tag">@tech.Trim()</span>
                                }
                            </div>
                        }

                        <div class="topic-meta">
                            <span class="topic-lecturer">@topic.LecturerName</span>
                            <span class="slot-info">
                                <span style="font-weight:600; color:@(pct >= 100 ? "#dc2626" : "#374151");">@topic.RegisteredCount</span>
                                <span>/ @topic.MaxStudents SV</span>
                            </span>
                        </div>
                    </div>

                    <div style="padding:0 16px; margin-bottom:12px;">
                        <div class="slot-bar">
                            <div class="slot-bar-fill @(pct >= 100 ? "full" : "")" style="width:@pct%"></div>
                        </div>
                    </div>

                    <div class="topic-card-foot">
                        @if (topic.AlreadyRegistered)
                        {
                            <span class="btn-register-done">Bạn đã đăng ký đề tài này</span>
                        }
                        else if (isFull)
                        {
                            <span class="btn-register-full">Hết chỗ đăng ký</span>
                        }
                        else
                        {
                            <form asp-action="Register" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="topicId" value="@topic.TopicId" />
                                <button type="submit" class="btn-register"
                                        onclick="return confirm('Xác nhận đăng ký đề tài này?')">
                                    Đăng ký
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="mt-4">
    <a asp-action="MyRegistrations" class="btn btn-outline-secondary">Xem đăng ký của tôi</a>
</div>
