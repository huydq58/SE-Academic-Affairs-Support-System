@model SE_Academic_Affairs_Support_System.ViewModels.LecturerTopicsViewModel
@using SE_Academic_Affairs_Support_System.Models
@{
    ViewData["Title"] = "Đề tài của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .rg-page-title { border-left:4px solid #2563eb; padding-left:14px; margin-bottom:24px; }
    .rg-page-title h2 { font-size:22px; font-weight:700; color:#1e3a8a; margin-bottom:3px; }
    .rg-page-title p  { font-size:13px; color:#6b7280; margin:0; }

    .sb { display:inline-block; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:600; white-space:nowrap; }
    .sb-green { background:#dcfce7; color:#166534; border:1px solid #bbf7d0; }
    .sb-gray  { background:#f1f5f9; color:#475569; border:1px solid #e2e8f0; }
    .sb-amber { background:#fef3c7; color:#92400e; border:1px solid #fde68a; }
    .sb-red   { background:#fee2e2; color:#991b1b; border:1px solid #fecaca; }
    .sb-blue  { background:#dbeafe; color:#1d4ed8; border:1px solid #bfdbfe; }

    .slot-badge { font-size:13px; font-weight:700; }
    .slot-full { color:#dc2626; }
    .slot-ok   { color:#16a34a; }

    .dt-wrap { border:1px solid #e5e7eb; border-radius:10px; overflow:hidden; }
    .dt { border-collapse:collapse; width:100%; }
    .dt thead th { background:#f8fafc; padding:12px 16px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:#64748b; border-bottom:1px solid #e5e7eb; white-space:nowrap; }
    .dt tbody td { padding:13px 16px; border-bottom:1px solid #f1f5f9; vertical-align:middle; font-size:14px; color:#374151; }
    .dt tbody tr:last-child td { border-bottom:none; }
    .dt tbody tr:hover td { background:#f8fafc; }

    .btn-del { display:inline-flex; align-items:center; padding:5px 12px; border-radius:6px; font-size:12px; font-weight:600; cursor:pointer; border:1px solid #fecaca; background:#fff; color:#dc2626; transition:all .15s; }
    .btn-del:hover { background:#fee2e2; border-color:#fca5a5; }

    @@media (max-width:767px) {
        .dt-wrap { border-radius:0; border-left:none; border-right:none; overflow:visible; }
        .dt thead { display:none; }
        .dt, .dt tbody { display:block; }
        .dt tr { display:block; border:1px solid #e5e7eb; border-radius:10px; margin-bottom:10px; background:#fff; box-shadow:0 1px 3px rgba(0,0,0,.06); }
        .dt td { display:flex; flex-direction:column; padding:10px 14px; border-bottom:1px solid #f3f4f6; font-size:14px; }
        .dt td:last-child { border-bottom:none; }
        .dt td::before { content:attr(data-label); font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#9ca3af; margin-bottom:5px; }
        .dt tbody tr:hover td { background:transparent; }
    }
</style>

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div class="rg-page-title mb-0">
        <h2>Đề Tài Của Tôi</h2>
        <p>Quản lý các đề tài đã tạo trong đợt đăng ký</p>
    </div>
    @if (Model.ActivePeriod != null)
    {
        <a asp-action="CreateTopic" class="btn btn-primary flex-shrink-0">Tạo đề tài mới</a>
    }
</div>

<partial name="_Alerts" />

@if (!Model.Topics.Any())
{
    <div class="text-center py-5" style="color:#9ca3af;">
        <p style="font-size:16px; font-weight:600; margin-bottom:8px; color:#374151;">Bạn chưa có đề tài nào.</p>
        @if (Model.ActivePeriod != null)
        {
            <a asp-action="CreateTopic" class="btn btn-primary mt-2">Tạo đề tài mới</a>
        }
        else
        {
            <p style="font-size:14px;">Hiện không có đợt đăng ký nào đang hoạt động.</p>
        }
    </div>
}
else
{
    <div class="dt-wrap">
        <table class="dt">
            <thead>
                <tr>
                    <th>Tên đề tài</th>
                    <th>SV đăng ký</th>
                    <th>Đợt</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Topics)
                {
                    <tr>
                        <td data-label="Tên đề tài">
                            <span class="fw-semibold" style="color:#1e3a8a;">@t.Title</span>
                        </td>
                        <td data-label="SV đăng ký">
                            <span class="slot-badge @(t.RegisteredCount >= t.MaxStudents ? "slot-full" : "slot-ok")">
                                @t.RegisteredCount / @t.MaxStudents
                            </span>
                        </td>
                        <td data-label="Đợt">
                            <span style="font-size:13px; color:#6b7280;">@t.PeriodName</span>
                        </td>
                        <td data-label="Trạng thái">
                            <span class="sb @(t.Status == TopicStatus.Open ? "sb-green" : t.Status == TopicStatus.Proposed ? "sb-blue" : "sb-gray")">
                                @(t.Status == TopicStatus.Open ? "Mở" : t.Status == TopicStatus.Closed ? "Đóng" : t.Status == TopicStatus.Proposed ? "Đề xuất" : "?")
                            </span>
                        </td>
                        <td data-label="Thao tác">
                            <form asp-action="DeleteTopic" method="post" style="margin:0"
                                  onsubmit="return confirm('Xác nhận xóa đề tài này?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="topicId" value="@t.TopicId" />
                                <button type="submit" class="btn-del">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
