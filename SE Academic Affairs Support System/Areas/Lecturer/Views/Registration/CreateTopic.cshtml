@model SE_Academic_Affairs_Support_System.ViewModels.CreateTopicViewModel
@{
    ViewData["Title"] = "Tạo đề tài mới";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<div class="container py-4" style="max-width:680px">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="MyTopics">Đề tài của tôi</a></li>
            <li class="breadcrumb-item active">Tạo đề tài mới</li>
        </ol>
    </nav>

    <h2 class="mb-4"><i class="bi bi-journal-plus text-primary me-2"></i>Tạo đề tài mới</h2>

    <form asp-asp-area="Lecturer" asp-action="CreateTopic" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="RegistrationPeriodId" />

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold"></label>
                    <input asp-for="Title" class="form-control" placeholder="Tên đề tài..." />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"
                              placeholder="Mô tả chi tiết về đề tài..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Requirements" class="form-label fw-semibold"></label>
                    <textarea asp-for="Requirements" class="form-control" rows="2"
                              placeholder="Ví dụ: SV cần biết C#, đã học môn CSDL..."></textarea>
                    <span asp-validation-for="Requirements" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Technologies" class="form-label fw-semibold"></label>
                    <input asp-for="Technologies" class="form-control"
                           placeholder="ASP.NET Core, SQL Server, React (phân cách bằng dấu phẩy)" />
                </div>

                <div class="mb-4">
                    <label asp-for="MaxStudents" class="form-label fw-semibold"></label>
                    <input asp-for="MaxStudents" type="number" min="1" max="10"
                           class="form-control" style="width:120px" />
                    <span asp-validation-for="MaxStudents" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-plus-lg me-1"></i> Tạo đề tài
                    </button>
                    <a asp-action="MyTopics" class="btn btn-outline-secondary">Hủy</a>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
