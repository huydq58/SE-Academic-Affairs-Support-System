@model SE_Academic_Affairs_Support_System.ViewModels.ReviewDecisionViewModel
@{
    ViewData["Title"] = "Xem xét đề xuất";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .rg-page-title { border-left:4px solid #2563eb; padding-left:14px; margin-bottom:24px; }
    .rg-page-title h2 { font-size:22px; font-weight:700; color:#1e3a8a; margin-bottom:3px; }
    .rg-page-title p  { font-size:13px; color:#6b7280; margin:0; }

    .rg-card { border:1px solid #dbeafe; border-radius:10px; overflow:hidden; margin-bottom:20px; }
    .rg-card-head { background:#eff6ff; border-bottom:1px solid #bfdbfe; padding:13px 20px; font-size:14px; font-weight:700; color:#1e3a8a; }
    .rg-card-body { background:#fff; padding:24px; }

    .info-row { display:flex; gap:12px; padding:9px 0; border-bottom:1px solid #f1f5f9; font-size:14px; }
    .info-row:last-child { border-bottom:none; padding-bottom:0; }
    .info-lbl { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:#9ca3af; min-width:120px; flex-shrink:0; padding-top:2px; }
    .info-val { color:#374151; line-height:1.6; flex:1; }

    .tech-tag { background:#f1f5f9; border:1px solid #e2e8f0; color:#475569; padding:2px 8px; border-radius:6px; font-size:11px; font-weight:500; display:inline-block; margin:2px 2px 2px 0; }

    .sb { display:inline-block; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:600; white-space:nowrap; }
    .sb-blue { background:#dbeafe; color:#1d4ed8; border:1px solid #bfdbfe; }

    .decision-opts { display:flex; gap:0; flex-wrap:wrap; border:1px solid #e5e7eb; border-radius:8px; overflow:hidden; margin-bottom:4px; }
    .decision-opt { flex:1; min-width:120px; }
    .decision-opt input { display:none; }
    .decision-opt label { display:block; padding:11px 16px; text-align:center; font-size:13px; font-weight:600; cursor:pointer; border-right:1px solid #e5e7eb; transition:all .15s; color:#6b7280; background:#fff; }
    .decision-opt:last-child label { border-right:none; }
    .decision-opt input:checked + label.approve { background:#dcfce7; color:#166534; }
    .decision-opt input:checked + label.revise  { background:#fef3c7; color:#92400e; }
    .decision-opt input:checked + label.reject  { background:#fee2e2; color:#991b1b; }
    .decision-opt label:hover { background:#f8fafc; }

    .form-control:focus { border-color:#2563eb; box-shadow:0 0 0 3px rgba(37,99,235,.12); }

    @@media (max-width:600px) {
        .decision-opts { flex-direction:column; }
        .decision-opt label { border-right:none; border-bottom:1px solid #e5e7eb; }
        .decision-opt:last-child label { border-bottom:none; }
        .info-row { flex-direction:column; gap:4px; }
        .info-lbl { min-width:unset; }
    }
</style>

<div style="max-width:780px;">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Inbox">Hộp thư</a></li>
            <li class="breadcrumb-item active">Xem xét đề xuất</li>
        </ol>
    </nav>

    <div class="rg-page-title">
        <h2>Xem Xét Đề Xuất</h2>
        <p>Xem thông tin đề xuất và đưa ra quyết định duyệt, yêu cầu sửa hoặc từ chối</p>
    </div>

    <partial name="_Alerts" />

    @if (Model.Proposal != null)
    {
        var p = Model.Proposal;
        <div class="rg-card">
            <div class="rg-card-head">Thông tin đề xuất</div>
            <div class="rg-card-body">
                <div class="info-row">
                    <span class="info-lbl">Sinh viên</span>
                    <span class="info-val">
                        <strong>@p.StudentName</strong>
                        <span style="color:#9ca3af; margin-left:6px;">(@p.StudentCode)</span>
                    </span>
                </div>
                <div class="info-row">
                    <span class="info-lbl">Đợt đăng ký</span>
                    <span class="info-val">@p.PeriodName</span>
                </div>
                <div class="info-row">
                    <span class="info-lbl">Tên đề tài</span>
                    <span class="info-val fw-semibold" style="color:#1e3a8a;">@p.ProposedTitle</span>
                </div>
                <div class="info-row">
                    <span class="info-lbl">Mô tả / Mục tiêu</span>
                    <span class="info-val" style="white-space:pre-wrap; background:#f8fafc; border:1px solid #e5e7eb; border-radius:6px; padding:10px; display:block;">@p.ProposedDescription</span>
                </div>
                @if (!string.IsNullOrEmpty(p.ProposedTechnologies))
                {
                    <div class="info-row">
                        <span class="info-lbl">Công nghệ</span>
                        <span class="info-val">
                            @foreach (var tech in p.ProposedTechnologies.Split(','))
                            {
                                <span class="tech-tag">@tech.Trim()</span>
                            }
                        </span>
                    </div>
                }
                <div class="info-row">
                    <span class="info-lbl">Ngày gửi</span>
                    <span class="info-val">@p.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                @if (p.RevisionCount > 0)
                {
                    <div class="info-row">
                        <span class="info-lbl">Lần chỉnh sửa</span>
                        <span class="info-val">
                            <span class="sb sb-blue">Lần @p.RevisionCount</span>
                        </span>
                    </div>
                }
            </div>
        </div>
    }

    <div class="rg-card">
        <div class="rg-card-head">Quyết định</div>
        <div class="rg-card-body">
            <form asp-action="Review" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="RegistrationId" />

                <div class="mb-3">
                    <label class="form-label fw-semibold" style="font-size:13px; text-transform:uppercase; letter-spacing:.04em; color:#6b7280;">Chọn hành động</label>
                    <div class="decision-opts">
                        <div class="decision-opt">
                            <input type="radio" asp-for="Decision" value="approve" id="decApprove" />
                            <label class="approve" for="decApprove">Duyệt</label>
                        </div>
                        <div class="decision-opt">
                            <input type="radio" asp-for="Decision" value="revise" id="decRevise" />
                            <label class="revise" for="decRevise">Yêu cầu chỉnh sửa</label>
                        </div>
                        <div class="decision-opt">
                            <input type="radio" asp-for="Decision" value="reject" id="decReject" />
                            <label class="reject" for="decReject">Từ chối</label>
                        </div>
                    </div>
                    <span asp-validation-for="Decision" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Note" class="form-label fw-semibold">Ghi chú</label>
                    <textarea asp-for="Note" class="form-control" rows="4"
                              placeholder="Nhập ghi chú, lý do từ chối hoặc yêu cầu chỉnh sửa..."></textarea>
                    <span asp-validation-for="Note" class="text-danger small"></span>
                    <div class="form-text" id="noteHint" style="color:#d97706; font-weight:500;"></div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">Xác nhận quyết định</button>
                    <a asp-action="Inbox" class="btn btn-outline-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const radios = document.querySelectorAll('input[name="Decision"]');
        const hint = document.getElementById('noteHint');

        function updateHint() {
            const val = document.querySelector('input[name="Decision"]:checked')?.value;
            hint.textContent = val === 'revise'
                ? 'Bắt buộc: Mô tả rõ điều cần sửa để sinh viên biết cách chỉnh lại.'
                : val === 'reject'
                    ? 'Không bắt buộc: Có thể giải thích lý do để sinh viên biết.'
                    : '';
        }

        radios.forEach(r => r.addEventListener('change', updateHint));
        updateHint();
    </script>
}
