@model SE_Academic_Affairs_Support_System.ViewModels.ReviewDecisionViewModel
@{
    ViewData["Title"] = "Xem xét đề xuất";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<div class="container py-4" style="max-width:760px">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Inbox">Hộp thư</a></li>
            <li class="breadcrumb-item active">Xem xét đề xuất</li>
        </ol>
    </nav>

    <h2 class="mb-4"><i class="bi bi-file-earmark-check text-primary me-2"></i>Xem xét đề xuất</h2>

    <partial name="_Alerts" />

    @if (Model.Proposal != null)
    {
        var p = Model.Proposal;

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-light fw-semibold py-3">
                <i class="bi bi-info-circle me-2 text-primary"></i>Thông tin đề xuất
            </div>
            <div class="card-body p-4">
                <dl class="row mb-0">
                    <dt class="col-sm-3 text-muted">Sinh viên</dt>
                    <dd class="col-sm-9">
                        <strong>@p.StudentName</strong>
                        <span class="text-muted ms-2">(@p.StudentCode)</span>
                    </dd>

                    <dt class="col-sm-3 text-muted">Đợt đăng ký</dt>
                    <dd class="col-sm-9">@p.PeriodName</dd>

                    <dt class="col-sm-3 text-muted">Tên đề tài</dt>
                    <dd class="col-sm-9 fw-semibold">@p.ProposedTitle</dd>

                    <dt class="col-sm-3 text-muted">Mô tả / Mục tiêu</dt>
                    <dd class="col-sm-9" style="white-space:pre-wrap">@p.ProposedDescription</dd>

                    @if (!string.IsNullOrEmpty(p.ProposedTechnologies))
                    {
                        <dt class="col-sm-3 text-muted">Công nghệ</dt>
                        <dd class="col-sm-9">
                            @foreach (var tech in p.ProposedTechnologies.Split(','))
                            {
                                <span class="badge bg-light text-dark border me-1">@tech.Trim()</span>
                            }
                        </dd>
                    }

                    <dt class="col-sm-3 text-muted">Ngày gửi</dt>
                    <dd class="col-sm-9">@p.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                    @if (p.RevisionCount > 0)
                    {
                        <dt class="col-sm-3 text-muted">Lần chỉnh sửa</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-info text-dark">Lần @p.RevisionCount</span>
                        </dd>
                    }
                </dl>
            </div>
        </div>
    }

    {{!-- Decision form --}}
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-light fw-semibold py-3">
            <i class="bi bi-check2-all me-2 text-success"></i>Quyết định
        </div>
        <div class="card-body p-4">
            <form asp-action="Review" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="RegistrationId" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Chọn hành động</label>
                    <div class="d-flex gap-3 flex-wrap">
                        <div class="form-check">
                            <input class="form-check-input" type="radio"
                                   asp-for="Decision" value="approve" id="decApprove" />
                            <label class="form-check-label text-success fw-semibold" for="decApprove">
                                <i class="bi bi-check-circle-fill me-1"></i> Duyệt
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio"
                                   asp-for="Decision" value="revise" id="decRevise" />
                            <label class="form-check-label text-warning fw-semibold" for="decRevise">
                                <i class="bi bi-arrow-repeat me-1"></i> Yêu cầu chỉnh sửa
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio"
                                   asp-for="Decision" value="reject" id="decReject" />
                            <label class="form-check-label text-danger fw-semibold" for="decReject">
                                <i class="bi bi-x-circle-fill me-1"></i> Từ chối
                            </label>
                        </div>
                    </div>
                    <span asp-validation-for="Decision" class="text-danger small"></span>
                </div>

                <div class="mb-4" id="noteBlock">
                    <label asp-for="Note" class="form-label fw-semibold"></label>
                    <textarea asp-for="Note" class="form-control" rows="4"
                              placeholder="Nhập ghi chú, lý do từ chối hoặc yêu cầu chỉnh sửa..."></textarea>
                    <span asp-validation-for="Note" class="text-danger small"></span>
                    <div class="form-text" id="noteHint"></div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-send-fill me-1"></i> Xác nhận quyết định
                    </button>
                    <a asp-action="Inbox" class="btn btn-outline-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const radios = document.querySelectorAll('input[name="Decision"]');
        const hint = document.getElementById('noteHint');

        function updateHint() {
            const val = document.querySelector('input[name="Decision"]:checked')?.value;
            hint.textContent = val === 'revise'
                ? 'Bắt buộc: Mô tả rõ điều cần sửa để sinh viên biết cách chỉnh lại.'
                : val === 'reject'
                    ? 'Không bắt buộc: Có thể giải thích lý do để sinh viên biết.'
                    : '';
        }

        radios.forEach(r => r.addEventListener('change', updateHint));
        updateHint();
    </script>
}
