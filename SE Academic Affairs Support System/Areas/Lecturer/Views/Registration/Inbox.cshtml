@model SE_Academic_Affairs_Support_System.ViewModels.LecturerInboxViewModel
@using SE_Academic_Affairs_Support_System.Models
@{
    ViewData["Title"] = "Hộp thư – Duyệt đề xuất";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .rg-page-title { border-left:4px solid #2563eb; padding-left:14px; margin-bottom:24px; }
    .rg-page-title h2 { font-size:22px; font-weight:700; color:#1e3a8a; margin-bottom:3px; }
    .rg-page-title p  { font-size:13px; color:#6b7280; margin:0; }

    .stat-box { background:#fff; border:1px solid #e5e7eb; border-radius:10px; padding:18px 14px; text-align:center; }
    .stat-num  { font-size:28px; font-weight:700; line-height:1; margin-bottom:4px; }
    .stat-lbl  { font-size:12px; color:#6b7280; font-weight:500; }
    .sn-amber { color:#d97706; }
    .sn-green { color:#16a34a; }
    .sn-blue  { color:#2563eb; }

    .section-head { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:#9ca3af; margin-bottom:14px; padding-bottom:8px; border-bottom:1px solid #f1f5f9; margin-top:28px; }

    .proposal-card { border:1px solid #dbeafe; border-left:4px solid #2563eb; border-radius:10px; background:#fff; padding:16px 18px; margin-bottom:12px; }
    .proposal-card:hover { box-shadow:0 4px 16px rgba(37,99,235,.08); }
    .proposal-title { font-size:15px; font-weight:700; color:#1e3a8a; margin-bottom:8px; }
    .proposal-meta { display:flex; flex-wrap:wrap; gap:6px 18px; font-size:13px; color:#6b7280; margin-bottom:10px; }
    .proposal-meta strong { color:#374151; }
    .proposal-desc { font-size:13px; color:#6b7280; line-height:1.6; margin-bottom:12px; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; }

    .sb { display:inline-block; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:600; white-space:nowrap; }
    .sb-green { background:#dcfce7; color:#166534; border:1px solid #bbf7d0; }
    .sb-red   { background:#fee2e2; color:#991b1b; border:1px solid #fecaca; }
    .sb-amber { background:#fef3c7; color:#92400e; border:1px solid #fde68a; }
    .sb-blue  { background:#dbeafe; color:#1d4ed8; border:1px solid #bfdbfe; }
    .sb-gray  { background:#f1f5f9; color:#475569; border:1px solid #e2e8f0; }

    .dt-wrap { border:1px solid #e5e7eb; border-radius:10px; overflow:hidden; }
    .dt { border-collapse:collapse; width:100%; }
    .dt thead th { background:#f8fafc; padding:11px 14px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:#64748b; border-bottom:1px solid #e5e7eb; white-space:nowrap; }
    .dt tbody td { padding:12px 14px; border-bottom:1px solid #f1f5f9; vertical-align:middle; font-size:14px; color:#374151; }
    .dt tbody tr:last-child td { border-bottom:none; }
    .dt tbody tr:hover td { background:#f8fafc; }

    .empty-box { background:#f8fafc; border:1px solid #e5e7eb; border-radius:10px; padding:28px; text-align:center; color:#9ca3af; font-size:14px; }

    @@media (max-width:767px) {
        .dt-wrap { border-radius:0; border-left:none; border-right:none; overflow:visible; }
        .dt thead { display:none; }
        .dt, .dt tbody { display:block; }
        .dt tr { display:block; border:1px solid #e5e7eb; border-radius:10px; margin-bottom:10px; background:#fff; }
        .dt td { display:flex; flex-direction:column; padding:10px 14px; border-bottom:1px solid #f3f4f6; }
        .dt td:last-child { border-bottom:none; }
        .dt td::before { content:attr(data-label); font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#9ca3af; margin-bottom:5px; }
        .dt tbody tr:hover td { background:transparent; }
        .proposal-actions { flex-direction:column; align-items:stretch; }
    }
</style>

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div class="rg-page-title mb-0">
        <h2>Hộp Thư Duyệt Đề Tài</h2>
        <p>Xem xét và phê duyệt các đề xuất đề tài từ sinh viên</p>
    </div>
    <a asp-action="MyTopics" class="btn btn-outline-secondary flex-shrink-0">Quản lý đề tài của tôi</a>
</div>

<partial name="_Alerts" />

<div class="row g-3 mb-2">
    <div class="col-4">
        <div class="stat-box">
            <div class="stat-num sn-amber">@Model.PendingProposals.Count</div>
            <div class="stat-lbl">Chờ duyệt</div>
        </div>
    </div>
    <div class="col-4">
        <div class="stat-box">
            <div class="stat-num sn-green">@Model.TotalApprovedCount</div>
            <div class="stat-lbl">Đã duyệt</div>
        </div>
    </div>
    <div class="col-4">
        <div class="stat-box">
            <div class="stat-num sn-blue">@Model.MaxStudentsAllowed</div>
            <div class="stat-lbl">Chỉ tiêu SV</div>
        </div>
    </div>
</div>

<div class="section-head">
    Đề xuất chờ duyệt
    @if (Model.PendingProposals.Count > 0)
    {
        <span class="sb sb-amber ms-1">@Model.PendingProposals.Count</span>
    }
</div>

@if (!Model.PendingProposals.Any())
{
    <div class="empty-box">Không có đề xuất nào đang chờ duyệt.</div>
}
else
{
    @foreach (var p in Model.PendingProposals)
    {
        <div class="proposal-card">
            <div class="proposal-title">@p.ProposedTitle</div>
            <div class="proposal-meta">
                <span><strong>@p.StudentName</strong> (@p.StudentCode)</span>
                <span>@p.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</span>
                @if (p.RevisionCount > 0)
                {
                    <span class="sb sb-blue">Lần sửa thứ @p.RevisionCount</span>
                }
            </div>
            <div class="proposal-desc">@p.ProposedDescription</div>
            <div class="d-flex flex-wrap gap-2 proposal-actions">
                <a asp-action="Review" asp-route-id="@p.RegistrationId"
                   class="btn btn-primary btn-sm px-3">
                    Xem &amp; Duyệt
                </a>
            </div>
        </div>
    }
}

@if (Model.RecentlyActioned.Any())
{
    <div class="section-head">Đã xử lý gần đây</div>
    <div class="dt-wrap">
        <table class="dt">
            <thead>
                <tr>
                    <th>Sinh viên</th>
                    <th>Tên đề tài</th>
                    <th>Đợt</th>
                    <th>Trạng thái</th>
                    <th>Cập nhật</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.RecentlyActioned)
                {
                    <tr>
                        <td data-label="Sinh viên">
                            <span class="fw-semibold">@p.StudentName</span>
                            <span style="color:#9ca3af; font-size:12px; margin-left:4px;">(@p.StudentCode)</span>
                        </td>
                        <td data-label="Tên đề tài" style="max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                            @p.ProposedTitle
                        </td>
                        <td data-label="Đợt" style="font-size:13px; color:#6b7280;">@p.PeriodName</td>
                        <td data-label="Trạng thái">
                            <span class="sb @(p.Status == RegistrationStatus.APPROVED ? "sb-green" : p.Status == RegistrationStatus.REJECTED ? "sb-red" : p.Status == RegistrationStatus.REVISION_REQUIRED ? "sb-blue" : "sb-gray")">
                                @(p.Status == RegistrationStatus.APPROVED ? "Đã duyệt" : p.Status == RegistrationStatus.REJECTED ? "Từ chối" : p.Status == RegistrationStatus.REVISION_REQUIRED ? "Yêu cầu sửa" : "Khác")
                            </span>
                        </td>
                        <td data-label="Cập nhật" style="font-size:13px; color:#6b7280;">@p.UpdatedAt.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
