@model IEnumerable<SE_Academic_Affairs_Support_System.Models.RegistrationPeriod>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Đợt đăng ký đề tài";
}

<style>
    .rg-page-title { border-left:4px solid #2563eb; padding-left:14px; margin-bottom:24px; }
    .rg-page-title h2 { font-size:22px; font-weight:700; color:#1e3a8a; margin-bottom:3px; }
    .rg-page-title p  { font-size:13px; color:#6b7280; margin:0; }

    .period-card { border:1px solid #dbeafe; border-radius:10px; background:#fff; overflow:hidden; height:100%; display:flex; flex-direction:column; }
    .period-card-head { background:#eff6ff; border-bottom:1px solid #bfdbfe; padding:14px 18px; }
    .period-card-head h5 { font-size:15px; font-weight:700; color:#1e3a8a; margin:0; }
    .period-card-body { padding:16px 18px; flex:1; display:flex; flex-direction:column; }
    .period-meta { display:flex; flex-direction:column; gap:8px; margin-bottom:18px; flex:1; }
    .period-meta-row { display:flex; gap:10px; font-size:13px; align-items:baseline; }
    .period-meta-lbl { font-weight:600; color:#6b7280; min-width:72px; flex-shrink:0; font-size:12px; text-transform:uppercase; letter-spacing:.04em; }
    .period-meta-val { color:#374151; }

    .btn-period-primary { display:inline-block; padding:9px 18px; background:#2563eb; color:#fff; border-radius:8px; font-size:13px; font-weight:700; text-decoration:none; transition:all .15s; border:1px solid #2563eb; }
    .btn-period-primary:hover { background:#1d4ed8; color:#fff; border-color:#1d4ed8; }
    .btn-period-grade { display:inline-block; padding:9px 18px; background:#d97706; color:#fff; border-radius:8px; font-size:13px; font-weight:700; text-decoration:none; transition:all .15s; border:1px solid #d97706; }
    .btn-period-grade:hover { background:#b45309; color:#fff; border-color:#b45309; }
    .btn-period-outline { display:inline-block; padding:9px 18px; background:#fff; color:#16a34a; border-radius:8px; font-size:13px; font-weight:700; text-decoration:none; transition:all .15s; border:1px solid #bbf7d0; }
    .btn-period-outline:hover { background:#dcfce7; color:#15803d; }

    @@media (max-width:600px) {
        .period-actions { flex-direction:column; }
        .btn-period-primary, .btn-period-grade, .btn-period-outline { text-align:center; }
    }
</style>

<div class="rg-page-title">
    <h2>Danh Sách Đợt Đăng Ký</h2>
    <p>Các đợt đăng ký đề tài đang diễn ra</p>
</div>

<partial name="_Alerts" />

@if (!Model.Any())
{
    <div class="text-center py-5" style="color:#9ca3af;">
        <p style="font-size:16px; font-weight:600; margin-bottom:8px; color:#374151;">Hiện không có đợt đăng ký nào đang diễn ra.</p>
        <p style="font-size:14px;">Vui lòng quay lại sau hoặc liên hệ quản trị viên để biết thêm thông tin.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var item in Model)
        {
            <div class="col-md-6">
                <div class="period-card">
                    <div class="period-card-head">
                        <h5>@item.Name</h5>
                    </div>
                    <div class="period-card-body">
                        <div class="period-meta">
                            <div class="period-meta-row">
                                <span class="period-meta-lbl">Học phần</span>
                                <span class="period-meta-val">@item.CourseName</span>
                            </div>
                            <div class="period-meta-row">
                                <span class="period-meta-lbl">Hạn cuối</span>
                                <span class="period-meta-val" style="color:#dc2626; font-weight:600;">
                                    @item.EndDate.ToString("dd/MM/yyyy HH:mm")
                                </span>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(item.GoogleSheetLink))
                        {
                            <div class="d-flex flex-wrap gap-2 period-actions">
                                @if (User.IsInRole("Student"))
                                {
                                    <a asp-controller="Topic" asp-action="List"
                                       asp-route-periodId="@item.Id"
                                       class="btn-period-primary">
                                        Xem &amp; Đăng ký đề tài
                                    </a>
                                }
                                @if (User.IsInRole("Lecturer") || User.IsInRole("Admin"))
                                {
                                    <a asp-controller="Grading" asp-action="List"
                                       asp-route-periodId="@item.Id"
                                       class="btn-period-grade">
                                        Chấm điểm
                                    </a>
                                }
                                <a href="@item.GoogleSheetLink" target="_blank"
                                   class="btn-period-outline">
                                    Mở Google Sheet
                                </a>
                            </div>
                        }
                        else
                        {
                            <span style="font-size:13px; color:#9ca3af;">Chưa có link tài liệu</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
