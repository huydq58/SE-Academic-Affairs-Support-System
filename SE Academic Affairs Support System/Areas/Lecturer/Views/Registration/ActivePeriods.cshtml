@model IEnumerable<SE_Academic_Affairs_Support_System.Models.RegistrationPeriod>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2 class="mb-4">Danh Sách Đợt Đăng Ký Đang Mở</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Hiện không có đợt đăng ký nào đang diễn ra.</div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-6 mb-3">
                    <div class="card border-primary">
                        <div class="card-body">
                            <h5 class="card-title text-primary">@item.Name</h5>
                            <p class="card-text">
                                <strong>Học phần:</strong> @item.CourseName <br />
                                <strong>Kết thúc:</strong> @item.EndDate.ToString("dd/MM/yyyy HH:mm")
                            </p>

                            @if (!string.IsNullOrEmpty(item.GoogleSheetLink))
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @* Nút đăng ký — chỉ sinh viên *@
                                    @if (User.IsInRole("Student"))
                                    {
                                        <a asp-controller="Topic" asp-action="List"
                                           asp-route-periodId="@item.Id"
                                           class="btn btn-primary">
                                            <i class="fas fa-list-ul me-1"></i>Xem & Đăng ký đề tài
                                        </a>
                                    }

                                    @* Nút chấm điểm — Lecturer và Admin *@
                                    @if (User.IsInRole("Lecturer") || User.IsInRole("Admin"))
                                    {
                                        <a asp-controller="Grading" asp-action="List"
                                           asp-route-periodId="@item.Id"
                                           class="btn btn-warning">
                                            <i class="fas fa-star me-1"></i>Chấm điểm
                                        </a>
                                    }

                                    <a href="@item.GoogleSheetLink" target="_blank"
                                       class="btn btn-outline-success">
                                        <i class="fas fa-file-excel me-1"></i>Mở Google Sheet
                                    </a>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-secondary" disabled>Chưa có link tài liệu</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
