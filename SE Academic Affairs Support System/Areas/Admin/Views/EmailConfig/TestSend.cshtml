@model SE_Academic_Affairs_Support_System.ViewModels.EmailConfigTestViewModel
@{
    ViewData["Title"] = "Gửi email thử";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="rg-page-title mb-4">
    <h2>Gửi email thử</h2>
    <p>Kiểm tra cấu hình: <strong>@ViewBag.ConfigName</strong></p>
</div>

<partial name="_Alerts" />

<div style="max-width:480px;">
    <form asp-area="Admin" asp-controller="EmailConfig" asp-action="TestSend" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ConfigId" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="font-size:13px;"></div>

        <div class="mb-3">
            <label asp-for="TestEmail" class="form-label fw-semibold"></label>
            <input asp-for="TestEmail" class="form-control" type="email" placeholder="recipient@example.com" />
            <span asp-validation-for="TestEmail" class="text-danger" style="font-size:12px;"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4">Gửi thử</button>
            <a asp-area="Admin" asp-controller="EmailConfig" asp-action="Index"
               class="btn btn-outline-secondary px-4">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
