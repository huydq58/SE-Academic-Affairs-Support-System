@model SE_Academic_Affairs_Support_System.ViewModels.EmailConfigFormViewModel
@{
    ViewData["Title"] = Model.IsEditMode ? "Sửa cấu hình Email" : "Thêm cấu hình Email";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="rg-page-title mb-4">
    <h2>@ViewData["Title"]</h2>
    <p>
        @if (Model.IsEditMode)
        {
            <text>Cập nhật thông tin cấu hình. Để trống App Password để giữ nguyên mật khẩu cũ.</text>
        }
        else
        {
            <text>Nhập thông tin SMTP để hệ thống gửi email thông báo.</text>
        }
    </p>
</div>

<partial name="_Alerts" />

<div style="max-width:600px;">
    <form asp-area="Admin" asp-controller="EmailConfig"
          asp-action="@(Model.IsEditMode ? "Edit" : "Create")"
          method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="font-size:13px;"></div>

        <div class="mb-3">
            <label asp-for="DisplayName" class="form-label fw-semibold"></label>
            <input asp-for="DisplayName" class="form-control" placeholder="VD: Gmail chính thức" />
            <span asp-validation-for="DisplayName" class="text-danger" style="font-size:12px;"></span>
        </div>

        <div class="mb-3">
            <label asp-for="SenderEmail" class="form-label fw-semibold"></label>
            <input asp-for="SenderEmail" class="form-control" type="email" placeholder="example@gmail.com" />
            <span asp-validation-for="SenderEmail" class="text-danger" style="font-size:12px;"></span>
        </div>

        <div class="mb-3">
            <label asp-for="SenderName" class="form-label fw-semibold"></label>
            <input asp-for="SenderName" class="form-control" placeholder="VD: Học vụ UIT" />
            <span asp-validation-for="SenderName" class="text-danger" style="font-size:12px;"></span>
        </div>

        <div class="mb-3">
            <label asp-for="AppPassword" class="form-label fw-semibold">
                App Password
                @if (Model.IsEditMode)
                {
                    <span style="font-weight:400; color:#6b7280; font-size:12px;">(để trống = giữ nguyên)</span>
                }
            </label>
            <input asp-for="AppPassword" class="form-control" type="password"
                   autocomplete="new-password"
                   placeholder="@(Model.IsEditMode ? "••••••••  (để trống = không đổi)" : "Gmail App Password")" />
            <span asp-validation-for="AppPassword" class="text-danger" style="font-size:12px;"></span>
            <div class="form-text" style="font-size:12px;">
                Dùng Gmail App Password (16 ký tự), không phải mật khẩu tài khoản Google.
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-8">
                <label asp-for="SmtpHost" class="form-label fw-semibold"></label>
                <input asp-for="SmtpHost" class="form-control" />
                <span asp-validation-for="SmtpHost" class="text-danger" style="font-size:12px;"></span>
            </div>
            <div class="col-4">
                <label asp-for="SmtpPort" class="form-label fw-semibold"></label>
                <input asp-for="SmtpPort" class="form-control" type="number" min="1" max="65535" />
                <span asp-validation-for="SmtpPort" class="text-danger" style="font-size:12px;"></span>
            </div>
        </div>

        <div class="mb-4">
            <div class="form-check">
                <input asp-for="EnableSsl" class="form-check-input" type="checkbox" />
                <label asp-for="EnableSsl" class="form-check-label">Bật SSL/TLS</label>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4">
                @(Model.IsEditMode ? "Lưu thay đổi" : "Thêm cấu hình")
            </button>
            <a asp-area="Admin" asp-controller="EmailConfig" asp-action="Index"
               class="btn btn-outline-secondary px-4">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
