@model SE_Academic_Affairs_Support_System.ViewModels.ImportTopicsViewModel
@{
    ViewData["Title"] = "Import đề tài từ file";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div style="border-left:4px solid #2563eb; padding-left:14px;">
        <h2 style="font-size:22px; font-weight:700; color:#1e3a8a; margin-bottom:4px;">Import đề tài từ file</h2>
        <p style="font-size:13px; color:#6b7280; margin:0;">
            Đợt đăng ký: <strong>@Model.PeriodName</strong>
        </p>
    </div>
    <a asp-action="Periods" class="btn btn-outline-secondary" style="font-size:13px;">
        <i class="bi bi-arrow-left me-1"></i>Quay lại
    </a>
</div>

<partial name="_Alerts" />

<div class="row g-4">
    <div class="col-12 col-lg-5">
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
            <div class="card-body p-4">
                <h6 style="font-size:15px; font-weight:700; color:#1e3a8a; margin-bottom:16px;">
                    <i class="bi bi-upload me-2 text-primary"></i>Tải lên file đề tài
                </h6>

                <form asp-action="ImportTopics" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="PeriodId" value="@Model.PeriodId" />

                    <div class="mb-4">
                        <label class="form-label" style="font-size:13px; font-weight:600;">
                            Chọn file <span class="text-danger">*</span>
                        </label>
                        <input type="file" name="File" accept=".xlsx,.csv,.txt"
                               class="form-control" style="font-size:13px;" required />
                        <div class="form-text" style="font-size:12px; color:#6b7280;">
                            Hỗ trợ: .xlsx, .csv, .txt
                        </div>
                        @if (ViewData.ModelState["File"]?.Errors.Count > 0)
                        {
                            <div class="text-danger" style="font-size:12px; margin-top:4px;">
                                @ViewData.ModelState["File"]!.Errors[0].ErrorMessage
                            </div>
                        }
                    </div>

                    <button type="submit" class="btn btn-primary w-100" style="font-size:13px; font-weight:600;">
                        <i class="bi bi-cloud-upload me-1"></i>Import
                    </button>
                </form>
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-4" style="border-radius:12px;">
            <div class="card-body p-4">
                <h6 style="font-size:14px; font-weight:700; color:#1e3a8a; margin-bottom:12px;">
                    <i class="bi bi-info-circle me-2 text-primary"></i>Định dạng file
                </h6>
                <p style="font-size:12px; color:#6b7280; margin-bottom:8px;">
                    File phải có dòng tiêu đề ở dòng đầu. Các cột theo thứ tự:
                </p>
                <div class="table-responsive">
                    <table class="table table-sm mb-0" style="font-size:12px;">
                        <thead style="background:#f8fafc;">
                            <tr>
                                <th style="padding:6px 10px; font-weight:600;">Cột</th>
                                <th style="padding:6px 10px; font-weight:600;">Tên</th>
                                <th style="padding:6px 10px; font-weight:600;">Bắt buộc</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr><td style="padding:5px 10px;">1</td><td style="padding:5px 10px;">LecturerCode</td><td style="padding:5px 10px;"><span style="color:#dc2626;">✓</span></td></tr>
                            <tr><td style="padding:5px 10px;">2</td><td style="padding:5px 10px;">Title</td><td style="padding:5px 10px;"><span style="color:#dc2626;">✓</span></td></tr>
                            <tr><td style="padding:5px 10px;">3</td><td style="padding:5px 10px;">Description</td><td style="padding:5px 10px;"></td></tr>
                            <tr><td style="padding:5px 10px;">4</td><td style="padding:5px 10px;">Requirements</td><td style="padding:5px 10px;"></td></tr>
                            <tr><td style="padding:5px 10px;">5</td><td style="padding:5px 10px;">Technologies</td><td style="padding:5px 10px;"></td></tr>
                            <tr><td style="padding:5px 10px;">6</td><td style="padding:5px 10px;">MaxStudents</td><td style="padding:5px 10px;"></td></tr>
                            <tr><td style="padding:5px 10px;">7</td><td style="padding:5px 10px;">Note</td><td style="padding:5px 10px;"></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @if (Model.IsProcessed)
    {
        <div class="col-12 col-lg-7">
            <div class="card border-0 shadow-sm" style="border-radius:12px;">
                <div class="card-body p-4">
                    <h6 style="font-size:15px; font-weight:700; color:#1e3a8a; margin-bottom:16px;">
                        <i class="bi bi-bar-chart me-2 text-primary"></i>Kết quả import
                    </h6>

                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <div style="background:#dcfce7; border-radius:10px; padding:16px; text-align:center;">
                                <div style="font-size:28px; font-weight:700; color:#166534;">@Model.Created</div>
                                <div style="font-size:13px; color:#166534; font-weight:600;">Đề tài đã thêm</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div style="background:#fef3c7; border-radius:10px; padding:16px; text-align:center;">
                                <div style="font-size:28px; font-weight:700; color:#92400e;">@Model.Skipped</div>
                                <div style="font-size:13px; color:#92400e; font-weight:600;">Dòng bỏ qua</div>
                            </div>
                        </div>
                    </div>

                    @if (Model.Errors.Any())
                    {
                        <div>
                            <p style="font-size:13px; font-weight:600; color:#dc2626; margin-bottom:8px;">
                                <i class="bi bi-exclamation-triangle me-1"></i>Chi tiết lỗi (@Model.Errors.Count dòng)
                            </p>
                            <div style="max-height:300px; overflow-y:auto; background:#fff8f8; border:1px solid #fecaca; border-radius:8px; padding:12px;">
                                @foreach (var err in Model.Errors)
                                {
                                    <div style="font-size:12px; color:#7f1d1d; padding:3px 0; border-bottom:1px solid #fecaca;">
                                        <i class="bi bi-x-circle me-1 text-danger"></i>@err
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div style="text-align:center; padding:20px; color:#166534;">
                            <i class="bi bi-check-circle-fill" style="font-size:32px;"></i>
                            <p style="font-size:13px; margin-top:8px; font-weight:600;">Import hoàn tất không có lỗi!</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
