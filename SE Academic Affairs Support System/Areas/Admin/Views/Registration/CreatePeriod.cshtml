@model SE_Academic_Affairs_Support_System.ViewModels.PeriodFormViewModel
@{
    bool isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Chỉnh sửa đợt đăng ký" : "Tạo đợt đăng ký mới";
    string formAction = isEdit
        ? Url.Action("EditPeriod")!
        : Url.Action("CreatePeriod")!;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .rg-page-title { border-left:4px solid #2563eb; padding-left:14px; margin-bottom:24px; }
    .rg-page-title h2 { font-size:22px; font-weight:700; color:#1e3a8a; margin-bottom:3px; }
    .rg-page-title p  { font-size:13px; color:#6b7280; margin:0; }

    .rg-form-card { border:1px solid #dbeafe; border-radius:10px; overflow:hidden; }
    .rg-form-head { background:#eff6ff; border-bottom:1px solid #bfdbfe; padding:14px 20px; font-size:14px; font-weight:700; color:#1e3a8a; }
    .rg-form-body { background:#fff; padding:24px; }

    .form-control:focus, .form-select:focus {
        border-color:#2563eb;
        box-shadow:0 0 0 3px rgba(37,99,235,.12);
    }
</style>

<div style="max-width:620px;">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Periods">Đợt đăng ký</a></li>
            <li class="breadcrumb-item active">@ViewData["Title"]</li>
        </ol>
    </nav>

    <div class="rg-page-title">
        <h2>@ViewData["Title"]</h2>
        <p>@(isEdit ? "Cập nhật thông tin đợt đăng ký" : "Tạo đợt đăng ký đề tài học phần mới")</p>
    </div>

    <form action="@formAction" method="post">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" asp-for="Id" /> }

        <div class="rg-form-card">
            <div class="rg-form-head">Thông tin đợt đăng ký</div>
            <div class="rg-form-body">

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control"
                           placeholder="Ví dụ: Đồ án tốt nghiệp – HK1 2025-2026" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CourseName" class="form-label fw-semibold"></label>
                    <input asp-for="CourseName" class="form-control"
                           placeholder="Ví dụ: Đồ án tốt nghiệp" />
                    <span asp-validation-for="CourseName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="GoogleSheetLink" class="form-label fw-semibold">Link Google Sheet</label>
                    <input asp-for="GoogleSheetLink" class="form-control"
                           placeholder="https://docs.google.com/spreadsheets/..." />
                    <span asp-validation-for="GoogleSheetLink" class="text-danger small"></span>
                    <div class="form-text">Dùng để lưu bảng đăng ký hoặc theo dõi sinh viên.</div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <label asp-for="StartDate" class="form-label fw-semibold"></label>
                        <input asp-for="StartDate" type="date" class="form-control" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>
                    <div class="col-sm-6">
                        <label asp-for="EndDate" class="form-label fw-semibold"></label>
                        <input asp-for="EndDate" type="date" class="form-control" />
                        <span asp-validation-for="EndDate" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-4" style="background:#f8fafc; border:1px solid #e5e7eb; border-radius:8px; padding:14px 16px;">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold">
                            Kích hoạt đợt đăng ký ngay
                        </label>
                    </div>
                    <div class="form-text mt-1">Chỉ một đợt được kích hoạt tại một thời điểm.</div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        @(isEdit ? "Lưu thay đổi" : "Tạo đợt")
                    </button>
                    <a asp-action="Periods" class="btn btn-outline-secondary">Hủy</a>
                </div>

            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
