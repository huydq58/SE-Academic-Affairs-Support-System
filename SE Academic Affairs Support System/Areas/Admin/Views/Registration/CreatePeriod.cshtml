@model SE_Academic_Affairs_Support_System.ViewModels.PeriodFormViewModel
@{
    bool isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Chỉnh sửa đợt đăng ký" : "Tạo đợt đăng ký mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .restrict-section { border: 1px solid #dbeafe; border-radius: 12px; overflow: hidden; margin-bottom: 20px; }
    .restrict-head    { background: #eff6ff; border-bottom: 1px solid #bfdbfe; padding: 12px 18px; }
    .restrict-head-toggle { display: flex; align-items: center; gap: 10px; cursor: pointer; margin: 0; }
    .restrict-head-toggle .lbl { font-size: 14px; font-weight: 700; color: #1e3a8a; }
    .restrict-head-toggle .sub { font-size: 12px; color: #6b7280; font-weight: 400; margin-left: 4px; }
    .restrict-body    { background: #fff; padding: 18px; display: none; }
    .restrict-body.show { display: block; }

    /* Tab selector */
    .sv-tabs { display: flex; gap: 0; border-bottom: 2px solid #e5e7eb; margin-bottom: 16px; }
    .sv-tab  { padding: 8px 20px; font-size: 13px; font-weight: 600; color: #6b7280; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -2px; transition: color .15s, border-color .15s; user-select: none; }
    .sv-tab:hover  { color: #2563eb; }
    .sv-tab.active { color: #2563eb; border-color: #2563eb; }
    .sv-tab-pane   { display: none; }
    .sv-tab-pane.active { display: block; }

    /* Student checkbox list */
    .sv-search { width: 100%; border: 1px solid #d1d5db; border-radius: 8px; padding: 7px 12px; font-size: 13px; margin-bottom: 10px; }
    .sv-search:focus { border-color: #2563eb; outline: none; box-shadow: 0 0 0 3px rgba(37,99,235,.1); }
    .sv-list  { max-height: 260px; overflow-y: auto; border: 1px solid #e5e7eb; border-radius: 8px; }
    .sv-item  { display: flex; align-items: center; gap: 10px; padding: 8px 12px; border-bottom: 1px solid #f3f4f6; font-size: 13px; cursor: pointer; transition: background .12s; }
    .sv-item:last-child { border-bottom: none; }
    .sv-item:hover { background: #f0f9ff; }
    .sv-item input[type=checkbox] { width: 16px; height: 16px; cursor: pointer; }
    .sv-item .sv-code { font-weight: 700; color: #2563eb; min-width: 90px; }
    .sv-item .sv-name { color: #374151; }
    .sv-count { font-size: 12px; color: #6b7280; margin-top: 6px; }

    /* File upload */
    .file-hint { font-size: 12.5px; color: #6b7280; margin-top: 6px; }
    .file-hint code { background: #f3f4f6; padding: 1px 5px; border-radius: 4px; font-size: 11px; }

    @@media (max-width: 576px) {
        .sv-tab { padding: 7px 12px; font-size: 12px; }
        .sv-item .sv-code { min-width: 70px; font-size: 12px; }
        .sv-item .sv-name { font-size: 12px; }
    }
</style>

<div style="max-width:640px;">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Periods">Đợt đăng ký</a></li>
            <li class="breadcrumb-item active">@ViewData["Title"]</li>
        </ol>
    </nav>

    <div class="rg-page-title">
        <h2>@ViewData["Title"]</h2>
        <p>@(isEdit ? "Cập nhật thông tin đợt đăng ký" : "Tạo đợt đăng ký đề tài học phần mới")</p>
    </div>

    <form asp-action="@(isEdit ? "EditPeriod" : "CreatePeriod")"
          method="post" enctype="multipart/form-data" hx-boost="false">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" asp-for="Id" /> }

        <!-- ── Thông tin cơ bản ── -->
        <div class="rg-form-card">
            <div class="rg-form-head">Thông tin đợt đăng ký</div>
            <div class="rg-form-body">

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control"
                           placeholder="Ví dụ: Đồ án tốt nghiệp – HK1 2025-2026" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CourseName" class="form-label fw-semibold"></label>
                    <input asp-for="CourseName" class="form-control"
                           placeholder="Ví dụ: Đồ án tốt nghiệp" />
                    <span asp-validation-for="CourseName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="GoogleSheetLink" class="form-label fw-semibold">Link Google Sheet</label>
                    <input asp-for="GoogleSheetLink" class="form-control"
                           placeholder="https://docs.google.com/spreadsheets/..." />
                    <span asp-validation-for="GoogleSheetLink" class="text-danger small"></span>
                    <div class="form-text">Dùng để lưu bảng đăng ký hoặc theo dõi sinh viên.</div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <label asp-for="StartDate" class="form-label fw-semibold"></label>
                        <input asp-for="StartDate" type="date" class="form-control" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>
                    <div class="col-sm-6">
                        <label asp-for="EndDate" class="form-label fw-semibold"></label>
                        <input asp-for="EndDate" type="date" class="form-control" />
                        <span asp-validation-for="EndDate" class="text-danger small"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="ReportDeadline" class="form-label fw-semibold">Hạn nộp báo cáo</label>
                    <input asp-for="ReportDeadline" type="datetime-local" class="form-control" />
                    <div class="form-text" style="font-size:12px;">
                        Đặt/đổi hạn nộp sẽ tự động gửi email thông báo cho SV đã được duyệt đề tài. Để trống nếu chưa áp dụng.
                    </div>
                    <span asp-validation-for="ReportDeadline" class="text-danger small"></span>
                </div>

                <div style="background:#f8fafc; border:1px solid #e5e7eb; border-radius:8px; padding:14px 16px;">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold">
                            Kích hoạt đợt đăng ký ngay
                        </label>
                    </div>
                    <div class="form-text mt-1">Chỉ một đợt được kích hoạt tại một thời điểm.</div>
                </div>

            </div>
        </div>

        <!-- ── Giới hạn sinh viên ── -->
        <div class="restrict-section">
            <div class="restrict-head">
                <label class="restrict-head-toggle">
                    <input type="checkbox" asp-for="RestrictToAllowedStudents"
                           id="chkRestrict" class="form-check-input" />
                    <span class="lbl">Giới hạn sinh viên đăng ký</span>
                    <span class="sub">(chỉ sinh viên trong danh sách mới được đăng ký)</span>
                </label>
            </div>
            <div class="restrict-body @(Model.RestrictToAllowedStudents ? "show" : "")" id="restrictBody">

                <!-- Tabs -->
                <div class="sv-tabs">
                    <div class="sv-tab active" data-tab="tab-select">Chọn từ danh sách</div>
                    <div class="sv-tab" data-tab="tab-file">Tải lên file</div>
                </div>

                <!-- Tab 1: Checkbox list -->
                <div class="sv-tab-pane active" id="tab-select">
                    <input type="text" id="svSearch" class="sv-search" placeholder="Tìm MSSV hoặc tên sinh viên..." />
                    <div class="sv-list" id="svList">
                        @if (!Model.AvailableStudents.Any())
                        {
                            <div class="sv-item" style="color:#9ca3af;justify-content:center;">
                                Chưa có sinh viên nào trong hệ thống.
                            </div>
                        }
                        else
                        {
                            @foreach (var s in Model.AvailableStudents)
                            {
                                <label class="sv-item" data-code="@s.StudentCode.ToLower()" data-name="@s.FullName.ToLower()">
                                    <input type="checkbox" name="SelectedStudentIds" value="@s.StudentProfileId"
                                           @(s.IsSelected || (Model.SelectedStudentIds.Contains(s.StudentProfileId)) ? "checked" : "") />
                                    <span class="sv-code">@s.StudentCode</span>
                                    <span class="sv-name">@s.FullName</span>
                                </label>
                            }
                        }
                    </div>
                    <div class="sv-count" id="svCount">
                        @Model.AvailableStudents.Count(s => s.IsSelected) / @Model.AvailableStudents.Count đã chọn
                    </div>
                </div>

                <!-- Tab 2: File upload -->
                <div class="sv-tab-pane" id="tab-file">
                    <label class="form-label fw-semibold" style="font-size:13px;">Chọn file danh sách</label>
                    <input type="file" asp-for="StudentListFile" class="form-control"
                           accept=".xlsx,.txt,.csv" style="font-size:13px;" />
                    <span asp-validation-for="StudentListFile" class="text-danger small"></span>
                    <div class="file-hint">
                        Hỗ trợ: <code>.xlsx</code> (cột đầu là MSSV), <code>.txt</code> / <code>.csv</code> (mỗi dòng một MSSV).<br />
                        MSSV phải khớp với mã sinh viên đã tồn tại trong hệ thống.
                    </div>
                </div>

            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4">
                @(isEdit ? "Lưu thay đổi" : "Tạo đợt")
            </button>
            <a asp-action="Periods" class="btn btn-outline-secondary">Hủy</a>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        // Toggle restrict panel
        var chk = document.getElementById('chkRestrict');
        var body = document.getElementById('restrictBody');
        if (chk && body) {
            chk.addEventListener('change', function () {
                body.classList.toggle('show', chk.checked);
            });
        }

        // Tabs
        document.querySelectorAll('.sv-tab').forEach(function (tab) {
            tab.addEventListener('click', function () {
                document.querySelectorAll('.sv-tab').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.sv-tab-pane').forEach(p => p.classList.remove('active'));
                tab.classList.add('active');
                var pane = document.getElementById(tab.dataset.tab);
                if (pane) pane.classList.add('active');
            });
        });

        // Search inside list
        var searchInput = document.getElementById('svSearch');
        var svList = document.getElementById('svList');
        var svCount = document.getElementById('svCount');
        if (searchInput && svList) {
            searchInput.addEventListener('input', function () {
                var kw = searchInput.value.toLowerCase().trim();
                var items = svList.querySelectorAll('.sv-item[data-code]');
                items.forEach(function (item) {
                    var match = !kw || item.dataset.code.includes(kw) || item.dataset.name.includes(kw);
                    item.style.display = match ? '' : 'none';
                });
            });
        }

        // Live count
        if (svList && svCount) {
            svList.addEventListener('change', function () {
                var total = svList.querySelectorAll('input[type=checkbox]').length;
                var checked = svList.querySelectorAll('input[type=checkbox]:checked').length;
                svCount.textContent = checked + ' / ' + total + ' đã chọn';
            });
        }
    })();
    </script>
}
