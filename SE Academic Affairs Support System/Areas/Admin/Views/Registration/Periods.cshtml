@model List<SE_Academic_Affairs_Support_System.Models.RegistrationPeriod>
@{
    ViewData["Title"] = "Quản lý đợt đăng ký";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .rg-page-title { border-left:4px solid #2563eb; padding-left:14px; margin-bottom:24px; }
    .rg-page-title h2 { font-size:22px; font-weight:700; color:#1e3a8a; margin-bottom:3px; }
    .rg-page-title p  { font-size:13px; color:#6b7280; margin:0; }

    .sb { display:inline-block; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:600; white-space:nowrap; }
    .sb-green { background:#dcfce7; color:#166534; border:1px solid #bbf7d0; }
    .sb-amber { background:#fef3c7; color:#92400e; border:1px solid #fde68a; }
    .sb-gray  { background:#f1f5f9; color:#475569; border:1px solid #e2e8f0; }

    .dt-wrap { border:1px solid #e5e7eb; border-radius:10px; overflow:hidden; }
    .dt { border-collapse:collapse; width:100%; }
    .dt thead th { background:#f8fafc; padding:12px 16px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:#64748b; border-bottom:1px solid #e5e7eb; white-space:nowrap; }
    .dt tbody td { padding:13px 16px; border-bottom:1px solid #f1f5f9; vertical-align:middle; font-size:14px; color:#374151; }
    .dt tbody tr:last-child td { border-bottom:none; }
    .dt tbody tr:hover td { background:#f8fafc; }

    .btn-act { display:inline-flex; align-items:center; padding:5px 12px; border-radius:6px; font-size:12px; font-weight:600; cursor:pointer; border:1px solid; transition:all .15s; text-decoration:none; white-space:nowrap; }
    .btn-act-outline  { background:#fff; color:#374151; border-color:#d1d5db; }
    .btn-act-outline:hover { background:#f8fafc; color:#1e3a8a; border-color:#93c5fd; }
    .btn-act-success  { background:#16a34a; color:#fff; border-color:#16a34a; }
    .btn-act-success:hover { background:#15803d; color:#fff; border-color:#15803d; }
    .btn-act-danger   { background:#fff; color:#dc2626; border-color:#fecaca; }
    .btn-act-danger:hover  { background:#fee2e2; border-color:#fca5a5; }
    .btn-act-pdf   { background:#fff; color:#dc2626; border-color:#fecaca; }
    .btn-act-pdf:hover { background:#fee2e2; }
    .btn-act-excel { background:#fff; color:#16a34a; border-color:#bbf7d0; }
    .btn-act-excel:hover { background:#dcfce7; }

    @@media (max-width:767px) {
        .dt-wrap { border-radius:0; border-left:none; border-right:none; overflow:visible; }
        .dt thead { display:none; }
        .dt, .dt tbody { display:block; }
        .dt tr { display:block; border:1px solid #e5e7eb; border-radius:10px; margin-bottom:10px; background:#fff; box-shadow:0 1px 3px rgba(0,0,0,.06); }
        .dt td { display:flex; flex-direction:column; padding:10px 14px; border-bottom:1px solid #f3f4f6; font-size:14px; }
        .dt td:last-child { border-bottom:none; }
        .dt td::before { content:attr(data-label); font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#9ca3af; margin-bottom:5px; }
        .dt tbody tr:hover td { background:transparent; }
    }
</style>

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div class="rg-page-title mb-0">
        <h2>Quản lý Đợt Đăng Ký</h2>
        <p>Tạo và quản lý các đợt đăng ký đề tài học phần</p>
    </div>
    <a asp-area="Admin" asp-controller="Registration" asp-action="CreatePeriod" class="btn btn-primary px-4">
        Tạo đợt mới
    </a>
</div>

<partial name="_Alerts" />

@if (!Model.Any())
{
    <div class="text-center py-5" style="color:#9ca3af;">
        <p style="font-size:16px; font-weight:600; margin-bottom:8px; color:#374151;">Chưa có đợt đăng ký nào.</p>
        <p style="font-size:14px;">Nhấn "Tạo đợt mới" để bắt đầu.</p>
    </div>
}
else
{
    <div class="dt-wrap">
        <table class="dt">
            <thead>
                <tr>
                    <th>Tên đợt</th>
                    <th>Học phần</th>
                    <th>Thời gian</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td data-label="Tên đợt">
                            <span class="fw-semibold" style="color:#1e3a8a;">@p.Name</span>
                        </td>
                        <td data-label="Học phần">@p.CourseName</td>
                        <td data-label="Thời gian">
                            <span style="font-size:13px; color:#6b7280;">
                                @p.StartDate.ToString("dd/MM/yyyy") — @p.EndDate.ToString("dd/MM/yyyy")
                            </span>
                        </td>
                        <td data-label="Trạng thái">
                            @if (p.IsActive)
                            {
                                <span class="sb sb-green">Đang mở</span>
                            }
                            else if (p.EndDate < DateTime.Now)
                            {
                                <span class="sb sb-gray">Đã kết thúc</span>
                            }
                            else
                            {
                                <span class="sb sb-amber">Chưa mở</span>
                            }
                        </td>
                        <td data-label="Thao tác">
                            <div class="d-flex flex-wrap gap-2">
                                <a asp-action="EditPeriod" asp-route-id="@p.Id" class="btn-act btn-act-outline">Sửa</a>

                                @if (!p.IsActive)
                                {
                                    <form asp-action="ActivatePeriod" method="post" style="margin:0"
                                          onsubmit="return confirm('Mở đợt đăng ký này?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="periodId" value="@p.Id" />
                                        <button type="submit" class="btn-act btn-act-success">Mở</button>
                                    </form>
                                }

                                @if (p.IsActive)
                                {
                                    <form asp-action="ClosePeriod" method="post" style="margin:0"
                                          onsubmit="return confirm('Chốt danh sách? Các đề xuất chưa duyệt sẽ bị hủy tự động.')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="periodId" value="@p.Id" />
                                        <button type="submit" class="btn-act btn-act-danger">Chốt</button>
                                    </form>
                                }

                                @if (!string.IsNullOrEmpty(p.GoogleSheetLink))
                                {
                                    <a href="@p.GetDownloadLink("pdf")" target="_blank" class="btn-act btn-act-pdf">PDF</a>
                                    <a href="@p.GetDownloadLink("xlsx")" target="_blank" class="btn-act btn-act-excel">Excel</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
