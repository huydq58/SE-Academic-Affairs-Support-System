@model List<SE_Academic_Affairs_Support_System.Models.RegistrationPeriod>
@{
    ViewData["Title"] = "Quản lý đợt đăng ký";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="bi bi-calendar-event-fill text-primary me-2"></i>Quản lý đợt đăng ký
        </h2>
        <a asp-area="Admin" asp-controller="Registration" asp-action="CreatePeriod" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Tạo đợt mới
        </a>

    </div>

    <partial name="_Alerts" />

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-calendar-x display-4"></i>
            <p class="mt-3">Chưa có đợt đăng ký nào.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Tên đợt</th>
                        <th>Môn học</th>
                        <th>Thời gian</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@p.Name</td>
                            <td>@p.CourseName</td>
                            <td class="small text-muted">
                                @p.StartDate.ToString("dd/MM/yyyy") → @p.EndDate.ToString("dd/MM/yyyy")
                            </td>
                            <td class="text-center">
                                @if (p.IsActive)
                                {
                                    <span class="badge bg-success">Đang mở</span>
                                }
                                else if (p.EndDate < DateTime.Now)
                                {
                                    <span class="badge bg-secondary">Đã kết thúc</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark border">Chưa mở</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="EditPeriod" asp-route-id="@p.Id"
                                       class="btn btn-outline-secondary">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    @if (!p.IsActive)
                                    {
                                        <form asp-action="ActivatePeriod" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="periodId" value="@p.Id" />
                                            <button type="submit" class="btn btn-outline-success"
                                                    onclick="return confirm('Mở đợt đăng ký này?')">
                                                <i class="bi bi-play-fill"></i> Mở
                                            </button>
                                        </form>
                                    }

                                    @if (p.IsActive)
                                    {
                                        <form asp-action="ClosePeriod" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="periodId" value="@p.Id" />
                                            <button type="submit" class="btn btn-outline-danger"
                                                    onclick="return confirm('Chốt danh sách? Các đề xuất chưa duyệt sẽ bị hủy tự động.')">
                                                <i class="bi bi-lock-fill"></i> Chốt
                                            </button>
                                        </form>
                                    }

                                    <a asp-action="Export" asp-route-periodId="@p.Id"
                                       class="btn btn-outline-primary" title="Xuất CSV">
                                        <i class="bi bi-download"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
