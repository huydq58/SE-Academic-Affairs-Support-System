@model List<SE_Academic_Affairs_Support_System.Models.RoomModel>
@using SE_Academic_Affairs_Support_System.Models
@{
    ViewData["Title"] = "Quản lý phòng họp";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Badge style theo condition
    static (string bg, string color, string border, string icon) ConditionStyle(string? c) => c switch
    {
        "Good"        => ("#dcfce7", "#166534", "#bbf7d0", "bi-check-circle-fill"),
        "Maintenance" => ("#fef3c7", "#92400e", "#fde68a", "bi-tools"),
        "Inactive"    => ("#f1f5f9", "#64748b", "#e2e8f0", "bi-slash-circle"),
        _             => ("#dcfce7", "#166534", "#bbf7d0", "bi-check-circle-fill")
    };
}

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div style="border-left:4px solid #2563eb; padding-left:14px;">
        <h2 style="font-size:22px; font-weight:700; color:#1e3a8a; margin-bottom:4px;">Quản lý phòng họp</h2>
        <p style="font-size:13px; color:#6b7280; margin:0;">Danh sách phòng có thể đặt trong hệ thống</p>
    </div>
    <a asp-area="Admin" asp-controller="System" asp-action="Index"
       class="btn btn-outline-secondary" style="font-size:13px;">
        <i class="bi bi-arrow-left me-1"></i>Quay lại
    </a>
</div>

<partial name="_Alerts" />

<div class="row g-4">
    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
            <div class="card-body p-4">
                <h6 style="font-size:15px; font-weight:700; color:#1e3a8a; margin-bottom:16px;">
                    <i class="bi bi-plus-circle me-2 text-primary"></i>Thêm phòng mới
                </h6>
                <form asp-area="Admin" asp-controller="RoomManage" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label" style="font-size:13px; font-weight:600;">
                            Tên phòng <span class="text-danger">*</span>
                        </label>
                        <input type="text" name="roomName" class="form-control" style="font-size:13px;"
                               placeholder="VD: E7.3" maxlength="100" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label" style="font-size:13px; font-weight:600;">Tình trạng</label>
                        <select name="condition" class="form-select" style="font-size:13px;">
                            @foreach (var c in RoomModel.Conditions)
                            {
                                <option value="@c">@c</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100" style="font-size:13px; font-weight:600;">
                        <i class="bi bi-plus me-1"></i>Thêm phòng
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
            <div class="card-body p-4">
                <h6 style="font-size:15px; font-weight:700; color:#1e3a8a; margin-bottom:16px;">
                    <i class="bi bi-list-ul me-2 text-primary"></i>Danh sách phòng
                    <span class="badge bg-primary ms-2" style="font-size:12px;">@Model.Count</span>
                </h6>

                @if (!Model.Any())
                {
                    <div style="text-align:center; padding:40px 20px; color:#9ca3af;">
                        <i class="bi bi-door-closed" style="font-size:40px; display:block; margin-bottom:12px;"></i>
                        <strong style="font-size:14px; color:#374151; display:block; margin-bottom:4px;">Chưa có phòng nào.</strong>
                        <span style="font-size:13px;">Sử dụng form bên trái để thêm phòng mới.</span>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" style="font-size:13px;">
                            <thead style="background:#f8fafc;">
                                <tr>
                                    <th style="font-weight:600; color:#374151; padding:10px 14px;">#</th>
                                    <th style="font-weight:600; color:#374151; padding:10px 14px;">Tên phòng</th>
                                    <th style="font-weight:600; color:#374151; padding:10px 14px;">Tình trạng</th>
                                    <th style="font-weight:600; color:#374151; padding:10px 14px; text-align:right;">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var room in Model)
                                {
                                    var style = ConditionStyle(room.Condition);
                                    <tr>
                                        <td style="color:#9ca3af; padding:10px 14px;">@room.RoomID</td>
                                        <td style="font-weight:600; color:#1e3a8a; padding:10px 14px;">
                                            <i class="bi bi-door-closed me-2 text-primary"></i>@room.RoomName
                                        </td>
                                        <td style="padding:10px 14px;">
                                            <span style="font-size:11px; font-weight:600;
                                                         background:@style.bg; color:@style.color;
                                                         border:1px solid @style.border;
                                                         border-radius:20px; padding:2px 10px;
                                                         white-space:nowrap;">
                                                <i class="bi @style.icon me-1"></i>@room.Condition
                                            </span>
                                        </td>
                                        <td style="padding:10px 14px; text-align:right;">
                                            <div class="d-flex gap-2 justify-content-end align-items-center flex-wrap">
                                                <form asp-area="Admin" asp-controller="RoomManage"
                                                      asp-action="UpdateCondition" asp-route-id="@room.RoomID"
                                                      method="post" class="d-flex gap-1 align-items-center">
                                                    @Html.AntiForgeryToken()
                                                    <select name="condition" class="form-select form-select-sm"
                                                            style="font-size:12px; width:130px;">
                                                        @foreach (var c in RoomModel.Conditions)
                                                        {
                                                            if (c == room.Condition)
                                                            {
                                                                <option value="@c" selected>@c</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@c">@c</option>
                                                            }
                                                        }
                                                    </select>
                                                    <button type="submit" class="btn btn-sm btn-outline-primary"
                                                            style="font-size:12px; white-space:nowrap;">
                                                        <i class="bi bi-check2"></i>
                                                    </button>
                                                </form>

                                                <form asp-area="Admin" asp-controller="RoomManage"
                                                      asp-action="Delete" asp-route-id="@room.RoomID"
                                                      method="post">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                                            style="font-size:12px;"
                                                            onclick="return confirm('Xóa phòng &quot;@room.RoomName&quot;?')">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
