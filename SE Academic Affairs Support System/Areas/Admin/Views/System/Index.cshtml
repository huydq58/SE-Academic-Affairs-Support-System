@{
    ViewData["Title"] = "Cài đặt hệ thống";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-4">
    <div style="border-left: 4px solid #2563eb; padding-left: 14px;">
        <h2 style="font-size:22px; font-weight:700; color:#1e3a8a; margin-bottom:4px;">Cài đặt hệ thống</h2>
        <p style="font-size:13px; color:#6b7280; margin:0;">Quản lý cấu hình email, phòng họp và tài khoản người dùng</p>
    </div>
</div>

<partial name="_Alerts" />

<div class="row g-4 mt-1">
    <div class="col-12 col-md-6">
        <a asp-area="Admin" asp-controller="EmailConfig" asp-action="Index"
           class="text-decoration-none d-block h-100">
            <div class="card h-100 border-0 shadow-sm"
                 style="border-radius:12px; transition: box-shadow .15s, transform .15s;"
                 onmouseover="this.style.boxShadow='0 6px 24px rgba(37,99,235,.15)';this.style.transform='translateY(-3px)'"
                 onmouseout="this.style.boxShadow='';this.style.transform=''">
                <div class="card-body d-flex align-items-start gap-4 p-4">
                    <div style="width:52px; height:52px; background:linear-gradient(135deg,#2563eb,#1e3a8a);
                                border-radius:12px; display:flex; align-items:center; justify-content:center;
                                flex-shrink:0;">
                        <i class="bi bi-envelope-gear-fill" style="font-size:24px; color:#fff;"></i>
                    </div>
                    <div>
                        <h5 style="font-size:16px; font-weight:700; color:#1e3a8a; margin-bottom:6px;">
                            Cấu hình Email
                        </h5>
                        <p style="font-size:13px; color:#6b7280; margin:0; line-height:1.6;">
                            Thiết lập tài khoản SMTP dùng để gửi thông báo hệ thống cho sinh viên và giảng viên.
                        </p>
                        <span class="mt-3 d-inline-flex align-items-center gap-1"
                              style="font-size:13px; font-weight:600; color:#2563eb;">
                            Quản lý <i class="bi bi-arrow-right"></i>
                        </span>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-12 col-md-6">
        <a asp-area="Admin" asp-controller="RoomManage" asp-action="Index"
           class="text-decoration-none d-block h-100">
            <div class="card h-100 border-0 shadow-sm"
                 style="border-radius:12px; transition: box-shadow .15s, transform .15s;"
                 onmouseover="this.style.boxShadow='0 6px 24px rgba(37,99,235,.15)';this.style.transform='translateY(-3px)'"
                 onmouseout="this.style.boxShadow='';this.style.transform=''">
                <div class="card-body d-flex align-items-start gap-4 p-4">
                    <div style="width:52px; height:52px; background:linear-gradient(135deg,#0891b2,#0e7490);
                                border-radius:12px; display:flex; align-items:center; justify-content:center;
                                flex-shrink:0;">
                        <i class="bi bi-door-open-fill" style="font-size:24px; color:#fff;"></i>
                    </div>
                    <div>
                        <h5 style="font-size:16px; font-weight:700; color:#1e3a8a; margin-bottom:6px;">
                            Quản lý phòng họp
                        </h5>
                        <p style="font-size:13px; color:#6b7280; margin:0; line-height:1.6;">
                            Thêm, xem và xóa danh sách phòng họp. Các phòng được thêm vào đây sẽ hiển thị trong tính năng đặt phòng.
                        </p>
                        <span class="mt-3 d-inline-flex align-items-center gap-1"
                              style="font-size:13px; font-weight:600; color:#2563eb;">
                            Quản lý <i class="bi bi-arrow-right"></i>
                        </span>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-12 col-md-6">
        <a asp-area="Admin" asp-controller="Account" asp-action="Index"
           class="text-decoration-none d-block h-100">
            <div class="card h-100 border-0 shadow-sm"
                 style="border-radius:12px; transition: box-shadow .15s, transform .15s;"
                 onmouseover="this.style.boxShadow='0 6px 24px rgba(37,99,235,.15)';this.style.transform='translateY(-3px)'"
                 onmouseout="this.style.boxShadow='';this.style.transform=''">
                <div class="card-body d-flex align-items-start gap-4 p-4">
                    <div style="width:52px; height:52px; background:linear-gradient(135deg,#7c3aed,#5b21b6);
                                border-radius:12px; display:flex; align-items:center; justify-content:center;
                                flex-shrink:0;">
                        <i class="bi bi-people-fill" style="font-size:24px; color:#fff;"></i>
                    </div>
                    <div>
                        <h5 style="font-size:16px; font-weight:700; color:#1e3a8a; margin-bottom:6px;">
                            Quản lý tài khoản
                        </h5>
                        <p style="font-size:13px; color:#6b7280; margin:0; line-height:1.6;">
                            Tạo, chỉnh sửa và phân quyền tài khoản cho Admin, Giảng viên và Sinh viên trong hệ thống.
                        </p>
                        <span class="mt-3 d-inline-flex align-items-center gap-1"
                              style="font-size:13px; font-weight:600; color:#2563eb;">
                            Quản lý <i class="bi bi-arrow-right"></i>
                        </span>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>
