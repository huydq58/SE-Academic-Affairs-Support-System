@* ===== Create.cshtml ===== *@
@* Đặt tại Views/Device/Create.cshtml *@

@model SE_Academic_Affairs_Support_System.Models.Device
@{
    ViewData["Title"] = "Thêm thiết bị mới";
}


<div class="dv-wrap">

    <div class="dv-page-title">
        <h2>Thêm thiết bị mới</h2>
        <p>Nhập thông tin thiết bị để đưa vào kho quản lý</p>
    </div>

    @await Html.PartialAsync("_Alerts")

    <form asp-action="Create" asp-controller="Device" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div class="dv-section">
            <div class="dv-section-head">Thông tin thiết bị</div>
            <div class="dv-section-body">

                <div class="mb-3">
                    <label class="form-label">Tên thiết bị <span class="text-danger">*</span></label>
                    <input asp-for="DeviceName"
                           class="form-control @(ViewData.ModelState["DeviceName"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           placeholder="Ví dụ: Laptop Dell Inspiron 15..." />
                    <span asp-validation-for="DeviceName" class="invalid-feedback d-block small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Phân loại</label>
                    <input asp-for="Category" class="form-control"
                           placeholder="Ví dụ: Laptop, Camera, Máy chiếu..." />
                </div>

                <div class="mb-0">
                    <label class="form-label">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="3"
                              placeholder="Mô tả chi tiết về thiết bị, cấu hình, tính năng..."></textarea>
                </div>

            </div>
        </div>

        <div class="dv-section">
            <div class="dv-section-head">Trạng thái ban đầu</div>
            <div class="dv-section-body">

                <div class="row g-3">
                    <div class="col-12 col-sm-6">
                        <label class="form-label">Trạng thái <span class="text-danger">*</span></label>
                        <select asp-for="Status" class="form-select">
                            <option value="Available">Sẵn sàng</option>
                            <option value="Borrowing">Đang mượn</option>
                            <option value="Returned">Đã trả</option>
                        </select>
                    </div>
                    <div class="col-12 col-sm-6">
                        <label class="form-label">Tình trạng <span class="text-danger">*</span></label>
                        <select asp-for="Condition" class="form-select">
                            <option value="Good">Tốt</option>
                            <option value="Broken">Hỏng</option>
                        </select>
                    </div>
                </div>

                <div class="dv-footer">
                    <a href="/Device/Index" class="btn btn-outline-secondary px-4">Hủy</a>
                    <button type="submit" class="btn btn-primary px-5">Thêm thiết bị</button>
                </div>

            </div>
        </div>

    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
