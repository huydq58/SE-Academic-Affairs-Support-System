@model SE_Academic_Affairs_Support_System.Models.DeviceRequest
@{
    ViewData["Title"] = "Đăng ký thành công";
}

<style>
    .success-wrap { max-width:560px; margin:0 auto; text-align:center; padding:48px 0 32px; }

    .success-circle {
        width:72px; height:72px; border-radius:50%;
        background:#dcfce7; border:2px solid #bbf7d0;
        display:inline-flex; align-items:center; justify-content:center;
        margin-bottom:20px;
    }
    .success-circle svg { width:36px; height:36px; }

    .success-wrap h2 { font-size:22px; font-weight:700; color:#1e3a8a; margin-bottom:8px; }
    .success-wrap .sub { font-size:14px; color:#6b7280; margin-bottom:28px; }

    .info-card { background:#f8fafc; border:1px solid #dbeafe; border-radius:10px; padding:20px 24px; text-align:left; margin-bottom:24px; }
    .info-card .section-head { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#1d4ed8; margin-bottom:14px; border-bottom:1px solid #bfdbfe; padding-bottom:8px; }
    .info-row { display:flex; gap:12px; margin-bottom:10px; }
    .info-row:last-child { margin-bottom:0; }
    .info-lbl { font-size:12px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:.04em; min-width:120px; flex-shrink:0; padding-top:2px; }
    .info-val { font-size:14px; color:#374151; }

    .notice-box { background:#fefce8; border:1px solid #fde68a; border-radius:8px; padding:12px 16px; font-size:13px; color:#78350f; text-align:left; margin-bottom:24px; line-height:1.6; }

    .action-row { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; }
    .btn-home { display:inline-block; padding:9px 24px; background:#2563eb; color:#fff; border-radius:8px; font-size:14px; font-weight:600; text-decoration:none; transition:all .15s; }
    .btn-home:hover { background:#1d4ed8; color:#fff; }
    .btn-catalog { display:inline-block; padding:9px 24px; background:#fff; color:#374151; border:1px solid #d1d5db; border-radius:8px; font-size:14px; font-weight:600; text-decoration:none; transition:all .15s; }
    .btn-catalog:hover { background:#f1f5f9; border-color:#9ca3af; }
</style>

<div class="success-wrap">

    <div class="success-circle">
        <svg viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
    </div>

    <h2>Yêu cầu đã được gửi!</h2>
    <p class="sub">Yêu cầu mượn thiết bị của bạn đang chờ phê duyệt từ quản lý.<br>Bạn sẽ nhận được thông báo khi có kết quả.</p>

    <div class="info-card">
        <div class="section-head">Thông tin yêu cầu</div>

        <div class="info-row">
            <div class="info-lbl">Thiết bị</div>
            <div class="info-val fw-semibold">@(Model.Device?.DeviceName ?? "—")</div>
        </div>
        <div class="info-row">
            <div class="info-lbl">Người mượn</div>
            <div class="info-val">@Model.BorrowerName</div>
        </div>
        <div class="info-row">
            <div class="info-lbl">Email</div>
            <div class="info-val">@Model.BorrowerEmail</div>
        </div>
        <div class="info-row">
            <div class="info-lbl">Ngày yêu cầu</div>
            <div class="info-val">@Model.RequestDate.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        @if (!string.IsNullOrEmpty(Model.Purpose))
        {
            <div class="info-row">
                <div class="info-lbl">Mục đích</div>
                <div class="info-val">@Model.Purpose</div>
            </div>
        }
    </div>

    <div class="notice-box">
        Vui lòng chú ý theo dõi email <strong>@Model.BorrowerEmail</strong> để nhận thông báo kết quả phê duyệt từ quản lý.
    </div>

    <div class="action-row">
        <a href="/Device/Catalog" class="btn-catalog">Xem thêm thiết bị</a>
        <a href="/" class="btn-home">Về trang chủ</a>
    </div>

</div>
