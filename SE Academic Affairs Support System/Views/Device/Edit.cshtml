@model SE_Academic_Affairs_Support_System.Models.Device
@{
    ViewData["Title"] = "Chỉnh sửa thiết bị";
}

<style>
    .status-strip { display:flex; flex-wrap:wrap; gap:16px; background:#f8fafc; border:1px solid #e5e7eb; border-radius:10px; padding:14px 18px; margin-bottom:20px; }
    .strip-item .strip-lbl { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:#9ca3af; margin-bottom:5px; }
</style>

<div class="dv-wrap">

    <div class="dv-page-title">
        <h2>Chỉnh sửa thiết bị</h2>
        <p>Cập nhật thông tin và trạng thái của thiết bị</p>
    </div>

    @await Html.PartialAsync("_Alerts")

    @{ var borrowedNow = (int)(ViewBag.Borrowed ?? 0); var availableNow = Model.TotalQuantity - Model.BrokenQuantity - borrowedNow; }
    <!-- Inventory strip (read-only info) -->
    <div class="status-strip">
        <div class="strip-item">
            <div class="strip-lbl">Mã TB</div>
            <span style="font-family:monospace; font-size:14px; color:#6b7280;">@(string.IsNullOrEmpty(Model.DeviceCode) ? $"#{Model.DeviceId}" : Model.DeviceCode)</span>
        </div>
        <div class="strip-item">
            <div class="strip-lbl">Tổng</div>
            <span class="sb sb-gray">@Model.TotalQuantity</span>
        </div>
        <div class="strip-item">
            <div class="strip-lbl">Đang mượn</div>
            <span class="sb sb-blue">@borrowedNow</span>
        </div>
        <div class="strip-item">
            <div class="strip-lbl">Còn lại</div>
            <span class="sb @(availableNow > 0 ? "sb-green" : "sb-red")">@availableNow</span>
        </div>
    </div>

    <form asp-action="Edit" asp-controller="Device" asp-route-id="@Model.DeviceId" method="post" novalidate hx-boost="false">
        @Html.AntiForgeryToken()

        <div class="dv-section">
            <div class="dv-section-head">Thông tin thiết bị</div>
            <div class="dv-section-body">

                <div class="mb-3">
                    <label class="form-label">Mã thiết bị</label>
                    <input asp-for="DeviceCode"
                           class="form-control @(ViewData.ModelState["DeviceCode"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           placeholder="Ví dụ: MC01 (để trống nếu không có)" />
                    <span asp-validation-for="DeviceCode" class="invalid-feedback d-block small"></span>
                    <div class="form-text" style="font-size:12px;">Mã định danh duy nhất, có thể để trống.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Tên thiết bị <span class="text-danger">*</span></label>
                    <input asp-for="DeviceName"
                           class="form-control @(ViewData.ModelState["DeviceName"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           placeholder="Tên thiết bị" />
                    <span asp-validation-for="DeviceName" class="invalid-feedback d-block small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Phân loại</label>
                    <input asp-for="Category" class="form-control"
                           placeholder="Ví dụ: Laptop, Camera, Máy chiếu..." />
                </div>

                <div class="mb-0">
                    <label class="form-label">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="3"
                              placeholder="Mô tả chi tiết về thiết bị..."></textarea>
                </div>

            </div>
        </div>

        <div class="dv-section">
            <div class="dv-section-head">Tồn kho</div>
            <div class="dv-section-body">

                <div class="row g-3">
                    <div class="col-12 col-sm-6">
                        <label class="form-label">Tổng số lượng <span class="text-danger">*</span></label>
                        <input asp-for="TotalQuantity" type="number" min="1" class="form-control" />
                        <span asp-validation-for="TotalQuantity" class="invalid-feedback d-block small"></span>
                        <div class="form-text" style="font-size:12px;">Không được nhỏ hơn số đang mượn (@borrowedNow).</div>
                    </div>
                    <div class="col-12 col-sm-6">
                        <label class="form-label">Số lượng hỏng</label>
                        <input asp-for="BrokenQuantity" type="number" min="0" class="form-control" />
                        <span asp-validation-for="BrokenQuantity" class="invalid-feedback d-block small"></span>
                    </div>
                </div>

                <div class="dv-footer">
                    <a href="/Device/Index" class="btn btn-outline-secondary px-4">Hủy</a>
                    <button type="submit" class="btn btn-primary px-5">Lưu thay đổi</button>
                </div>

            </div>
        </div>

    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
