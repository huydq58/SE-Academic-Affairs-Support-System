@model SE_Academic_Affairs_Support_System.Models.Device
@{
    ViewData["Title"] = "Chỉnh sửa thiết bị";
}

<style>
    .dv-wrap { max-width:620px; margin:0 auto; }
    .dv-page-title { border-left:4px solid #2563eb; padding-left:14px; margin-bottom:28px; }
    .dv-page-title h2 { font-size:22px; font-weight:700; color:#1e3a8a; margin-bottom:3px; }
    .dv-page-title p  { font-size:13px; color:#6b7280; margin:0; }

    /* Status strip */
    .status-strip { display:flex; flex-wrap:wrap; gap:16px; background:#f8fafc; border:1px solid #e5e7eb; border-radius:10px; padding:14px 18px; margin-bottom:20px; }
    .strip-item .strip-lbl { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:#9ca3af; margin-bottom:5px; }
    .sb { display:inline-block; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:600; white-space:nowrap; }
    .sb-green { background:#dcfce7; color:#166534; border:1px solid #bbf7d0; }
    .sb-blue  { background:#dbeafe; color:#1d4ed8; border:1px solid #bfdbfe; }
    .sb-amber { background:#fef3c7; color:#92400e; border:1px solid #fde68a; }
    .sb-red   { background:#fee2e2; color:#991b1b; border:1px solid #fecaca; }

    .dv-section { border:1px solid #dbeafe; border-radius:10px; overflow:hidden; margin-bottom:18px; }
    .dv-section-head { background:#eff6ff; border-bottom:1px solid #bfdbfe; padding:10px 18px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:#1d4ed8; }
    .dv-section-body { padding:20px 18px; }

    .dv-wrap .form-label { font-size:13px; font-weight:600; color:#374151; }
    .dv-wrap .form-control,
    .dv-wrap .form-select { font-size:14px; border-color:#d1d5db; border-radius:7px; padding:9px 12px; }
    .dv-wrap .form-control:focus,
    .dv-wrap .form-select:focus { border-color:#2563eb; box-shadow:0 0 0 3px rgba(37,99,235,.12); outline:none; }
    .dv-wrap .form-control.is-invalid { border-color:#dc2626; background-image:none; }

    .dv-footer { display:flex; justify-content:flex-end; gap:10px; padding-top:18px; border-top:1px solid #e5e7eb; margin-top:20px; }
    .dv-wrap .btn-primary { background-color:#2563eb; border-color:#2563eb; }
    .dv-wrap .btn-primary:hover { background-color:#1d4ed8; border-color:#1d4ed8; }
</style>

<div class="dv-wrap">

    <div class="dv-page-title">
        <h2>Chỉnh sửa thiết bị</h2>
        <p>Cập nhật thông tin và trạng thái của thiết bị</p>
    </div>

    @await Html.PartialAsync("_Alerts")

    <!-- Status strip (read-only info) -->
    <div class="status-strip">
        <div class="strip-item">
            <div class="strip-lbl">Mã TB</div>
            <span style="font-family:monospace; font-size:14px; color:#6b7280;">#@Model.DeviceId</span>
        </div>
        <div class="strip-item">
            <div class="strip-lbl">Trạng thái hiện tại</div>
            <span class="sb @(Model.Status == "Available" ? "sb-green" : Model.Status == "Borrowing" ? "sb-blue" : "sb-amber")">
                @(Model.Status == "Available" ? "Sẵn sàng" : Model.Status == "Borrowing" ? "Đang mượn" : "Đã trả")
            </span>
        </div>
        <div class="strip-item">
            <div class="strip-lbl">Tình trạng hiện tại</div>
            <span class="sb @(Model.Condition == "Good" ? "sb-green" : "sb-red")">
                @(Model.Condition == "Good" ? "Tốt" : "Hỏng")
            </span>
        </div>
    </div>

    <form asp-action="Edit" asp-controller="Device" asp-route-id="@Model.DeviceId" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div class="dv-section">
            <div class="dv-section-head">Thông tin thiết bị</div>
            <div class="dv-section-body">

                <div class="mb-3">
                    <label class="form-label">Tên thiết bị <span class="text-danger">*</span></label>
                    <input asp-for="DeviceName"
                           class="form-control @(ViewData.ModelState["DeviceName"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           placeholder="Tên thiết bị" />
                    <span asp-validation-for="DeviceName" class="invalid-feedback d-block small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Phân loại</label>
                    <input asp-for="Category" class="form-control"
                           placeholder="Ví dụ: Laptop, Camera, Máy chiếu..." />
                </div>

                <div class="mb-0">
                    <label class="form-label">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="3"
                              placeholder="Mô tả chi tiết về thiết bị..."></textarea>
                </div>

            </div>
        </div>

        <div class="dv-section">
            <div class="dv-section-head">Trạng thái & Tình trạng</div>
            <div class="dv-section-body">

                <div class="row g-3">
                    <div class="col-12 col-sm-6">
                        <label class="form-label">Trạng thái</label>
                        <select asp-for="Status" class="form-select">
                            <option value="Available">Sẵn sàng</option>
                            <option value="Borrowing">Đang mượn</option>
                            <option value="Returned">Đã trả</option>
                        </select>
                    </div>
                    <div class="col-12 col-sm-6">
                        <label class="form-label">Tình trạng</label>
                        <select asp-for="Condition" class="form-select">
                            <option value="Good">Tốt</option>
                            <option value="Broken">Hỏng</option>
                        </select>
                    </div>
                </div>

                <div class="dv-footer">
                    <a href="/Device/Index" class="btn btn-outline-secondary px-4">Hủy</a>
                    <button type="submit" class="btn btn-primary px-5">Lưu thay đổi</button>
                </div>

            </div>
        </div>

    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
