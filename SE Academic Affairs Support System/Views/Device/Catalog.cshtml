@model List<SE_Academic_Affairs_Support_System.Models.Device>
@{
    ViewData["Title"] = "Danh sách Thiết bị";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
    var selectedCat = ViewBag.SelectedCategory as string;
}

<style>
    .dv-page-title { border-left:4px solid #2563eb; padding-left:14px; margin-bottom:24px; }
    .dv-page-title h2 { font-size:22px; font-weight:700; color:#1e3a8a; margin-bottom:3px; }
    .dv-page-title p  { font-size:13px; color:#6b7280; margin:0; }

    .search-wrap { position:relative; }
    .search-wrap input { padding-left:12px; border-color:#d1d5db; border-radius:8px; font-size:14px; }
    .search-wrap input:focus { border-color:#2563eb; box-shadow:0 0 0 3px rgba(37,99,235,.12); outline:none; }

    .cat-pill { display:inline-block; padding:5px 14px; border-radius:20px; font-size:13px; font-weight:500; cursor:pointer; border:1px solid #d1d5db; background:#fff; color:#6b7280; text-decoration:none; transition:all .15s; white-space:nowrap; }
    .cat-pill:hover { border-color:#93c5fd; color:#2563eb; background:#eff6ff; }
    .cat-pill.active { background:#2563eb; border-color:#2563eb; color:#fff; }

    .dt-wrap { border:1px solid #e5e7eb; border-radius:10px; overflow:hidden; }
    .dt { border-collapse:collapse; width:100%; }
    .dt thead th { background:#f8fafc; padding:12px 16px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:#64748b; border-bottom:1px solid #e5e7eb; white-space:nowrap; }
    .dt tbody td { padding:13px 16px; border-bottom:1px solid #f1f5f9; vertical-align:middle; font-size:14px; color:#374151; }
    .dt tbody tr:last-child td { border-bottom:none; }
    .dt tbody tr:hover td { background:#f8fafc; }
    .dt tr.hidden { display:none !important; }

    .sb { display:inline-block; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:600; white-space:nowrap; }
    .sb-green { background:#dcfce7; color:#166534; border:1px solid #bbf7d0; }
    .sb-red   { background:#fee2e2; color:#991b1b; border:1px solid #fecaca; }
    .sb-blue  { background:#dbeafe; color:#1d4ed8; border:1px solid #bfdbfe; }

    .cat-tag  { background:#f1f5f9; border:1px solid #e2e8f0; color:#475569; padding:2px 8px; border-radius:6px; font-size:12px; }

    .btn-borrow { display:inline-block; padding:5px 14px; background:#2563eb; color:#fff; border-radius:6px; font-size:13px; font-weight:600; text-decoration:none; transition:all .15s; }
    .btn-borrow:hover { background:#1d4ed8; color:#fff; }
    .btn-borrow-disabled { display:inline-block; padding:5px 14px; background:#f1f5f9; color:#9ca3af; border-radius:6px; font-size:13px; font-weight:600; }

    @@media (max-width:767px) {
        /* Bỏ viền wrapper, để card tự quản */
        .dt-wrap { border:none; background:transparent; overflow:visible; border-radius:0; }
        .dt thead { display:none; }
        .dt, .dt tbody { display:block; background:transparent; }

        /* Mỗi hàng = 1 card */
        .dt tr {
            display:block;
            background:#fff;
            border:1px solid #e5e7eb;
            border-left:4px solid #2563eb;
            border-radius:10px;
            margin-bottom:16px;
            box-shadow:0 2px 10px rgba(37,99,235,.08);
            overflow:hidden;
        }
        .dt tr.hidden { display:none !important; }

        /* Hàng tên thiết bị — header của card */
        .dt td:first-child {
            background:#eff6ff;
            border-bottom:2px solid #bfdbfe;
            padding:12px 16px;
            display:block;
        }
        .dt td:first-child::before { display:none; }
        .dt td:first-child .fw-semibold { font-size:15px; color:#1e3a8a; }

        /* Hàng thao tác — footer của card */
        .dt td:last-child {
            background:#f8fafc;
            border-top:1px solid #e5e7eb;
            border-bottom:none;
            padding:12px 16px;
            display:block;
        }
        .dt td:last-child::before { display:none; }

        /* Các hàng giữa: label trái + value phải, ngang hàng */
        .dt td {
            display:flex;
            flex-direction:row;
            align-items:center;
            gap:10px;
            padding:9px 16px;
            border-bottom:1px solid #f1f5f9;
            font-size:13px;
            color:#374151;
            background:#fff;
        }
        .dt td::before {
            content:attr(data-label);
            font-size:11px;
            font-weight:700;
            text-transform:uppercase;
            letter-spacing:.05em;
            color:#6b7280;
            min-width:84px;
            flex-shrink:0;
        }

        /* Nút mượn full-width, nổi bật */
        .btn-borrow {
            display:block;
            width:100%;
            text-align:center;
            padding:11px 14px;
            font-size:14px;
            border-radius:8px;
        }
        .btn-borrow-disabled {
            display:block;
            width:100%;
            text-align:center;
            padding:11px 14px;
            font-size:14px;
            border-radius:8px;
            background:#f1f5f9;
            color:#9ca3af;
        }

        .dt tbody tr:hover td { background:#fff; }
        .dt tbody tr:hover td:first-child { background:#eff6ff; }
        .dt tbody tr:hover td:last-child { background:#f8fafc; }
    }
</style>

<div class="dv-page-title">
    <h2>Danh sách Thiết bị</h2>
    <p>Xem tất cả thiết bị hiện có và gửi yêu cầu mượn</p>
</div>

@await Html.PartialAsync("_Alerts")

<!-- Search + Category filter -->
<div class="d-flex flex-wrap gap-3 align-items-center mb-3">
    <div class="search-wrap flex-grow-1" style="max-width:360px;">
        <input type="text" id="searchInput" class="form-control" placeholder="Tìm tên thiết bị..." oninput="applyFilter()" />
    </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-4">
    <button class="cat-pill @(string.IsNullOrEmpty(selectedCat) ? "active" : "")" onclick="setCat('', this)">Tất cả</button>
    @foreach (var cat in categories)
    {
        <button class="cat-pill @(selectedCat == cat ? "active" : "")" onclick="setCat('@cat', this)">@cat</button>
    }
</div>

<!-- Table -->
<div class="dt-wrap">
    <table class="dt">
        <thead>
            <tr>
                <th>Tên thiết bị</th>
                <th>Phân loại</th>
                <th>Mô tả</th>
                <th>Tình trạng</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody id="deviceTable">
            @foreach (var d in Model)
            {
                <tr data-name="@d.DeviceName.ToLower()" data-cat="@(d.Category ?? "")">
                    <td data-label="Tên thiết bị">
                        <span class="fw-semibold">@d.DeviceName</span>
                    </td>
                    <td data-label="Phân loại">
                        <span class="cat-tag">@(string.IsNullOrEmpty(d.Category) ? "Khác" : d.Category)</span>
                    </td>
                    <td data-label="Mô tả">
                        <span class="text-muted" style="font-size:13px;">@(string.IsNullOrEmpty(d.Description) ? "—" : d.Description)</span>
                    </td>
                    <td data-label="Tình trạng">
                        <span class="sb @(d.Condition == "Good" ? "sb-green" : "sb-red")">
                            @(d.Condition == "Good" ? "Tốt" : "Hỏng")
                        </span>
                    </td>
                    <td data-label="Trạng thái">
                        <span class="sb @(d.Status == "Available" ? "sb-green" : "sb-blue")">
                            @(d.Status == "Available" ? "Sẵn sàng" : "Đang mượn")
                        </span>
                    </td>
                    <td data-label="Thao tác">
                        @if (d.Status == "Available" && d.Condition == "Good")
                        {
                            <a href="/Device/BorrowForm?deviceId=@d.DeviceId" class="btn-borrow">Mượn</a>
                        }
                        else
                        {
                            <span class="btn-borrow-disabled">Không có sẵn</span>
                        }
                    </td>
                </tr>
            }
            <tr id="emptyRow" class="hidden">
                <td colspan="6" style="text-align:center; padding:48px 16px; color:#9ca3af; font-size:14px;">
                    Không tìm thấy thiết bị phù hợp.
                </td>
            </tr>
        </tbody>
    </table>
</div>

<script>
    var currentCat = '@(selectedCat ?? "")';

    function setCat(cat, el) {
        currentCat = cat;
        document.querySelectorAll('.cat-pill').forEach(function(p) { p.classList.remove('active'); });
        el.classList.add('active');
        applyFilter();
    }

    function applyFilter() {
        var q = document.getElementById('searchInput').value.trim().toLowerCase();
        var rows = document.querySelectorAll('#deviceTable tr:not(#emptyRow)');
        var visible = 0;
        rows.forEach(function(tr) {
            var name = tr.getAttribute('data-name') || '';
            var cat  = tr.getAttribute('data-cat') || '';
            var matchQ   = !q || name.includes(q);
            var matchCat = !currentCat || cat === currentCat;
            if (matchQ && matchCat) {
                tr.classList.remove('hidden');
                visible++;
            } else {
                tr.classList.add('hidden');
            }
        });
        document.getElementById('emptyRow').classList.toggle('hidden', visible > 0);
    }
</script>
