@model List<SE_Academic_Affairs_Support_System.Models.Device>
@{
    ViewData["Title"] = "Danh sách thiết bị ";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
    var selectedCat = ViewBag.SelectedCategory as string;
    var searchVal = ViewBag.Search as string;
    var total = (int)(ViewBag.TotalAvailable ?? 0);

    // Hàm hỗ trợ render icon theo danh mục
    string Icon(string cat) => cat?.ToLower() switch
    {
        var c when c != null && c.Contains("chiếu") => "📽️",
        var c when c != null && c.Contains("âm thanh") => "🎙️",
        var c when c != null && c.Contains("micro") => "🎤",
        var c when c != null && c.Contains("màn hình") => "🖥️",
        var c when c != null && c.Contains("cáp") => "🔌",
        var c when c != null && c.Contains("camera") => "📷",
        var c when c != null && c.Contains("máy tính") => "💻",
        _ => "🔧"
    };
}

<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

<style>
    :root {
        --bg: #0f1117;
        --surface: #1a1d27;
        --surface2: #22263a;
        --border: #2e3350;
        --accent: #4f8ef7;
        --green: #22c55e;
        --yellow: #f59e0b;
        --red: #ef4444;
        --orange: #f97316;
        --text: #e8eaf6;
        --muted: #7c83a8;
        --radius: 12px;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Be Vietnam Pro', sans-serif;
    }

    .dm-page {
        padding: 28px 32px;
        max-width: 1200px;
        margin: 0 auto;
    }

    /* ── HEADER & SEARCH ── */
    .dm-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        margin-bottom: 32px;
    }

        .dm-header h1 {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .dm-header p {
            color: var(--muted);
            font-size: 15px;
        }

    .search-container {
        width: 100%;
        max-width: 600px;
        margin: 20px auto 0;
        position: relative;
    }

    .search-input {
        width: 100%;
        background: var(--surface);
        border: 1.5px solid var(--border);
        color: var(--text);
        padding: 14px 20px 14px 45px;
        border-radius: 50px;
        font-size: 15px;
        outline: none;
        transition: 0.2s;
        font-family: inherit;
    }

        .search-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(79, 142, 247, 0.15);
        }

    .search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 18px;
        color: var(--muted);
    }

    /* ── CATEGORY PILLS ── */
    .cat-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: center;
        margin-bottom: 24px;
    }

    .cpill {
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text);
        padding: 8px 16px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: 0.2s;
        user-select: none;
    }

        .cpill:hover {
            background: var(--surface2);
        }

        .cpill.active {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
        }

    /* ── TABLE ── */
    .dm-table-wrap {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: auto;
    }

    .dm-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

        .dm-table th {
            padding: 16px;
            font-size: 13px;
            color: var(--muted);
            text-transform: uppercase;
            background: var(--surface2);
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

        .dm-table td {
            padding: 16px;
            font-size: 14px;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }

        .dm-table tbody tr {
            transition: background 0.2s;
        }

            .dm-table tbody tr:hover {
                background: var(--surface2);
            }

            .dm-table tbody tr.hidden {
                display: none;
            }

    /* ── BADGES & ELEMENTS ── */
    .status-badge {
        display: inline-flex;
        gap: 5px;
        padding: 5px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    .badge-green {
        background: #22c55e1a;
        color: #86efac;
        border: 1px solid #22c55e33;
    }

    .badge-red {
        background: #ef44441a;
        color: #fca5a5;
        border: 1px solid #ef444433;
    }

    .device-name-wrap {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .device-icon {
        font-size: 20px;
        background: var(--surface2);
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        border: 1px solid var(--border);
    }

    .device-meta {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .device-code {
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        color: var(--muted);
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        transition: 0.2s;
        text-decoration: none;
    }

    }

    .empty-state {
        text-align: center;
        padding: 40px 20px;
        color: var(--muted);
    }
</style>

<div class="dm-page">
    <div class="dm-header">
        <h1 style="color: black;">Danh sách thiết bị</h1>
        <p>Hiện có <strong>@total</strong> thiết bị đang ở trạng thái sẵn sàng phục vụ</p>

        <div class="search-container">
            <span class="search-icon">🔍</span>
            <input type="text" id="sInput" class="search-input" placeholder="Tìm tên thiết bị, mã số, mô tả..." value="@searchVal" onkeyup="applyFilter()" autocomplete="off" />
        </div>
    </div>

    <div class="cat-pills">
        <div class="cpill @(string.IsNullOrEmpty(selectedCat) ? "active" : "")" onclick="setCat('', this)">Tất cả</div>
        @foreach (var c in categories)
        {
            <div class="cpill @(selectedCat == c ? "active" : "")" onclick="setCat('@c', this)">
                @Icon(c) @c
            </div>
        }
    </div>

    <div class="dm-table-wrap">
        <table class="dm-table">
            <thead>
                <tr>
                    <th>Thiết bị</th>
                    <th>Phân loại</th>
                    <th>Tình trạng</th>
                    <th style="text-align: right;">Thao tác</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @if (!Model.Any())
                {
                    <tr id="emptyDbRow"><td colspan="4" class="empty-state">Kho hiện tại chưa có thiết bị nào.</td></tr>
                }

                @foreach (var d in Model)
                {
                    bool isAvail = (d.Status == "Available" && d.Condition == "Good");

                    <tr class="device-row"
                        data-name="@(d.DeviceName?.ToLower())"
                        data-cat="@(d.Category)"
                        data-desc="@(d.Description?.ToLower())"
                        data-id="@d.DeviceId">

                        <td>
                            <div class="device-name-wrap">
                                <div class="device-icon">@Icon(d.Category)</div>
                                <div class="device-meta">
                                    <strong>@d.DeviceName</strong>
                                    <span class="device-code">#@d.DeviceId</span>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span style="color: var(--muted); font-size: 13px;">@(string.IsNullOrEmpty(d.Category) ? "Khác" : d.Category)</span>
                        </td>
                        <td>
                            @if (isAvail)
                            {
                                <span class="status-badge badge-green">Sẵn sàng</span>
                            }
                            else
                            {
                                <span class="status-badge badge-red">Không khả dụng</span>
                            }
                        </td>
                        <td style="text-align: right;">
                            @if (isAvail)
                            {
                                <a href="/Device/BorrowForm?deviceId=@d.DeviceId" class="btn btn-primary">Mượn ngay →</a>
                            }
                            else
                            {
                                <span class="btn btn-disabled">Tạm hết</span>
                            }
                        </td>
                    </tr>
                }
                <tr id="emptySearchRow" style="display: none;">
                    <td colspan="4" class="empty-state">
                        <div style="font-size: 24px; margin-bottom: 8px;">👻</div>
                        Không tìm thấy thiết bị nào phù hợp với bộ lọc.
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<script>
    let activeCat = '@selectedCat';

    // Xử lý click chọn Tab danh mục
    function setCat(cat, btn) {
        activeCat = cat;
        document.querySelectorAll('.cpill').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        applyFilter();
    }

    // Xử lý bộ lọc Tìm kiếm & Danh mục
    function applyFilter() {
        let q = (document.getElementById('sInput').value || '').toLowerCase().trim();
        let rows = document.querySelectorAll('.device-row');
        let visibleCount = 0;

        rows.forEach(row => {
            let matchCat = !activeCat || row.dataset.cat === activeCat;
            let matchSearch = !q
                || row.dataset.name.includes(q)
                || row.dataset.id.includes(q)
                || (row.dataset.desc && row.dataset.desc.includes(q));

            if (matchCat && matchSearch) {
                row.classList.remove('hidden');
                visibleCount++;
            } else {
                row.classList.add('hidden');
            }
        });

        // Hiển thị dòng thông báo nếu tìm không thấy
        let emptyRow = document.getElementById('emptySearchRow');
        let dbEmptyRow = document.getElementById('emptyDbRow');

        if (emptyRow) {
            // Chỉ hiện "Không tìm thấy" nếu trong DB có đồ nhưng bị filter mất
            emptyRow.style.display = (visibleCount === 0 && !dbEmptyRow) ? 'table-row' : 'none';
        }
    }

    // Chạy filter ngay lần đầu load trang (nếu có sắn từ khóa search từ Controller)
    document.addEventListener('DOMContentLoaded', applyFilter);
</script>