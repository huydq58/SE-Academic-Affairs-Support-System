@model SE_Academic_Affairs_Support_System.Models.CreateBorrowViewModel
@{
    ViewData["Title"] = "Đăng ký mượn thiết bị";
}

<style>
    .bf-wrap { max-width:700px; margin:0 auto; }

    .bf-section {border:1px solid #dbeafe; border-radius:10px; overflow:hidden; margin-bottom:18px; }
    .bf-section-head { background:#eff6ff; border-bottom:1px solid #bfdbfe; padding:10px 18px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:#1d4ed8; }
    .bf-section-body { padding:20px 18px; }

    .bf-wrap .form-label { font-size:13px; font-weight:600; color:#374151; }
    .bf-wrap .form-control,
    .bf-wrap .form-select { font-size:14px; border-color:#d1d5db; border-radius:7px; padding:9px 12px; }
    .bf-wrap .form-control:focus,
    .bf-wrap .form-select:focus { border-color:#2563eb; box-shadow:0 0 0 3px rgba(37,99,235,.12); outline:none; }
    .bf-wrap .form-control.is-invalid { border-color:#dc2626; background-image:none; }

    .device-pick-list { display:flex; flex-direction:column; gap:8px; max-height:340px; overflow-y:auto; }
    .device-pick-row { display:flex; align-items:center; gap:12px; border:1px solid #e5e7eb; border-radius:8px; padding:8px 12px; }
    .device-pick-row:hover { border-color:#bfdbfe; background:#f8fbff; }
    .dp-check { display:flex; align-items:center; gap:10px; flex:1; margin:0; cursor:pointer; }
    .dp-check .dp-cb { width:17px; height:17px; }
    .dp-name { font-size:14px; color:#1f2937; font-weight:500; }
    .dp-cat { font-size:12px; color:#6b7280; margin-left:4px; }
    .dp-qty { display:flex; align-items:center; gap:6px; flex-shrink:0; }
    .dp-qty label { font-size:11px; font-weight:700; color:#9ca3af; margin:0; }
    .dp-qty input { width:74px; }

    .commit-box { background:#fefce8; border:1px solid #fde68a; border-radius:8px; padding:14px 16px; }
    .commit-box p { font-size:13px; color:#78350f; margin:0 0 10px 0; line-height:1.6; }

    .bf-footer { display:flex; justify-content:flex-end; gap:10px; padding-top:18px; border-top:1px solid #e5e7eb; margin-top:20px; }
    .bf-wrap .btn-primary { background-color:#2563eb; border-color:#2563eb; }
    .bf-wrap .btn-primary:hover { background-color:#1d4ed8; border-color:#1d4ed8; }
</style>

<div class="bf-wrap">

    <div class="dv-page-title">
        <h2>Đăng ký mượn thiết bị</h2>
        <p>Chọn một hoặc nhiều thiết bị và điền thông tin để gửi yêu cầu mượn</p>
    </div>

    @await Html.PartialAsync("_Alerts")

    <form asp-action="BorrowForm" asp-controller="Device" method="post" novalidate hx-boost="false">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

        <!-- Device selection (multi) -->
        <div class="bf-section">
            <div class="bf-section-head">Chọn thiết bị (có thể chọn nhiều)</div>
            <div class="bf-section-body">
                @if (!Model.Items.Any())
                {
                    <p class="text-muted" style="font-size:13px; margin:0;">
                        Hiện không có thiết bị nào sẵn sàng để mượn.
                    </p>
                }
                else
                {
                    <div class="device-pick-list">
                        @for (int i = 0; i < Model.Items.Count; i++)
                        {
                            <div class="device-pick-row">
                                <input type="hidden" asp-for="Items[i].DeviceId" />
                                <input type="hidden" asp-for="Items[i].DeviceName" />
                                <input type="hidden" asp-for="Items[i].Category" />
                                <input type="hidden" asp-for="Items[i].Available" />
                                <label class="dp-check">
                                    <input type="checkbox" asp-for="Items[i].Selected" class="dp-cb" />
                                    <span class="dp-name">
                                        @Model.Items[i].DeviceName
                                        @if (!string.IsNullOrEmpty(Model.Items[i].Category))
                                        {
                                            <span class="dp-cat">(@Model.Items[i].Category)</span>
                                        }
                                        <span class="dp-cat" style="color:#16a34a;">• còn @Model.Items[i].Available</span>
                                    </span>
                                </label>
                                <div class="dp-qty">
                                    <label>SL</label>
                                    <input type="number" asp-for="Items[i].Quantity" min="1" max="@Model.Items[i].Available"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Borrower info -->
        <div class="bf-section">
            <div class="bf-section-head">Thông tin người mượn</div>
            <div class="bf-section-body">

                <div class="mb-3">
                    <label class="form-label">Họ và tên <span class="text-danger">*</span></label>
                    <input asp-for="BorrowerName" class="form-control" placeholder="Nguyễn Văn A" />
                    <span asp-validation-for="BorrowerName" class="text-danger small"></span>
                </div>

                <div class="mb-0">
                    <label class="form-label">Email <span class="text-danger">*</span></label>
                    <input asp-for="BorrowerEmail" type="email" class="form-control"
                           placeholder="email@student.uit.edu.vn" />
                    <span asp-validation-for="BorrowerEmail" class="text-danger small"></span>
                </div>

            </div>
        </div>

        <!-- Purpose -->
        <div class="bf-section">
            <div class="bf-section-head">Mục đích sử dụng</div>
            <div class="bf-section-body">
                <div>
                    <label class="form-label">Mô tả mục đích <span class="text-danger">*</span></label>
                    <textarea asp-for="Purpose" class="form-control" rows="3"
                              placeholder="Mô tả ngắn gọn mục đích mượn thiết bị..."></textarea>
                    <span asp-validation-for="Purpose" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <!-- Commitment -->
        <div class="bf-section">
            <div class="bf-section-head">Cam kết sử dụng</div>
            <div class="bf-section-body">
                <div class="commit-box">
                    <p>
                        Bằng việc gửi yêu cầu này, tôi cam kết sử dụng thiết bị đúng mục đích,
                        giữ gìn cẩn thận và hoàn trả kịp thời trong tình trạng nguyên vẹn.
                        Trong trường hợp hỏng hóc hoặc mất mát, tôi chịu hoàn toàn trách nhiệm bồi thường.
                    </p>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="commitCheck" required />
                        <label class="form-check-label" for="commitCheck"
                               style="font-size:13px; font-weight:600; color:#78350f;">
                            Tôi đã đọc và đồng ý với các điều khoản trên
                        </label>
                    </div>
                </div>

                <div class="bf-footer">
                    <a href="/Device/Catalog" class="btn btn-outline-secondary px-4">Hủy</a>
                    <button type="submit" class="btn btn-primary px-5">Gửi yêu cầu</button>
                </div>
            </div>
        </div>

    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
