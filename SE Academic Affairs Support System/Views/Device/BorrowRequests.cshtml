@model List<SE_Academic_Affairs_Support_System.Models.DeviceRequestViewModel>
@{
    ViewData["Title"] = "Duyệt Yêu Cầu Mượn";
}

<style>
    .dv-page-title { border-left:4px solid #2563eb; padding-left:14px; margin-bottom:24px; }
    .dv-page-title h2 { font-size:22px; font-weight:700; color:#1e3a8a; margin-bottom:3px; }
    .dv-page-title p  { font-size:13px; color:#6b7280; margin:0; }

    .stat-box { background:#fff; border:1px solid #e5e7eb; border-radius:10px; padding:14px 12px; text-align:center; }
    .stat-num  { font-size:26px; font-weight:700; line-height:1; margin-bottom:4px; color:#374151; }
    .stat-lbl  { font-size:12px; color:#6b7280; font-weight:500; }
    .sn-amber  { color:#d97706; }
    .sn-green  { color:#16a34a; }

    .tab-pill { display:inline-block; padding:5px 16px; border-radius:20px; font-size:13px; font-weight:500; cursor:pointer; border:1px solid #d1d5db; background:#fff; color:#6b7280; transition:all .15s; white-space:nowrap; }
    .tab-pill:hover { border-color:#93c5fd; color:#2563eb; background:#eff6ff; }
    .tab-pill.active { background:#2563eb; border-color:#2563eb; color:#fff; }

    .req-card { border:1px solid #e5e7eb; border-radius:10px; margin-bottom:14px; background:#fff; overflow:hidden; transition:box-shadow .15s; }
    .req-card:hover { box-shadow:0 2px 8px rgba(37,99,235,.1); }
    .req-card.status-Pending   { border-left:4px solid #f59e0b; }
    .req-card.status-Approved  { border-left:4px solid #22c55e; }
    .req-card.status-Rejected  { border-left:4px solid #ef4444; }
    .req-card.status-Returned  { border-left:4px solid #6b7280; }

    .req-header { background:#f8fafc; border-bottom:1px solid #e5e7eb; padding:12px 18px; display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; }
    .req-title  { font-weight:700; color:#1e3a8a; font-size:15px; }
    .req-body   { padding:16px 18px; }
    .req-meta   { display:grid; grid-template-columns:repeat(auto-fill, minmax(200px, 1fr)); gap:10px; margin-bottom:14px; }
    .meta-lbl   { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:#9ca3af; margin-bottom:3px; }
    .meta-val   { font-size:14px; color:#374151; }

    .req-actions { display:flex; gap:8px; flex-wrap:wrap; }
    .btn-act { display:inline-flex; align-items:center; padding:5px 14px; border-radius:6px; font-size:13px; font-weight:600; cursor:pointer; border:1px solid #e5e7eb; background:#fff; color:#374151; transition:all .15s; }
    .btn-act-success { background:#22c55e; color:#fff; border-color:#22c55e; }
    .btn-act-success:hover { background:#16a34a; border-color:#16a34a; }
    .btn-act-danger { background:#fff; color:#dc2626; border-color:#fecaca; }
    .btn-act-danger:hover { background:#fee2e2; border-color:#fca5a5; }

    .sb { display:inline-block; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:600; white-space:nowrap; }
    .sb-green { background:#dcfce7; color:#166534; border:1px solid #bbf7d0; }
    .sb-amber { background:#fef3c7; color:#92400e; border:1px solid #fde68a; }
    .sb-red   { background:#fee2e2; color:#991b1b; border:1px solid #fecaca; }
    .sb-gray  { background:#f3f4f6; color:#374151; border:1px solid #e5e7eb; }

    .req-card.hidden { display:none !important; }

    .empty-state { text-align:center; padding:60px 20px; color:#9ca3af; }
    .empty-state p { font-size:14px; margin-top:8px; }
</style>

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
    <div class="dv-page-title mb-0">
        <h2>Duyệt Yêu Cầu Mượn Thiết bị</h2>
        <p>Xem xét và phê duyệt các yêu cầu mượn thiết bị</p>
    </div>
    <a href="/Device/Index" class="btn btn-outline-secondary btn-sm px-3">Quản lý kho</a>
</div>

@await Html.PartialAsync("_Alerts")

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-6 col-sm-4">
        <div class="stat-box">
            <div class="stat-num sn-amber">@Model.Count(r => r.Request.Status == "Pending")</div>
            <div class="stat-lbl">Chờ duyệt</div>
        </div>
    </div>
    <div class="col-6 col-sm-4">
        <div class="stat-box">
            <div class="stat-num sn-green">@Model.Count(r => r.Request.Status == "Approved")</div>
            <div class="stat-lbl">Đã duyệt</div>
        </div>
    </div>
    <div class="col-6 col-sm-4">
        <div class="stat-box">
            <div class="stat-num">@Model.Count</div>
            <div class="stat-lbl">Tổng cộng</div>
        </div>
    </div>
</div>

<!-- Tab filter -->
<div class="d-flex flex-wrap gap-2 mb-4">
    <button class="tab-pill active" onclick="setTab('all', this)">Tất cả</button>
    <button class="tab-pill" onclick="setTab('Pending', this)">Chờ duyệt</button>
    <button class="tab-pill" onclick="setTab('Approved', this)">Đã duyệt</button>
    <button class="tab-pill" onclick="setTab('Rejected', this)">Đã từ chối</button>
    <button class="tab-pill" onclick="setTab('Returned', this)">Đã trả</button>
</div>

<!-- Request cards -->
<div id="requestList">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <p>Chưa có yêu cầu mượn thiết bị nào.</p>
        </div>
    }
    @foreach (var vm in Model)
    {
        var req    = vm.Request;
        var device = vm.Device;
        var statusLabel = req.Status == "Pending"  ? "Chờ duyệt"   :
                          req.Status == "Approved" ? "Đã duyệt"    :
                          req.Status == "Rejected" ? "Đã từ chối"  :
                          req.Status == "Returned" ? "Đã trả"      : req.Status;
        var statusClass = req.Status == "Pending"  ? "sb-amber" :
                          req.Status == "Approved" ? "sb-green"  :
                          req.Status == "Rejected" ? "sb-red"    : "sb-gray";

        <div class="req-card status-@req.Status" data-status="@req.Status">
            <div class="req-header">
                <span class="req-title">@(device?.DeviceName ?? "Thiết bị không xác định")</span>
                <span class="sb @statusClass">@statusLabel</span>
            </div>
            <div class="req-body">
                <div class="req-meta">
                    <div>
                        <div class="meta-lbl">Người mượn</div>
                        <div class="meta-val fw-semibold">@req.BorrowerName</div>
                    </div>
                    <div>
                        <div class="meta-lbl">Email</div>
                        <div class="meta-val">@req.BorrowerEmail</div>
                    </div>
                    <div>
                        <div class="meta-lbl">Ngày yêu cầu</div>
                        <div class="meta-val">@req.RequestDate.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    @if (req.ReturnDate.HasValue)
                    {
                        <div>
                            <div class="meta-lbl">Ngày trả</div>
                            <div class="meta-val">@req.ReturnDate.Value.ToString("dd/MM/yyyy")</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(req.Purpose))
                    {
                        <div style="grid-column:1/-1;">
                            <div class="meta-lbl">Mục đích</div>
                            <div class="meta-val">@req.Purpose</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(req.RejectReason))
                    {
                        <div style="grid-column:1/-1;">
                            <div class="meta-lbl">Lý do từ chối</div>
                            <div class="meta-val text-danger">@req.RejectReason</div>
                        </div>
                    }
                </div>

                @if (req.Status == "Pending")
                {
                    <div class="req-actions">
                        <form method="post" action="/Device/ApproveRequest/@req.RequestId" style="margin:0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-act btn-act-success">Phê duyệt</button>
                        </form>
                        <form method="post" action="/Device/RejectRequest/@req.RequestId" style="margin:0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-act btn-act-danger"
                                    onclick="return confirm('Xác nhận từ chối yêu cầu của @req.BorrowerName?')">
                                Từ chối
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    }
</div>

<div id="emptyTabMsg" class="empty-state" style="display:none;">
    <p>Không có yêu cầu nào trong mục này.</p>
</div>

<script>
    function setTab(status, el) {
        document.querySelectorAll('.tab-pill').forEach(function(p) { p.classList.remove('active'); });
        el.classList.add('active');
        var cards = document.querySelectorAll('.req-card');
        var visible = 0;
        cards.forEach(function(c) {
            var s = c.getAttribute('data-status');
            var show = (status === 'all') || (s === status);
            c.classList.toggle('hidden', !show);
            if (show) visible++;
        });
        document.getElementById('emptyTabMsg').style.display = (visible === 0 ? 'block' : 'none');
    }
</script>
