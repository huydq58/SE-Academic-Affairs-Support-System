@model List<SE_Academic_Affairs_Support_System.Models.DeviceRequestViewModel>
@{
    ViewData["Title"] = "Duyệt Yêu Cầu Mượn";
}

<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

<style>
    :root {
        --bg: #0f1117; --surface: #1a1d27; --surface2: #22263a;
        --border: #2e3350; --accent: #4f8ef7; --accent2: #7c5cfc;
        --green: #22c55e; --yellow: #f59e0b; --red: #ef4444;
        --orange: #f97316; --text: #e8eaf6; --muted: #7c83a8; --radius: 12px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--text); font-family: 'Be Vietnam Pro', sans-serif; }

    .page { padding: 28px 32px; max-width: 1100px; margin: 0 auto; }

    .page-header { display: flex; align-items: center; gap: 16px; margin-bottom: 28px; flex-wrap: wrap; }
    .page-header a { display: inline-flex; align-items: center; gap: 6px; color: var(--muted); font-size: 13px; text-decoration: none; }
    .page-header a:hover { color: var(--text); }
    .page-header h1 { font-size: 24px; font-weight: 700; }

    .alert { padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; display: flex; align-items: center; gap: 10px; }
    .alert-success { background: #22c55e1a; border: 1px solid #22c55e44; color: #86efac; }
    .alert-error   { background: #ef44441a; border: 1px solid #ef444444; color: #fca5a5; }

    /* TABS */
    .tabs { display: flex; gap: 4px; margin-bottom: 20px; background: var(--surface); padding: 6px; border-radius: 10px; border: 1px solid var(--border); width: fit-content; flex-wrap: wrap; }
    .tab-btn { padding: 7px 16px; border-radius: 7px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; background: transparent; color: var(--muted); font-family: 'Be Vietnam Pro', sans-serif; transition: all 0.15s; }
    .tab-btn.active { background: var(--surface2); color: var(--text); }
    .tab-btn:hover:not(.active) { color: var(--text); }

    /* CARDS */
    .request-list { display: flex; flex-direction: column; gap: 12px; }

    .request-card {
        background: var(--surface); border: 1px solid var(--border);
        border-radius: var(--radius); padding: 20px 24px;
        display: grid; grid-template-columns: 1fr auto; gap: 16px;
        transition: border-color 0.2s;
    }
    .request-card:hover { border-color: var(--accent); }
    .request-card.pending  { border-left: 3px solid var(--yellow); }
    .request-card.approved { border-left: 3px solid var(--green); }
    .request-card.rejected { border-left: 3px solid var(--red); }
    .request-card.returned { border-left: 3px solid var(--orange); }

    .rc-left { display: flex; flex-direction: column; gap: 10px; }
    .rc-top { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .rc-device-name { font-size: 16px; font-weight: 700; }
    .rc-category { background: var(--surface2); color: var(--muted); border: 1px solid var(--border); border-radius: 6px; padding: 2px 8px; font-size: 12px; }

    .rc-meta { display: flex; gap: 20px; flex-wrap: wrap; font-size: 13px; color: var(--muted); }
    .rc-meta span { display: flex; align-items: center; gap: 5px; }
    .rc-meta strong { color: var(--text); }

    .rc-purpose { background: var(--surface2); border-radius: 8px; padding: 9px 14px; font-size: 13px; color: var(--muted); border-left: 2px solid var(--border); }
    .rc-purpose span { color: var(--text); }
    .rc-reject-reason { background: #ef44441a; border-radius: 8px; padding: 8px 14px; font-size: 13px; color: #fca5a5; border-left: 2px solid var(--red); }

    .rc-right { display: flex; flex-direction: column; align-items: flex-end; gap: 10px; justify-content: space-between; }

    .status-badge { display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px; border-radius: 20px; font-size: 12px; font-weight: 700; white-space: nowrap; }
    .s-pending  { background: #f59e0b1a; color: var(--yellow); border: 1px solid #f59e0b44; }
    .s-approved { background: #22c55e1a; color: #86efac;       border: 1px solid #22c55e44; }
    .s-rejected { background: #ef44441a; color: #fca5a5;       border: 1px solid #ef444444; }
    .s-returned { background: #f973161a; color: #fdba74;       border: 1px solid #f9731644; }

    .rc-time { font-size: 11px; color: var(--muted); font-family: 'Space Mono', monospace; }

    .action-btns { display: flex; gap: 8px; }
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; transition: all 0.18s; text-decoration: none; font-family: 'Be Vietnam Pro', sans-serif; }
    .btn-approve { background: var(--green); color: #000; }
    .btn-approve:hover { background: #16a34a; color: #000; }
    .btn-reject  { background: transparent; color: var(--red); border: 1.5px solid var(--red); }
    .btn-reject:hover { background: #ef44441a; }
    .btn-outline { background: transparent; color: var(--text); border: 1.5px solid var(--border); }
    .btn-outline:hover { border-color: var(--accent); color: var(--accent); }

    /* EMPTY */
    .empty { padding: 60px; text-align: center; color: var(--muted); }
    .empty .icon { font-size: 48px; margin-bottom: 12px; }
    .empty h3 { font-size: 16px; color: var(--text); margin-bottom: 4px; }

    
</style>

<div class="page">
    <div class="page-header">
        <a href="/Device/Index">← Quay lại danh sách</a>
        <h1 style="color: black">Yêu cầu mượn thiết bị</h1>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">✅ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-error">⚠️ @TempData["Error"]</div>
    }

    <!-- TABS -->
    <div class="tabs">
        <button class="tab-btn active" onclick="filterTab('all', this)">Tất cả (@Model.Count)</button>
        <button class="tab-btn" onclick="filterTab('Pending', this)">Chờ duyệt (@Model.Count(r => r.Request.Status == "Pending"))</button>
        <button class="tab-btn" onclick="filterTab('Approved', this)">Đã duyệt (@Model.Count(r => r.Request.Status == "Approved"))</button>
        <button class="tab-btn" onclick="filterTab('Rejected', this)">Từ chối (@Model.Count(r => r.Request.Status == "Rejected"))</button>
        <button class="tab-btn" onclick="filterTab('Returned', this)">Đã trả (@Model.Count(r => r.Request.Status == "Returned"))</button>
    </div>

    <!-- CARDS -->
    <div class="request-list" id="requestList">
        @if (!Model.Any())
        {
            <div class="empty">
                <div class="icon">📭</div>
                <h3>Chưa có yêu cầu mượn nào</h3>
                <p>Các yêu cầu mượn từ sinh viên sẽ hiển thị ở đây</p>
            </div>
        }

        @foreach (var vm in Model)
        {
            var r   = vm.Request;
            var dev = vm.Device;
            <div class="request-card @r.Status.ToLower()" data-status="@r.Status">
                <div class="rc-left">
                    <div class="rc-top">
                        <span class="rc-device-name">@(dev?.DeviceName ?? "Thiết bị không tìm thấy")</span>
                        @if (!string.IsNullOrEmpty(dev?.Category))
                        {
                            <span class="rc-category">@dev.Category</span>
                        }
                    </div>
                    <div class="rc-meta">
                        <span>👤 <strong>@r.BorrowerName</strong></span>
                        <span>✉️ <strong>@r.BorrowerEmail</strong></span>
                        <span>📅 <strong>@r.RequestDate.ToString("dd/MM/yyyy HH:mm")</strong></span>
                    </div>
                    <div class="rc-purpose">
                        🎯 Mục đích: <span>@r.Purpose</span>
                    </div>
                    @if (r.Status == "Rejected" && !string.IsNullOrEmpty(r.RejectReason))
                    {
                        <div class="rc-reject-reason">❌ Lý do từ chối: @r.RejectReason</div>
                    }
                </div>
                <div class="rc-right">
                    <span class="status-badge @(r.Status == "Pending" ? "s-pending" : r.Status == "Approved" ? "s-approved" : r.Status == "Rejected" ? "s-rejected" : "s-returned")">
                        @(r.Status == "Pending" ? "⏳ Chờ duyệt" : r.Status == "Approved" ? "✅ Đã duyệt" : r.Status == "Rejected" ? "❌ Từ chối" : "🟠 Đã trả")
                    </span>
                    <span class="rc-time">#@r.RequestId</span>
                    @if (r.Status == "Pending")
                    {
                        <div class="action-btns">
                            <button type="button"
                                    class="btn btn-approve"
                                    data-devicename="@(dev?.DeviceName ?? "")"
                                    onclick="confirmApprove('@r.RequestId', this.getAttribute('data-devicename'))">
                                ✅ Duyệt
                            </button>

                            <button type="button"
                                    class="btn btn-reject"
                                    data-devicename="@(dev?.DeviceName ?? "")"
                                    onclick="confirmReject('@r.RequestId', this.getAttribute('data-devicename'))">
                                ❌ Từ chối
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>


<form id="actionForm" method="post" style="display: none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="rejectReason" id="hiddenRejectReason" value="" />
</form>
<script>
    // ── XỬ LÝ DUYỆT ──
    function confirmApprove(requestId, devName) {
        if (confirm(`✅ Bạn có chắc chắn muốn DUYỆT yêu cầu mượn thiết bị:\n- ${devName}\n\nThiết bị sẽ chuyển sang trạng thái "Đang mượn".`)) {
            let form = document.getElementById('actionForm');
            form.action = '/Device/ApproveRequest/' + requestId;
            form.submit();
        }
    }

    // ── XỬ LÝ TỪ CHỐI ──
    function confirmReject(requestId, devName) {
        // Dùng prompt để cho phép nhập lý do tùy chọn (nhấn Cancel sẽ trả về null)
        let reason = prompt(`❌ Bạn có chắc chắn muốn TỪ CHỐI yêu cầu mượn thiết bị:\n- ${devName}\n\nNhập lý do từ chối (tùy chọn rồi nhấn OK):`);

        if (reason !== null) {
            let form = document.getElementById('actionForm');
            form.action = '/Device/RejectRequest/' + requestId;
            document.getElementById('hiddenRejectReason').value = reason;
            form.submit();
        }
    }

    // ── TABS (giữ nguyên) ──
    function filterTab(status, btn) {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('.request-card').forEach(card => {
            card.style.display = (status === 'all' || card.dataset.status === status) ? 'grid' : 'none';
        });
    }
</script>