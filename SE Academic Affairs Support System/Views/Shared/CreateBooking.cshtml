@model SE_Academic_Affairs_Support_System.ViewModels.CreateBookingViewModel

@{
    ViewData["Title"] = "Gửi yêu cầu đặt phòng";
}

<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

<style>
    :root {
        --bg: #0f1117;
        --surface: #1a1d27;
        --surface2: #22263a;
        --border: #2e3350;
        --accent: #4f8ef7;
        --green: #22c55e;
        --yellow: #f59e0b;
        --red: #ef4444;
        --text: #e8eaf6;
        --muted: #7c83a8;
        --radius: 12px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Be Vietnam Pro', sans-serif;
    }

    .dm-page {
        padding: 28px 32px;
        max-width: 640px;
        margin: 0 auto;
    }

    /* ── HEADER ── */
    .dm-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        margin-bottom: 32px;
    }

    .dm-header h1 {
        font-size: 28px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 8px;
    }

    .dm-header p { font-size: 15px; color: var(--muted); }

    /* ── ALERT ── */
    .alert-error {
        background: #ef44441a;
        border: 1px solid #ef444444;
        color: #fca5a5;
        border-radius: 8px;
        padding: 12px 14px;
        font-size: 13px;
        margin-bottom: 20px;
    }

    /* ── CARD ── */
    .dm-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
        margin-bottom: 20px;
    }

    .dm-card h3 {
        font-size: 13px;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 8px;
        border-bottom: 1px solid var(--border);
        padding-bottom: 12px;
        text-transform: uppercase;
        color: var(--muted);
        font-weight: 600;
        letter-spacing: 0.04em;
    }

    /* ── BOOKING INFO SUMMARY ── */
    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .info-item { display: flex; flex-direction: column; gap: 4px; }

    .info-label {
        font-size: 11px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        font-weight: 600;
    }

    .info-value {
        font-size: 15px;
        font-weight: 600;
        color: var(--text);
        font-family: 'Space Mono', monospace;
    }

    .info-value.accent { color: var(--accent); }

    .time-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #4f8ef711;
        border: 1px solid #4f8ef733;
        color: #93c5fd;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
        font-family: 'Space Mono', monospace;
        margin-top: 4px;
    }

    /* ── FORM ── */
    .form-group { margin-bottom: 16px; }

    .form-group label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        color: var(--muted);
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .req { color: var(--red); margin-left: 2px; }

    .form-control {
        width: 100%;
        background: var(--surface2);
        border: 1px solid var(--border);
        color: var(--text);
        padding: 10px 14px;
        border-radius: 8px;
        font-size: 14px;
        outline: none;
        transition: 0.2s;
        font-family: inherit;
    }

    .form-control:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(79, 142, 247, 0.15);
    }

    textarea.form-control { resize: vertical; min-height: 90px; }

    .invalid-msg { font-size: 12px; color: #fca5a5; margin-top: 4px; display: block; }

    /* ── BUTTONS ── */
    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 11px 20px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        transition: 0.2s;
        text-decoration: none;
    }

    .btn-primary {
        background: var(--accent);
        color: #fff;
        flex: 1;
    }

    .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }

    .btn-outline {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text);
    }

    .btn-outline:hover { background: var(--surface2); }

    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 8px;
    }
</style>

<div class="dm-page">

    <div class="dm-header">
        <h1>Đặt phòng học</h1>
        <p>Điền thông tin để gửi yêu cầu đến Phòng Quản lý</p>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert-error">
            <div asp-validation-summary="All"></div>
        </div>
    }

    <form asp-action="CreateBooking" method="post">
        <input type="hidden" asp-for="RoomId" />
        <input type="hidden" asp-for="BookingDate" />
        <input type="hidden" asp-for="RoomName" />
        <input type="hidden" asp-for="StartTime" />
        <input type="hidden" asp-for="EndTime" />

        @* ── Thông tin đặt phòng ── *@
        <div class="dm-card">
            <h3>📋 Thông tin đặt phòng</h3>
            <div class="info-grid">
                <div class="info-item">
                    <span class="info-label">Phòng</span>
                    <span class="info-value accent">@Model.RoomName</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Ngày đặt</span>
                    <span class="info-value">@Model.BookingDate.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="info-item" style="grid-column: 1 / -1;">
                    <span class="info-label">Thời gian</span>
                    <span class="time-badge">
                        🕐 @Model.StartTime.ToString(@"hh\:mm") — @Model.EndTime.ToString(@"hh\:mm")
                    </span>
                </div>
            </div>
        </div>

        @* ── Thông tin người đặt ── *@
        <div class="dm-card">
            <h3>👤 Thông tin người đặt</h3>

            <div class="form-group">
                <label>Tên người đặt <span class="req">*</span></label>
                <input asp-for="UserName" class="form-control" placeholder="Nhập họ và tên" />
                <span asp-validation-for="UserName" class="invalid-msg"></span>
            </div>

            <div class="form-group">
                <label>Số điện thoại <span class="req">*</span></label>
                <input asp-for="PhoneNumber" class="form-control" placeholder="09xxxxxxxx" />
                <span asp-validation-for="PhoneNumber" class="invalid-msg"></span>
            </div>

            <div class="form-group">
                <label>Email liên hệ <span class="req">*</span></label>
                <input asp-for="UserEmail" class="form-control" placeholder="abc@gmail.com" />
            </div>

            <div class="form-group">
                <label>Mục đích sử dụng <span class="req">*</span></label>
                <textarea asp-for="Purpose" class="form-control"
                          placeholder="Học bù, Seminar, Họp nhóm..."></textarea>
                <span asp-validation-for="Purpose" class="invalid-msg"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Gửi yêu cầu →</button>
                <a href="@Url.Action("RoomBooking", new { roomId = Model.RoomId })"
                   class="btn btn-outline">Hủy</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
