@model SE_Academic_Affairs_Support_System.ViewModels.CreateBookingViewModel

@{
    ViewData["Title"] = "Gửi yêu cầu đặt phòng";
}

<div style="max-width:640px;">

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb" style="font-size:13px;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("RoomList", "Home")">Danh sách phòng</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("WeeklySchedule", "Room", new { roomId = Model.RoomId })">Lịch phòng</a>
            </li>
            <li class="breadcrumb-item active">Đặt phòng</li>
        </ol>
    </nav>

    <div class="rg-page-title">
        <h2>Gửi Yêu Cầu Đặt Phòng</h2>
        <p>Điền thông tin để gửi yêu cầu đến Phòng Quản lý</p>
    </div>

    <partial name="_Alerts" />

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger py-2 mb-3" style="font-size:13px;">
            <div asp-validation-summary="All"></div>
        </div>
    }

    <form asp-action="CreateBooking" asp-controller="Room" method="post" hx-boost="false">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="RoomId" />
        <input type="hidden" asp-for="BookingDate" />
        <input type="hidden" asp-for="RoomName" />
        <input type="hidden" asp-for="StartTime" />
        <input type="hidden" asp-for="EndTime" />

        @* Tóm tắt thông tin đặt phòng *@
        <div class="rg-form-card mb-3">
            <div class="rg-form-head">Thông tin đặt phòng</div>
            <div class="rg-form-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:#9ca3af; margin-bottom:4px;">Phòng</div>
                        <div style="font-size:15px; font-weight:700; color:#2563eb;">@Model.RoomName</div>
                    </div>
                    <div class="col-sm-6">
                        <div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:#9ca3af; margin-bottom:4px;">Ngày đặt</div>
                        <div style="font-size:15px; font-weight:600; color:#374151;">@Model.BookingDate.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="col-12">
                        <div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:#9ca3af; margin-bottom:6px;">Thời gian</div>
                        <span style="display:inline-flex; align-items:center; gap:6px; background:#eff6ff; border:1px solid #bfdbfe; color:#1d4ed8; padding:6px 16px; border-radius:20px; font-size:14px; font-weight:700;">
                            @Model.StartTime.ToString(@"hh\:mm") &mdash; @Model.EndTime.ToString(@"hh\:mm")
                        </span>
                    </div>
                </div>
            </div>
        </div>

        @* Form người đặt *@
        <div class="rg-form-card">
            <div class="rg-form-head">Thông tin người đặt</div>
            <div class="rg-form-body">

                <div class="mb-3">
                    <label asp-for="UserName" class="form-label fw-semibold"></label>
                    <input asp-for="UserName" class="form-control" placeholder="Nhập họ và tên" />
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label fw-semibold"></label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="09xxxxxxxx" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="UserEmail" class="form-label fw-semibold"></label>
                    <input asp-for="UserEmail" type="email" class="form-control" placeholder="abc@gmail.com" />
                    <span asp-validation-for="UserEmail" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Purpose" class="form-label fw-semibold"></label>
                    <textarea asp-for="Purpose" class="form-control" rows="3"
                              placeholder="Học bù, Seminar, Họp nhóm..."></textarea>
                    <span asp-validation-for="Purpose" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">Gửi yêu cầu</button>
                    <a href="@Url.Action("WeeklySchedule", "Room", new { roomId = Model.RoomId })"
                       class="btn btn-outline-secondary">Hủy</a>
                </div>

            </div>
        </div>

    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
