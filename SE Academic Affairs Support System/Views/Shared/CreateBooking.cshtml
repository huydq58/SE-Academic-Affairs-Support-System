@model SE_Academic_Affairs_Support_System.ViewModels.CreateBookingViewModel

@{
    ViewData["Title"] = "Gửi Yêu Cầu Đặt Phòng";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white py-3 text-center rounded-top-4">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-journal-plus me-2"></i> Phiếu Yêu Cầu Đặt Phòng</h4>
                </div>

                <div class="card-body p-4 p-md-5">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger rounded-3" role="alert">
                            <div asp-validation-summary="All" class="text-danger mb-0"></div>
                        </div>
                    }

                    <form asp-action="CreateBooking" method="post">
                        <input type="hidden" asp-for="RoomId" />
                        <input type="hidden" asp-for="BookingDate" />
                        <input type="hidden" asp-for="RoomName" />
                        <input type="hidden" asp-for="StartTime" />
                        <input type="hidden" asp-for="EndTime" />

                        <div class="bg-primary bg-opacity-10 p-4 rounded-4 mb-4 border border-primary-subtle shadow-sm">
                            <h6 class="text-primary mb-3 text-uppercase fw-bold fs-7">
                                <i class="bi bi-info-circle-fill me-1"></i> Thông tin đăng ký
                            </h6>
                            <div class="row g-3">
                                <div class="col-6">
                                    <span class="text-muted small d-block">Phòng:</span>
                                    <span class="fw-bold text-primary fs-5">@Model.RoomName</span>
                                </div>
                                <div class="col-6">
                                    <span class="text-muted small d-block">Ngày đặt:</span>
                                    <span class="fw-bold text-dark fs-5">@Model.BookingDate.ToString("dd/MM/yyyy")</span>
                                </div>
                                <div class="col-12">
                                    <span class="text-muted small d-block mb-1">Thời gian:</span>
                                    <span class="badge bg-primary px-3 py-2 fs-6 rounded-pill shadow-sm">
                                        <i class="bi bi-clock me-1"></i> @Model.StartTime.ToString(@"hh\:mm") - @Model.EndTime.ToString(@"hh\:mm")
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="UserName" class="form-control border-primary-subtle" placeholder="Nhập tên đăng nhập" />
                            <label asp-for="UserName">Tên người đặt <span class="text-danger">*</span></label>
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="PhoneNumber" class="form-control border-primary-subtle" placeholder="09xxxxxxx" />
                            <label asp-for="PhoneNumber">Số điện thoại liên hệ <span class="text-danger">*</span></label>
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <textarea asp-for="Purpose" class="form-control border-primary-subtle" placeholder="Nhập lý do" style="height: 100px"></textarea>
                            <label asp-for="Purpose">Mục đích sử dụng (Học bù, Seminar...) <span class="text-danger">*</span></label>
                            <span asp-validation-for="Purpose" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm">
                                <i class="bi bi-send-fill me-2"></i> Gửi Yêu Cầu
                            </button>
                            <a href="@Url.Action("RoomBooking", new { roomId = Model.RoomId })" class="btn btn-outline-secondary rounded-pill fw-semibold mt-2">
                                <i class="bi bi-x-circle me-1"></i> Hủy & Quay lại lịch
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}