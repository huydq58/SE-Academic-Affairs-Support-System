<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SE Academic Affairs</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SE_Academic_Affairs_Support_System.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

    <!-- jQuery và Bootstrap JS lên head để chỉ load 1 lần, không re-execute sau mỗi HTMX swap -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- HTMX: intercept link/form, swap <body> qua AJAX thay vì full reload -->
    <script src="https://unpkg.com/htmx.org@2.0.4" crossorigin="anonymous"></script>

    <style>
        /* === Navbar === */
        .navbar-accent {
            border-bottom: 2px solid #dbeafe;
        }

        .navbar-brand-icon {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg, #2563eb, #1e3a8a);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 16px;
            flex-shrink: 0;
        }

        .navbar-brand-text {
            font-size: 15px;
            font-weight: 700;
            color: #1e3a8a;
            line-height: 1.1;
        }

        .navbar-brand-sub {
            font-size: 10px;
            font-weight: 500;
            color: #6b7280;
            letter-spacing: 0.02em;
        }

        .custom-nav-hover {
            color: #374151 !important;
            transition: color 0.15s ease-in-out;
            font-size: 14px;
        }

        .custom-nav-hover:hover {
            color: #2563eb !important;
        }

        .dropdown-menu-accent {
            border-radius: 8px;
            padding: 6px 4px;
            min-width: 190px;
        }

        .dropdown-menu-accent .dropdown-item {
            font-size: 13px;
            font-weight: 500;
            color: #374151;
            border-radius: 6px;
            padding: 7px 12px;
            transition: background 0.15s;
        }

        .dropdown-menu-accent .dropdown-item:hover {
            background: #eff6ff;
            color: #1d4ed8;
        }

        .navbar-user-badge {
            font-size: 13px;
            font-weight: 600;
            color: #1d4ed8;
            background: #eff6ff;
            border: 1px solid #bfdbfe;
            border-radius: 20px;
            padding: 4px 12px;
            display: inline-flex;
            align-items: center;
        }

        .btn-login {
            background-color: #2563eb;
            border-color: #2563eb;
            color: #fff;
            font-size: 13px;
            font-weight: 600;
            transition: background 0.15s;
        }

        .btn-login:hover {
            background-color: #1d4ed8;
            border-color: #1d4ed8;
            color: #fff;
        }

        .btn-logout {
            border: 1px solid #bfdbfe;
            color: #2563eb;
            font-size: 13px;
            font-weight: 600;
            background: transparent;
            transition: all 0.15s;
        }

        .btn-logout:hover {
            background: #eff6ff;
            border-color: #93c5fd;
            color: #1d4ed8;
        }

        /* === HTMX progress bar === */
        #htmx-progress {
            position: fixed;
            top: 0;
            left: 0;
            height: 2px;
            width: 0%;
            background: #2563eb;
            z-index: 10000;
            opacity: 0;
            transition: width 0.25s ease, opacity 0.2s ease;
        }

        /* === HTMX page fade === */
        main {
            animation: none;
        }
        .htmx-settling main,
        .htmx-request main {
            opacity: 1;
        }
    </style>
</head>

@using Microsoft.AspNetCore.Identity
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<body class="d-flex flex-column min-vh-100 bg-light" hx-boost="true">

    <!-- HTMX progress bar -->
    <div id="htmx-progress" aria-hidden="true"></div>

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white shadow-sm mb-4 sticky-top navbar-accent">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2 text-decoration-none" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="navbar-brand-icon">
                        <i class="bi bi-mortarboard-fill"></i>
                    </span>
                    <span class="navbar-brand-text">
                        SE UIT
                        <small class="navbar-brand-sub d-block">Academic Affairs</small>
                    </span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link fw-semibold custom-nav-hover" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house me-1"></i>Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold custom-nav-hover" asp-area="" asp-controller="Home" asp-action="RoomList">
                                <i class="bi bi-door-closed me-1"></i>Đặt phòng
                            </a>
                        </li>

                        @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link fw-semibold custom-nav-hover dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-cpu me-1"></i>Thiết bị
                                </a>
                                <ul class="dropdown-menu shadow-sm border-0 dropdown-menu-accent">
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="Device" asp-action="Catalog">
                                            <i class="bi bi-box-arrow-in-down-right me-2 text-primary"></i>Mượn thiết bị
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="Device" asp-action="Index">
                                            <i class="bi bi-sliders me-2 text-primary"></i>Quản lý thiết bị
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-semibold custom-nav-hover" asp-area="" asp-controller="Device" asp-action="Catalog">
                                    <i class="bi bi-cpu me-1"></i>Thiết bị
                                </a>
                            </li>
                        }

                        @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link fw-semibold custom-nav-hover dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-phone me-1"></i>Ứng dụng
                                </a>
                                <ul class="dropdown-menu shadow-sm border-0 dropdown-menu-accent">
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="AppRegistration" asp-action="Create">
                                            <i class="bi bi-cloud-upload me-2 text-primary"></i>Đăng tải ứng dụng
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="AppRegistration" asp-action="PendingRequests">
                                            <i class="bi bi-check2-circle me-2 text-primary"></i>Duyệt yêu cầu
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-semibold custom-nav-hover" asp-area="" asp-controller="AppRegistration" asp-action="Create">
                                    <i class="bi bi-phone me-1"></i>Ứng dụng
                                </a>
                            </li>
                        }

                        @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-semibold custom-nav-hover" asp-area="Admin" asp-controller="Registration" asp-action="Periods">
                                    <i class="bi bi-calendar3 me-1"></i>Đợt đăng ký
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link fw-semibold custom-nav-hover" asp-area="Admin" asp-controller="Account" asp-action="Index">
                                    <i class="bi bi-people me-1"></i>Tài khoản
                                </a>
                            </li>
                        }

                        @if (SignInManager.IsSignedIn(User) && User.IsInRole("Lecturer"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link fw-semibold custom-nav-hover dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-journal-text me-1"></i>Đề tài
                                </a>
                                <ul class="dropdown-menu shadow-sm border-0 dropdown-menu-accent">
                                    <li>
                                        <a class="dropdown-item" asp-area="Lecturer" asp-controller="Registration" asp-action="CreateTopic">
                                            <i class="bi bi-plus-circle me-2 text-primary"></i>Tạo đề tài
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Lecturer" asp-controller="Registration" asp-action="MyTopics">
                                            <i class="bi bi-collection me-2 text-primary"></i>Đề tài của tôi
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Lecturer" asp-controller="Registration" asp-action="ActivePeriods">
                                            <i class="bi bi-star me-2 text-primary"></i>Chấm điểm
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        @if (SignInManager.IsSignedIn(User) && User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-semibold custom-nav-hover" asp-area="Student" asp-controller="Registration" asp-action="ActivePeriods">
                                    <i class="bi bi-journal-text me-1"></i>Đăng ký đề tài
                                </a>
                            </li>
                        }
                    </ul>

                    @if (SignInManager.IsSignedIn(User))
                    {
                        <ul class="navbar-nav align-items-center gap-2">
                            <li class="nav-item">
                                <span class="navbar-user-badge">
                                    <i class="bi bi-person-circle me-1"></i>@UserManager.GetUserName(User)
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-logout rounded-pill px-3" asp-area="" asp-controller="Login" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
                                </a>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="btn btn-login rounded-pill px-4" asp-area="" asp-controller="Login" asp-action="Index">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập
                                </a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1">
        <main role="main" class="pb-3 p-4 bg-white rounded-3 shadow-sm mb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white mt-auto py-3">
        <div class="container text-center">
            &copy; 2026 - SE Academic Affairs Support System -
            <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Chính sách bảo mật</a>
        </div>
    </footer>

    <script>
        // === HTMX progress bar ===
        (function () {
            var bar = document.getElementById('htmx-progress');
            var timer = null;

            document.addEventListener('htmx:beforeRequest', function () {
                clearTimeout(timer);
                bar.style.width = '0%';
                bar.style.opacity = '1';
                // Animate tới 80% trong khi chờ response
                requestAnimationFrame(function () {
                    bar.style.transition = 'width 8s cubic-bezier(0.1, 0.05, 0, 1), opacity 0.2s ease';
                    bar.style.width = '80%';
                });
            });

            document.addEventListener('htmx:afterSettle', function () {
                bar.style.transition = 'width 0.15s ease, opacity 0.3s ease 0.15s';
                bar.style.width = '100%';
                timer = setTimeout(function () {
                    bar.style.opacity = '0';
                    setTimeout(function () { bar.style.width = '0%'; }, 300);
                }, 150);
            });

            // Nếu request lỗi, ẩn bar
            document.addEventListener('htmx:responseError', function () {
                bar.style.opacity = '0';
                bar.style.width = '0%';
            });
        })();

        // === Đóng mobile navbar sau khi navigate ===
        document.addEventListener('htmx:afterSettle', function () {
            var navCollapse = document.querySelector('.navbar-collapse.show');
            if (navCollapse) {
                var bsCollapse = bootstrap.Collapse.getInstance(navCollapse);
                if (bsCollapse) bsCollapse.hide();
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    @await Html.PartialAsync("_SuccessToast")
</body>
</html>
