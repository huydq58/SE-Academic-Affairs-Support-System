@model SE_Academic_Affairs_Support_System.Models.ScheduleViewModel



@{

    ViewData["Title"] = "Lịch Đặt Phòng Hàng Tuần";

    // Hàm phụ trợ để dịch DayOfWeek sang tiếng Việt

    string GetVietnameseDay(DayOfWeek day)

    {

        return day switch

        {

            DayOfWeek.Monday => "Thứ 2",

            DayOfWeek.Tuesday => "Thứ 3",

            DayOfWeek.Wednesday => "Thứ 4",

            DayOfWeek.Thursday => "Thứ 5",

            DayOfWeek.Friday => "Thứ 6",

            DayOfWeek.Saturday => "Thứ 7",

            DayOfWeek.Sunday => "Chủ Nhật",

            _ => ""

        };

    }

}



<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h3 class="text-primary fw-bold text-uppercase mb-0">

            Lịch Đặt Phòng

        </h3>

        <div class="d-flex align-items-center gap-3 bg-white px-4 py-2 rounded-pill shadow-sm border">

            <a href="@Url.Action("WeeklySchedule", new { selectedDate = Model.WeekStartDate.AddDays(-7).ToString("yyyy-MM-dd") })" class="btn btn-sm btn-outline-secondary rounded-circle">

                <i class="bi bi-chevron-left">&lt;</i>

            </a>



            <h5 class="mb-0 text-dark fw-semibold px-2">

                Tuần: @Model.WeekStartDate.ToString("dd/MM/yyyy") - @Model.WeekEndDate.ToString("dd/MM/yyyy")

            </h5>



            <a href="@Url.Action("WeeklySchedule", new { selectedDate = Model.WeekStartDate.AddDays(7).ToString("yyyy-MM-dd") })" class="btn btn-sm btn-outline-secondary rounded-circle">

                <i class="bi bi-chevron-right">&gt;</i>

            </a>

        </div>

    </div>



    <tbody>
        @foreach (var slot in Model.TimeSlots)
        {
            <tr>
                <td class="fw-bold bg-light">
                    <div>@slot.SlotName</div>
                    <div class="small text-muted fw-normal">
                        @slot.StartTime.ToString(@"hh\:mm") - @slot.EndTime.ToString(@"hh\:mm")
                    </div>
                </td>

                @foreach (var day in Model.DaysInWeek)
                {
                    // Lọc để chỉ lấy các đơn đã duyệt (Approved)
                    var booking = Model.WeeklyBookings.FirstOrDefault(b =>
                    b.RoomId == 1&&
                    b.BookingDate.Date == day.Date &&
                    b.Status == "Approved" &&
                    b.StartTime <= slot.StartTime &&
                    b.EndTime >= slot.EndTime);

                    <td>
                        @if (booking != null)
                        {
                            <div class="p-2 rounded bg-danger bg-opacity-10 border border-danger border-opacity-25">
                                <span class="badge bg-danger mb-1">Đã đặt</span>

                                <div class="fw-bold text-dark small text-truncate" title="@booking.UserName">
                                    <i class="bi bi-person-fill"></i> Huy
                                </div>

                                <div class="text-muted small text-truncate" title="@booking.Purpose">
                                    @booking.Purpose
                                </div>
                            </div>
                        }
                        else
                        {
                            <a href="@Url.Action("CreateBooking", "Room", new { roomId = 1, date = day.ToString("yyyy-MM-dd"), startTime = slot.StartTime.ToString(@"hh\:mm"), endTime = slot.EndTime.ToString(@"hh\:mm") })"
                               class="text-decoration-none d-block p-3 rounded bg-success bg-opacity-10 text-success fw-semibold hover-book">
                                + Trống
                            </a>
                        }
                    </td>
                }
            </tr>
        }
    </tbody>
</div>



<style>

    .hover-book {
        transition: all 0.2s ease-in-out;
    }



        .hover-book:hover {
            background-color: #198754 !important;
            color: white !important;
            transform: scale(0.95);
        }

</style>