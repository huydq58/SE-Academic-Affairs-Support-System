@model SE_Academic_Affairs_Support_System.Models.ScheduleViewModel

@{
    ViewData["Title"] = "Lịch Đặt Phòng Hàng Tuần";

    string GetVietnameseDay(DayOfWeek day) => day switch
    {
        DayOfWeek.Monday    => "Thứ 2",
        DayOfWeek.Tuesday   => "Thứ 3",
        DayOfWeek.Wednesday => "Thứ 4",
        DayOfWeek.Thursday  => "Thứ 5",
        DayOfWeek.Friday    => "Thứ 6",
        DayOfWeek.Saturday  => "Thứ 7",
        DayOfWeek.Sunday    => "Chủ Nhật",
        _                   => ""
    };
}

<style>
    .rm-page-title { border-left:4px solid #2563eb; padding-left:14px; margin-bottom:24px; }
    .rm-page-title h2 { font-size:22px; font-weight:700; color:#1e3a8a; margin-bottom:3px; }
    .rm-page-title p  { font-size:13px; color:#6b7280; margin:0; }

    .week-nav { display:flex; align-items:center; gap:12px; background:#f8fafc; border:1px solid #e5e7eb; border-radius:10px; padding:10px 16px; }
    .week-nav .week-label { font-size:14px; font-weight:600; color:#374151; white-space:nowrap; }
    .week-nav a { display:inline-flex; align-items:center; justify-content:center; width:32px; height:32px; border:1px solid #d1d5db; border-radius:6px; background:#fff; color:#374151; text-decoration:none; font-size:14px; transition:all .15s; }
    .week-nav a:hover { background:#2563eb; border-color:#2563eb; color:#fff; }

    /* Schedule table */
    .schedule-wrap { border:1px solid #e5e7eb; border-radius:10px; overflow:hidden; margin-top:20px; }
    .schedule-table { border-collapse:collapse; width:100%; }
    .schedule-table th { background:#f8fafc; padding:10px 14px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:#64748b; border-bottom:1px solid #e5e7eb; text-align:center; }
    .schedule-table th.slot-col { text-align:left; min-width:110px; }
    .schedule-table td { border-bottom:1px solid #f1f5f9; border-right:1px solid #f1f5f9; padding:8px; vertical-align:top; }
    .schedule-table td.slot-label { background:#f8fafc; padding:10px 14px; white-space:nowrap; }
    .slot-name { font-size:13px; font-weight:600; color:#374151; }
    .slot-time { font-size:11px; color:#9ca3af; font-family:monospace; margin-top:2px; }

    .cell-booked { background:#fee2e2; border:1px solid #fecaca; border-radius:6px; padding:8px; }
    .cell-booked .booked-label { display:inline-block; background:#ef4444; color:#fff; border-radius:4px; font-size:11px; font-weight:700; padding:1px 7px; margin-bottom:4px; }
    .cell-booked .booked-user { font-size:12px; font-weight:600; color:#991b1b; }
    .cell-booked .booked-purpose { font-size:11px; color:#b91c1c; margin-top:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

    .cell-free { display:block; text-decoration:none; background:#dcfce7; border:1px solid #bbf7d0; border-radius:6px; padding:8px; text-align:center; font-size:13px; font-weight:600; color:#166534; transition:all .15s; }
    .cell-free:hover { background:#16a34a; color:#fff; border-color:#16a34a; }

    @@media (max-width:767px) {
        .schedule-wrap { overflow-x:auto; }
    }
</style>

<!-- Header -->
<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div class="rm-page-title mb-0">
        <h2>Lịch Đặt Phòng Hàng Tuần</h2>
        <p>Xem lịch và chọn khung giờ trống để đặt phòng</p>
    </div>

    <div class="week-nav">
        <a href="@Url.Action("WeeklySchedule", new { selectedDate = Model.WeekStartDate.AddDays(-7).ToString("yyyy-MM-dd") })">&lt;</a>
        <span class="week-label">@Model.WeekStartDate.ToString("dd/MM/yyyy") — @Model.WeekEndDate.ToString("dd/MM/yyyy")</span>
        <a href="@Url.Action("WeeklySchedule", new { selectedDate = Model.WeekStartDate.AddDays(7).ToString("yyyy-MM-dd") })">&gt;</a>
    </div>
</div>

<!-- Schedule grid -->
<div class="schedule-wrap">
    <table class="schedule-table">
        <thead>
            <tr>
                <th class="slot-col">Tiết học</th>
                @foreach (var day in Model.DaysInWeek)
                {
                    <th>
                        <div>@GetVietnameseDay(day.DayOfWeek)</div>
                        <div style="font-size:10px; font-weight:500; color:#9ca3af;">@day.ToString("dd/MM")</div>
                    </th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var slot in Model.TimeSlots)
            {
                <tr>
                    <td class="slot-label">
                        <div class="slot-name">@slot.SlotName</div>
                        <div class="slot-time">@slot.StartTime.ToString(@"hh\:mm") - @slot.EndTime.ToString(@"hh\:mm")</div>
                    </td>
                    @foreach (var day in Model.DaysInWeek)
                    {
                        var booking = Model.WeeklyBookings.FirstOrDefault(b =>
                            b.RoomId == 1 &&
                            b.BookingDate.Date == day.Date &&
                            b.Status == "Approved" &&
                            b.StartTime <= slot.StartTime &&
                            b.EndTime >= slot.EndTime);
                        <td>
                            @if (booking != null)
                            {
                                <div class="cell-booked">
                                    <div class="booked-label">Đã đặt</div>
                                    <div class="booked-user">@booking.UserName</div>
                                    <div class="booked-purpose">@booking.Purpose</div>
                                </div>
                            }
                            else
                            {
                                <a class="cell-free"
                                   href="@Url.Action("CreateBooking", "Room", new { roomId = 1, date = day.ToString("yyyy-MM-dd"), startTime = slot.StartTime.ToString(@"hh\:mm"), endTime = slot.EndTime.ToString(@"hh\:mm") })">
                                    Trống
                                </a>
                            }
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
