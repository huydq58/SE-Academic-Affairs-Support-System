@model SE_Academic_Affairs_Support_System.Models.ScheduleViewModel

@{
    ViewData["Title"] = "Lịch Đặt Phòng";
    var currentRoom = Model.Rooms.FirstOrDefault();
    var isAdmin = User.IsInRole("Admin");
}

<style>
    /* Calendar card */
    .cal-card { border:1px solid #dbeafe; border-radius:12px; overflow:hidden; }
    .cal-card-head { background:#eff6ff; border-bottom:1px solid #bfdbfe; padding:14px 20px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px; }
    .cal-card-head h5 { font-size:15px; font-weight:700; color:#1e3a8a; margin:0; }
    .cal-hint { display:inline-block; background:#dbeafe; border:1px solid #bfdbfe; color:#1d4ed8; border-radius:20px; padding:4px 14px; font-size:12px; font-weight:600; }
    .cal-card-body { background:#fff; padding:20px; }

    /* FullCalendar overrides */
    .fc-event { border:none !important; border-radius:6px !important; box-shadow:0 2px 4px rgba(0,0,0,.08); cursor:pointer; transition:transform .15s; }
    .fc-event:hover { transform:scale(1.02); box-shadow:0 4px 8px rgba(0,0,0,.12); }
    .fc .fc-toolbar-title { font-size:1.2rem !important; font-weight:700; color:#1e3a8a; }
    .fc .fc-button-primary { background-color:#fff !important; color:#2563eb !important; border:1px solid #d1d5db !important; border-radius:6px !important; font-weight:600; }
    .fc .fc-button-primary:hover,
    .fc .fc-button-primary:not(:disabled).fc-button-active { background-color:#2563eb !important; color:#fff !important; border-color:#2563eb !important; }
    .fc-timegrid-slot:hover { background-color:rgba(37,99,235,.06) !important; cursor:pointer; }
    .fc-day-past, .fc-day-sun { background-color:#f8fafc !important; }
    .fc-day-past .fc-timegrid-slot, .fc-day-sun .fc-timegrid-slot { cursor:not-allowed !important; }
    .fc-event-title, .fc-event-time { white-space:nowrap; overflow:hidden; text-overflow:ellipsis; font-size:.8rem; }

    .hint-desktop { display:inline; }
    .hint-mobile  { display:none; }

    /* Modal */
    .modal-content { border:none; border-radius:12px; box-shadow:0 8px 32px rgba(37,99,235,.12); }
    .modal-header { background:#eff6ff; border-bottom:1px solid #bfdbfe; border-radius:12px 12px 0 0; }
    .modal-header .modal-title { font-size:15px; font-weight:700; color:#1e3a8a; }
    .modal-footer { border-top:1px solid #f1f5f9; }

    .modal-info-row { display:flex; gap:10px; margin-bottom:10px; }
    .modal-info-row:last-child { margin-bottom:0; }
    .modal-info-lbl { font-size:11px; font-weight:700; text-transform:uppercase; color:#9ca3af; min-width:90px; flex-shrink:0; padding-top:2px; }
    .modal-info-val { font-size:14px; color:#374151; }

    .confirm-box { background:#f0f9ff; border:1px solid #bae6fd; border-radius:8px; padding:16px 20px; text-align:left; display:inline-block; }
    .confirm-row { font-size:14px; color:#374151; margin-bottom:8px; }
    .confirm-row:last-child { margin-bottom:0; }
    .confirm-row .lbl { color:#0369a1; font-size:11px; font-weight:700; text-transform:uppercase; margin-bottom:2px; }
    .confirm-row .val { font-weight:600; }

    @@media (max-width:768px) {
        .cal-card-body { padding:10px 8px; }
        .page-header-row { flex-direction:column; align-items:flex-start !important; gap:8px; }
        .fc .fc-toolbar { flex-wrap:wrap; gap:4px; margin-bottom:8px !important; }
        .fc .fc-toolbar-chunk { display:flex; flex-wrap:wrap; gap:4px; }
        .fc .fc-toolbar-title { font-size:.85rem !important; }
        .fc .fc-button { padding:3px 7px !important; font-size:.75rem !important; }
        .fc .fc-col-header-cell-cushion { font-size:.7rem !important; }
        .fc .fc-timegrid-slot-label-cushion { font-size:.68rem !important; }
        .fc-event-title, .fc-event-time { font-size:.68rem !important; }
        .hint-desktop { display:none; }
        .hint-mobile  { display:inline; }
        .modal-dialog { margin:8px !important; }
        .modal-footer { flex-direction:column; gap:8px; }
        .modal-footer .btn { width:100%; }
    }

    @@media (max-width:400px) {
        .fc .fc-toolbar-title { font-size:.78rem !important; }
        .fc .fc-button { padding:2px 5px !important; font-size:.7rem !important; }
        .fc-event-title, .fc-event-time { font-size:.62rem !important; }
    }
</style>

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4 page-header-row">
    <div class="rm-page-title mb-0">
        <h2>Hệ thống Đặt Phòng</h2>
        <p>Kéo thả hoặc nhấn giữ để chọn khung giờ và đặt phòng</p>
    </div>
    <a href="@Url.Action("RoomList", "Home")" class="btn btn-outline-secondary btn-sm px-3">Quay lại danh sách</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="cal-card">
    <div class="cal-card-head">
        <h5>Lịch phòng: @(currentRoom?.RoomName ?? "Chưa chọn phòng")</h5>
        <span class="cal-hint">
            <span class="hint-desktop">Kéo thả chuột để đặt phòng</span>
            <span class="hint-mobile">Nhấn giữ để đặt phòng</span>
        </span>
    </div>
    <div class="cal-card-body">
        <div id="calendar"></div>
    </div>
</div>

@Html.AntiForgeryToken()

<!-- Modal: Chi tiết đơn đặt phòng -->
<div class="modal fade" id="eventDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Chi tiết đơn đặt phòng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="modal-info-row">
                    <div class="modal-info-lbl">Người đặt</div>
                    <div class="modal-info-val fw-semibold" id="modalUserName"></div>
                </div>
                <div class="modal-info-row">
                    <div class="modal-info-lbl">Thời gian</div>
                    <div class="modal-info-val" id="modalTime"></div>
                </div>
                <div class="modal-info-row">
                    <div class="modal-info-lbl">Trạng thái</div>
                    <div class="modal-info-val"><span id="modalStatus" class="badge px-3 py-2"></span></div>
                </div>
                <div class="modal-info-row">
                    <div class="modal-info-lbl">Mục đích</div>
                    <div class="modal-info-val" id="modalPurpose" style="background:#f8fafc; border:1px solid #e5e7eb; border-radius:6px; padding:10px; font-size:13px;"></div>
                </div>
                @if (isAdmin)
                {
                    <div id="cancelReasonBox" style="display:none; margin-top:16px; border-top:1px solid #f1f5f9; padding-top:14px;">
                        <label class="form-label" style="font-size:13px; font-weight:600;">Lý do hủy lịch</label>
                        <textarea id="cancelReasonInput" class="form-control" rows="2" placeholder="Nhập lý do hủy (tùy chọn)..."></textarea>
                        <div class="d-flex gap-2 justify-content-end mt-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="btnCancelAbort">Bỏ qua</button>
                            <button type="button" class="btn btn-sm btn-danger" id="btnConfirmCancel">Xác nhận hủy &amp; gửi mail</button>
                        </div>
                    </div>
                }
            </div>
            <div class="modal-footer justify-content-center">
                @if (isAdmin)
                {
                    <button type="button" class="btn btn-outline-danger px-4" id="btnShowCancel">
                        <i class="bi bi-calendar-x me-1"></i>Hủy lịch
                    </button>
                }
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Xác nhận thời gian -->
<div class="modal fade" id="confirmSelectionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Xác nhận thời gian đặt phòng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <p class="text-muted mb-4" style="font-size:14px;">Bạn muốn đặt phòng trong khoảng thời gian sau?</p>
                <div class="confirm-box">
                    <div class="confirm-row">
                        <div class="lbl">Thứ</div>
                        <div class="val" id="confirmDay"></div>
                    </div>
                    <div class="confirm-row">
                        <div class="lbl">Ngày</div>
                        <div class="val" id="confirmDate"></div>
                    </div>
                    <div class="confirm-row">
                        <div class="lbl">Thời gian</div>
                        <div class="val" id="confirmTime" style="color:#2563eb;"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer justify-content-center pb-4">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Hủy, chọn lại</button>
                <button type="button" class="btn btn-primary px-4" id="btnProceedBooking">Đồng ý, tiếp tục</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@@6.1.11/index.global.min.js'></script>

    <script>
        (function () {
            var calendarEl = document.getElementById('calendar');
            var roomId = @(currentRoom?.RoomID ?? 0);

            if (roomId === 0) {
                calendarEl.innerHTML = '<div class="alert alert-warning text-center fw-bold py-4">Vui lòng chọn một phòng cụ thể để xem lịch.</div>';
                return;
            }

            // FullCalendar CDN là external script — HTMX không re-load, nhưng
            // có thể chưa kịp execute nếu script tag vừa được inject. Retry nếu cần.
            if (typeof FullCalendar === 'undefined') {
                setTimeout(function () { initCalendar(); }, 200);
            } else {
                initCalendar();
            }

            function initCalendar() {
                var isMobile = window.innerWidth < 768;

                var calendar = new FullCalendar.Calendar(calendarEl, {
                    initialView: isMobile ? 'timeGridDay' : 'timeGridWeek',
                    locale: 'EN',
                    selectLongPressDelay: 200,

                    headerToolbar: {
                        left: 'prev,next today',
                        center: 'title',
                        right: isMobile ? 'timeGridDay,timeGridWeek' : 'dayGridMonth,timeGridWeek,timeGridDay'
                    },

                    slotMinTime: '07:00:00',
                    slotMaxTime: '17:00:00',
                    allDaySlot: false,
                    height: 'auto',
                    expandRows: true,

                    windowResize: function () {
                        calendar.changeView(window.innerWidth < 768 ? 'timeGridDay' : 'timeGridWeek');
                    },

                    selectAllow: function (selectInfo) {
                        var now = new Date();
                        if (selectInfo.start < now) return false;
                        if (selectInfo.start.getDay() === 0) return false;
                        return true;
                    },

                    selectOverlap: function (event) {
                        return event.extendedProps.status !== 'Approved';
                    },

                    events: '/Room/GetBookingsForCalendar?roomId=' + roomId,
                    selectable: true,
                    selectMirror: true,

                    select: function (info) {
                        var dateStr       = info.startStr.split('T')[0];
                        var startTime     = info.startStr.split('T')[1].substring(0, 5);
                        var endTime       = info.endStr.split('T')[1].substring(0, 5);
                        var dateObj       = new Date(info.startStr);
                        var formattedDate = dateObj.toLocaleDateString('vi-VN');
                        var daysOfWeek    = ['Chủ Nhật', 'Thứ 2', 'Thứ 3', 'Thứ 4', 'Thứ 5', 'Thứ 6', 'Thứ 7'];
                        var dayName       = daysOfWeek[dateObj.getDay()];

                        document.getElementById('confirmDay').innerText  = dayName;
                        document.getElementById('confirmDate').innerText = formattedDate;
                        document.getElementById('confirmTime').innerText = startTime + ' – ' + endTime;

                        var confirmModal = new bootstrap.Modal(document.getElementById('confirmSelectionModal'));
                        confirmModal.show();

                        document.getElementById('btnProceedBooking').onclick = function () {
                            confirmModal.hide();
                            window.location.href = '/Room/CreateBooking?roomId=' + roomId
                                + '&date=' + dateStr
                                + '&startTime=' + startTime
                                + '&endTime=' + endTime;
                        };

                        document.getElementById('confirmSelectionModal').addEventListener('hidden.bs.modal', function () {
                            calendar.unselect();
                        }, { once: true });
                    },

                    eventClick: function (info) {
                        window.__currentBookingId = info.event.id;
                        var cancelBox = document.getElementById('cancelReasonBox');
                        if (cancelBox) { cancelBox.style.display = 'none'; var ci = document.getElementById('cancelReasonInput'); if (ci) ci.value = ''; }
                        var showBtn = document.getElementById('btnShowCancel');
                        if (showBtn) showBtn.style.display = '';

                        var status    = info.event.extendedProps.status;
                        var purpose   = info.event.extendedProps.purpose || 'Không có ghi chú';
                        var startTime = info.event.start.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
                        var endTime   = info.event.end
                            ? info.event.end.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' })
                            : '';

                        document.getElementById('modalUserName').innerText = info.event.title;
                        document.getElementById('modalTime').innerText     = endTime ? startTime + ' – ' + endTime : startTime;
                        document.getElementById('modalPurpose').innerText  = purpose;

                        var statusBadge = document.getElementById('modalStatus');
                        if (status === 'Approved') {
                            statusBadge.innerText     = 'Đã duyệt';
                            statusBadge.className     = 'badge px-3 py-2';
                            statusBadge.style.cssText = 'background:#dcfce7; color:#166534; border:1px solid #bbf7d0;';
                        } else {
                            statusBadge.innerText     = 'Đang chờ duyệt';
                            statusBadge.className     = 'badge px-3 py-2';
                            statusBadge.style.cssText = 'background:#fef3c7; color:#92400e; border:1px solid #fde68a;';
                        }

                        new bootstrap.Modal(document.getElementById('eventDetailModal')).show();
                    }
                });

                calendar.render();

                // ── Admin: hủy lịch ngay trên calendar ──
                var btnShowCancel = document.getElementById('btnShowCancel');
                var btnCancelAbort = document.getElementById('btnCancelAbort');
                var btnConfirmCancel = document.getElementById('btnConfirmCancel');

                if (btnShowCancel) {
                    btnShowCancel.addEventListener('click', function () {
                        document.getElementById('cancelReasonBox').style.display = 'block';
                        btnShowCancel.style.display = 'none';
                    });
                }
                if (btnCancelAbort) {
                    btnCancelAbort.addEventListener('click', function () {
                        document.getElementById('cancelReasonBox').style.display = 'none';
                        if (btnShowCancel) btnShowCancel.style.display = '';
                    });
                }
                if (btnConfirmCancel) {
                    btnConfirmCancel.addEventListener('click', function () {
                        var id = window.__currentBookingId;
                        if (!id) return;
                        var reason = (document.getElementById('cancelReasonInput') || {}).value || '';
                        var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
                        var token = tokenEl ? tokenEl.value : '';
                        btnConfirmCancel.disabled = true;

                        fetch('/Room/CancelBookingAjax', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: new URLSearchParams({ id: id, cancelReason: reason, __RequestVerificationToken: token })
                        })
                        .then(function (r) { return r.json(); })
                        .then(function (data) {
                            btnConfirmCancel.disabled = false;
                            var modalEl = document.getElementById('eventDetailModal');
                            var inst = bootstrap.Modal.getInstance(modalEl);
                            if (inst) inst.hide();
                            if (data.success) calendar.refetchEvents();
                            alert(data.message || (data.success ? 'Đã hủy lịch.' : 'Hủy thất bại.'));
                        })
                        .catch(function () {
                            btnConfirmCancel.disabled = false;
                            alert('Có lỗi xảy ra khi hủy lịch. Vui lòng thử lại.');
                        });
                    });
                }
            }
        })();
    </script>
}
