@model IEnumerable<SE_Academic_Affairs_Support_System.Models.RoomBooking>

@{
    ViewData["Title"] = "Quản lý Yêu Cầu Đặt Phòng";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-primary fw-bold text-uppercase mb-0">
            <i class="bi bi-inboxes-fill me-2"></i> Yêu Cầu Chờ Duyệt
        </h3>
        <span class="badge bg-warning text-dark fs-6 rounded-pill px-3 py-2 shadow-sm">
            Tổng: @Model.Count() yêu cầu
        </span>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Người yêu cầu</th>
                            <th>Phòng</th>
                            <th>Ngày đặt</th>
                            <th>Khung giờ</th>
                            <th>Mục đích & SĐT</th>
                            <th>Ngày gửi</th>
                            <th class="text-center pe-4" style="width: 200px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    <i class="bi bi-check2-all fs-1 d-block mb-2"></i>
                                    Hiện tại không có yêu cầu nào cần duyệt.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">@item.User?.FullName</td>
                                    <td><span class="badge bg-primary">@item.Room?.RoomName</span></td>
                                    <td class="fw-semibold text-dark">@item.BookingDate.ToString("dd/MM/yyyy")</td>

                                    <td>
                                        <div class="fw-bold text-dark">@item.Slot?.SlotName</div>
                                        <div class="small text-muted">
                                            @item.Slot?.StartTime.ToString(@"hh\:mm") - @item.Slot?.EndTime.ToString(@"hh\:mm")
                                        </div>
                                    </td>

                                    <td>
                                        <div class="text-truncate" style="max-width: 250px;" title="@item.Purpose">
                                            @item.Purpose
                                        </div>
                                    </td>
                                    <td class="small text-muted">@item.CreatedAt.ToString("dd/MM HH:mm")</td>
                                    <td class="pe-4 text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <form asp-action="ApproveBooking" method="post" onsubmit="return confirm('Xác nhận DUYỆT yêu cầu này? Các đơn trùng lịch sẽ bị từ chối.');">
                                                <input type="hidden" name="id" value="@item.BookingId" />
                                                <button type="submit" class="btn btn-sm btn-success rounded-3 shadow-sm" title="Duyệt">
                                                    <i class="bi bi-check-lg"></i> Duyệt
                                                </button>
                                            </form>

                                            <form asp-action="RejectBooking" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn TỪ CHỐI yêu cầu này?');">
                                                <input type="hidden" name="id" value="@item.BookingId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-3" title="Từ chối">
                                                    <i class="bi bi-x-lg"></i> Từ chối
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>