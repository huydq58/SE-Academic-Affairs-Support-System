@using SE_Academic_Affairs_Support_System.ViewModels
@using SE_Academic_Affairs_Support_System.Models
@model GradeFormViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Chấm điểm";
    bool isUpdate = Model.Row.Score.HasValue;
}

<style>
    .info-row       { display:flex; gap:12px; padding:10px 0; border-bottom:1px solid #f1f5f9; font-size:14px; align-items:baseline; }
    .info-row:last-child { border-bottom:none; }
    .info-lbl       { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#9ca3af; min-width:110px; flex-shrink:0; padding-top:2px; }
    .info-val       { color:#374151; font-weight:500; }

    .quick-score-grid { display:flex; flex-wrap:wrap; gap:6px; margin-top:10px; }
    .qs-btn {
        display:inline-flex; align-items:center; justify-content:center;
        width:48px; height:36px; border-radius:7px; font-size:13px; font-weight:700;
        cursor:pointer; border:1px solid; transition:all .15s; background:#fff;
    }
    .qs-high { color:#166534; border-color:#bbf7d0; }
    .qs-high:hover  { background:#dcfce7; }
    .qs-high.active { background:#dcfce7; }
    .qs-mid  { color:#1d4ed8; border-color:#bfdbfe; }
    .qs-mid:hover   { background:#dbeafe; }
    .qs-mid.active  { background:#dbeafe; }
    .qs-low  { color:#991b1b; border-color:#fecaca; }
    .qs-low:hover   { background:#fee2e2; }
    .qs-low.active  { background:#fee2e2; }

</style>

@* Breadcrumb *@
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb" style="font-size:13px;">
        <li class="breadcrumb-item">
            <a asp-action="List" asp-route-periodId="@Model.PeriodId">
                Danh sách chấm điểm
            </a>
        </li>
        <li class="breadcrumb-item active">@(isUpdate ? "Cập nhật điểm" : "Chấm điểm")</li>
    </ol>
</nav>

@* Title *@
<div class="rg-page-title mb-4">
    <h2>@(isUpdate ? "Cập nhật điểm báo cáo" : "Chấm điểm báo cáo")</h2>
    <p>@Model.Row.StudentName — @Model.Row.TopicName</p>
</div>

<div>

    @* ── Thông tin sinh viên / đề tài ── *@
    <div class="rg-form-card">
        <div class="rg-form-head">
            <i class="bi bi-person-fill me-2"></i>Thông tin sinh viên
        </div>
        <div class="rg-form-body">
            <div class="info-row">
                <span class="info-lbl">MSSV / ID</span>
                <span class="info-val">
                    <span class="sb sb-blue" style="font-family:monospace; font-size:11px;">@Model.Row.Mssv</span>
                </span>
            </div>
            <div class="info-row">
                <span class="info-lbl">Họ tên</span>
                <span class="info-val" style="font-weight:700; color:#1e3a8a;">@Model.Row.StudentName</span>
            </div>
            <div class="info-row">
                <span class="info-lbl">Tên đề tài</span>
                <span class="info-val" style="font-weight:600;">@Model.Row.TopicName</span>
            </div>
            <div class="info-row">
                <span class="info-lbl">Giảng viên HD</span>
                <span class="info-val">@Model.Row.Lecturer</span>
            </div>
            @if (isUpdate)
            {
                <div class="info-row">
                    <span class="info-lbl">Điểm hiện tại</span>
                    <span class="info-val">
                        <span style="font-size:20px; font-weight:800; color:#1d4ed8;">
                            @Model.Row.Score!.Value.ToString("0.#")
                        </span>
                        <span class="text-muted" style="font-size:12px; margin-left:8px;">
                            chấm bởi @Model.Row.GradedBy lúc @Model.Row.GradedAt
                        </span>
                    </span>
                </div>
            }
        </div>
    </div>

    @* ── Form nhập điểm ── *@
    <div class="rg-form-card">
        <div class="rg-form-head">
            <i class="bi bi-star-fill me-2"></i>@(isUpdate ? "Cập nhật điểm" : "Nhập điểm")
        </div>
        <div class="rg-form-body">
            <form asp-action="Grade" method="post" hx-boost="false">
                @Html.AntiForgeryToken()
                <input type="hidden" name="periodId" value="@Model.PeriodId" />
                <input type="hidden" name="sheetId" value="@Model.SheetId" />
                <input type="hidden" name="mssv" value="@Model.Row.Mssv" />

                <div class="mb-4">
                    <label class="form-label fw-semibold" style="font-size:13px;">
                        Điểm báo cáo
                        <span class="text-muted fw-normal">(0 – 10, cho phép 0.5)</span>
                    </label>

                    @* Slider + số *@
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <input type="range"
                               id="scoreRange"
                               min="0" max="10" step="0.5"
                               value="@Model.Score.ToString("0.#").Replace(",", ".")"
                               class="form-range flex-grow-1"
                               oninput="window.syncScore(this.value)" />
                        <input type="number"
                               id="scoreInput"
                               name="score"
                               min="0" max="10" step="0.5"
                               value="@Model.Score.ToString("0.#").Replace(",", ".")"
                               class="form-control text-center fw-bold"
                               style="width:80px; font-size:20px; border-color:#2563eb;"
                               oninput="window.syncRange(this.value)"
                               required />
                    </div>

                    @* Nút chọn nhanh *@
                    <div class="quick-score-grid">
                        @foreach (var v in new[]{ 4.0f, 4.5f, 5.0f, 5.5f, 6.0f, 6.5f, 7.0f, 7.5f, 8.0f, 8.5f, 9.0f, 9.5f, 10.0f })
                        {
                            string qsCls = v >= 8 ? "qs-high" : v >= 5 ? "qs-mid" : "qs-low";
                            <button type="button"
                                    class="qs-btn @qsCls"
                                    data-val="@v.ToString("0.#").Replace(",", ".")">
                                @v.ToString("0.#")
                            </button>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <a asp-action="List" asp-route-periodId="@Model.PeriodId"
                       class="btn-act btn-act-outline">
                        <i class="bi bi-arrow-left me-1"></i>Quay lại
                    </a>
                    <button type="submit" class="btn-act btn-act-primary"
                            onclick="return window.confirmGrade()"
                            style="padding:8px 20px; font-size:13.5px;">
                        <i class="bi bi-check-lg me-1"></i>
                        @(isUpdate ? "Cập nhật điểm" : "Lưu điểm")
                    </button>
                </div>
            </form>
        </div>
    </div>

</div>

@section Scripts {
    <script>
    (function () {
        window.syncScore = function (val) {
            document.getElementById('scoreInput').value = val;
            updateActiveBtn(val);
        };

        window.syncRange = function (val) {
            var v = parseFloat(val);
            if (!isNaN(v) && v >= 0 && v <= 10) {
                document.getElementById('scoreRange').value = v;
                updateActiveBtn(String(v));
            }
        };

        window.confirmGrade = function () {
            var score = document.getElementById('scoreInput').value;
            var name  = '@Html.Raw(Model.Row.StudentName.Replace("'", "\\'"))';
            return confirm('Xác nhận ' + '@(isUpdate ? "cập nhật" : "chấm")' + ' điểm ' + score + ' cho sinh viên "' + name + '"?');
        };

        function updateActiveBtn(val) {
            document.querySelectorAll('.qs-btn').forEach(function (b) {
                b.classList.toggle('active', b.dataset.val === String(parseFloat(val)));
            });
        }

        document.querySelectorAll('.qs-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var v = btn.dataset.val;
                document.getElementById('scoreInput').value = v;
                document.getElementById('scoreRange').value = v;
                updateActiveBtn(v);
            });
        });

        // Highlight nút tương ứng với điểm hiện tại khi load
        updateActiveBtn(document.getElementById('scoreInput').value);
    })();
    </script>
}
