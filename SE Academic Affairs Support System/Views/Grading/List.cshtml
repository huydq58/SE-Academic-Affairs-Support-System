@using SE_Academic_Affairs_Support_System.ViewModels
@using SE_Academic_Affairs_Support_System.Models
@model GradingListViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Chấm điểm — " + Model.PeriodName;
    int gradedCount   = Model.Rows.Count(r => r.Score.HasValue);
    int ungradedCount = Model.Rows.Count(r => !r.Score.HasValue);
}

<style>
    .dt thead th { background:#eff6ff; color:#1e3a8a; border-bottom:2px solid #bfdbfe; }
    .dt-wrap { overflow-x:auto; }
    .dt tbody tr.row-ungraded td { background:#fffbeb; }
    .dt tbody tr.row-ungraded:hover td { background:#fef3c7; }

    .score-val  { display:inline-block; font-size:15px; font-weight:700; border-radius:8px; padding:2px 10px; }
    .score-high { background:#dcfce7; color:#166534; border:1px solid #bbf7d0; }
    .score-mid  { background:#dbeafe; color:#1d4ed8; border:1px solid #bfdbfe; }
    .score-low  { background:#fee2e2; color:#991b1b; border:1px solid #fecaca; }

</style>

@* Breadcrumb *@
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb" style="font-size:13px;">
        <li class="breadcrumb-item">
            <a asp-controller="RegistrationPeriod" asp-action="ActivePeriods">Đợt đăng ký</a>
        </li>
        <li class="breadcrumb-item active">Chấm điểm — @Model.PeriodName</li>
    </ol>
</nav>

@* Header *@
<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div class="rg-page-title mb-0">
        <h2>Chấm điểm báo cáo</h2>
        <p>@Model.PeriodName — @Model.CourseName</p>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-2">
        <span class="sb sb-blue">@Model.Rows.Count sinh viên</span>
        <span class="sb sb-green">Đã chấm: @gradedCount</span>
        @if (ungradedCount > 0)
        {
            <span class="sb sb-amber">Chưa chấm: @ungradedCount</span>
        }
    </div>
</div>

<partial name="_Alerts" />

@* Search *@
<form method="get" class="mb-4">
    <input type="hidden" name="periodId" value="@Model.PeriodId" />
    <div class="d-flex gap-2" style="max-width:500px;">
        <div class="search-wrap flex-grow-1">
            <input type="text" name="search" class="form-control"
                   placeholder="Tìm theo MSSV, họ tên hoặc tên đề tài…"
                   value="@Model.SearchQuery" />
        </div>
        <button class="btn-act btn-act-outline" type="submit">
            <i class="bi bi-search me-1"></i>Tìm
        </button>
        @if (!string.IsNullOrEmpty(Model.SearchQuery))
        {
            <a asp-action="List" asp-route-periodId="@Model.PeriodId"
               class="btn-act btn-act-danger" title="Xóa bộ lọc">
                <i class="bi bi-x-lg"></i>
            </a>
        }
    </div>
</form>

@if (!Model.Rows.Any())
{
    <div class="empty-state">
        <i class="bi bi-search" style="font-size:32px; color:#d1d5db;"></i>
        <p style="font-weight:600; color:#374151; margin-top:12px;">Không có kết quả phù hợp.</p>
        @if (!string.IsNullOrEmpty(Model.SearchQuery))
        {
            <p>Thử lại với từ khóa khác.</p>
        }
        else
        {
            <p>Google Sheet chưa có dữ liệu hoặc chưa được tạo bảng điểm.</p>
        }
    </div>
}
else
{
    <div class="dt-wrap">
        <table class="dt">
            <thead>
                <tr>
                    <th style="width:44px;">STT</th>
                    <th style="width:130px;">MSSV / ID</th>
                    <th>Họ tên</th>
                    <th>Tên đề tài</th>
                    <th style="width:140px;">Giảng viên HD</th>
                    <th style="width:120px;" class="text-center">Điểm</th>
                    <th style="width:145px;">Thời gian chấm</th>
                    <th style="width:90px;" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Rows.Count; i++)
                {
                    var r = Model.Rows[i];
                    bool graded = r.Score.HasValue;
                    string rowCls = graded ? "" : "row-ungraded";

                    <tr class="@rowCls">
                        <td data-label="STT" class="text-center" style="color:#9ca3af;">@(i + 1)</td>
                        <td data-label="MSSV / ID">
                            <code title="@r.Mssv"
                                  style="font-size:11px; color:#1d4ed8; background:#dbeafe; border:1px solid #bfdbfe; border-radius:4px; padding:2px 6px; display:block; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; max-width:118px;">
                                @r.Mssv
                            </code>
                        </td>
                        <td data-label="Họ tên" style="font-weight:600;">@r.StudentName</td>
                        <td data-label="Tên đề tài">
                            <div style="font-size:13.5px; font-weight:600; color:#1e3a8a;">@r.TopicName</div>
                        </td>
                        <td data-label="Giảng viên HD" style="font-size:13px; color:#6b7280;">@r.Lecturer</td>
                        <td data-label="Điểm" class="text-center">
                            @if (graded)
                            {
                                double sv = r.Score!.Value;
                                string scoreCls = sv >= 8 ? "score-high" : sv >= 5 ? "score-mid" : "score-low";
                                <span class="score-val @scoreCls">@sv.ToString("0.#")</span>
                            }
                            else
                            {
                                <span class="text-muted" style="font-size:12px; font-style:italic;">Chưa chấm</span>
                            }
                        </td>
                        <td data-label="Thời gian chấm">
                            @if (graded)
                            {
                                <div style="font-size:12.5px; color:#374151;">@r.GradedAt</div>
                                <div style="font-size:11px; color:#9ca3af;">@r.GradedBy</div>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td data-label="Thao tác" class="text-center">
                            <a asp-action="Grade"
                               asp-route-periodId="@Model.PeriodId"
                               asp-route-sheetId="@Model.SheetId"
                               asp-route-mssv="@r.Mssv"
                               class="btn-act @(graded ? "btn-act-outline" : "btn-act-primary")">
                                <i class="bi @(graded ? "bi-pencil" : "bi-star-fill") me-1"></i>
                                @(graded ? "Sửa" : "Chấm")
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
