@model TopicListSheetViewModel
@using SE_Academic_Affairs_Support_System.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Đăng ký đề tài — " + Model.PeriodName;
    int availableCount = Model.Topics.Count(t =>
    {
        var reg = Model.GetRegistration(t.RowIndex);
        return reg == null && t.Registered < t.MaxSlot;
    });
}

<style>
    /* Ghi đè màu header table cho trang này */
    .dt thead th { background: #eff6ff; color: #1e3a8a; border-bottom: 2px solid #bfdbfe; }
    .dt tbody tr.row-full td { background: #f8fafc; color: #9ca3af; }
    .dt tbody tr.row-full:hover td { background: #f8fafc; }

    /* Modal */
    .modal-content { border:none; border-radius:12px; box-shadow:0 8px 32px rgba(37,99,235,.12); }
    .modal-header  { background:#eff6ff; border-bottom:1px solid #bfdbfe; border-radius:12px 12px 0 0; }
    .modal-header .modal-title { font-size:15px; font-weight:700; color:#1e3a8a; }
    .modal-footer  { border-top:1px solid #f1f5f9; }

    .topic-name { font-size:13.5px; font-weight:600; color:#1e3a8a; }
    .topic-note { font-size:12px; color:#6b7280; margin-top:2px; }

    @@media (max-width:767px) {
        .stat-chips { flex-wrap:wrap; }
    }
</style>

@* Breadcrumb *@
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb" style="font-size:13px;">
        <li class="breadcrumb-item">
            <a asp-area="Student" asp-controller="Registration" asp-action="ActivePeriods">
                Đợt đăng ký
            </a>
        </li>
        <li class="breadcrumb-item active">@Model.PeriodName</li>
    </ol>
</nav>

@* Header *@
<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div class="rg-page-title mb-0">
        <h2>@Model.PeriodName</h2>
        <p>@Model.CourseName</p>
    </div>
    <div class="d-flex align-items-center gap-2 stat-chips">
        <span class="sb sb-blue">@Model.Topics.Count đề tài</span>
        <span class="sb @(availableCount > 0 ? "sb-green" : "sb-gray")">
            @availableCount còn trống
        </span>
    </div>
</div>

@* Flash message sau đăng ký *@
@if (Model.StatusMessage != null)
{
    <div class="alert alert-@(Model.IsSuccess ? "success" : "danger") alert-dismissible fade show mb-4"
         role="alert" style="font-size:13.5px; border-radius:8px;">
        <i class="bi bi-@(Model.IsSuccess ? "check-circle-fill" : "exclamation-circle-fill") me-2"></i>
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* Bảng đề tài *@
@if (!Model.Topics.Any())
{
    <div class="empty-state">
        <p style="font-weight:600; color:#374151;">Google Sheet chưa có dữ liệu đề tài.</p>
        <p>Vui lòng liên hệ giảng viên hoặc giáo vụ để cập nhật danh sách.</p>
    </div>
}
else
{
    <div class="dt-wrap">
        <table class="dt">
            <thead>
                <tr>
                    <th style="width:44px;">STT</th>
                    <th>Tên đề tài</th>
                    <th style="width:150px;">Giảng viên HD</th>
                    <th style="width:145px;">Sinh viên 1</th>
                    <th style="width:145px;">Sinh viên 2</th>
                    <th style="width:64px;" class="text-center">Slot</th>
                    <th style="width:110px;" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Topics)
                {
                    var reg = Model.GetRegistration(t.RowIndex);
                    var sv1Name = reg?.StudentName1 ?? t.Student1;
                    var sv2Name = reg?.StudentName2;
                    bool isFull = reg != null || t.Registered >= t.MaxSlot;

                    <tr class="@(isFull ? "row-full" : "")">
                        <td data-label="STT" class="text-center">@t.Stt</td>
                        <td data-label="Tên đề tài">
                            <div class="topic-name">@t.TopicName</div>
                            @if (!string.IsNullOrEmpty(t.Note))
                            {
                                <div class="topic-note">@t.Note</div>
                            }
                        </td>
                        <td data-label="Giảng viên HD">
                            <div style="font-size:13.5px; font-weight:600;">@t.Lecturer</div>
                            @if (!string.IsNullOrEmpty(t.LecturerInfo))
                            {
                                <div style="font-size:12px; color:#6b7280;">@t.LecturerInfo</div>
                            }
                        </td>
                        <td data-label="Sinh viên 1">
                            @if (!string.IsNullOrEmpty(sv1Name))
                            {
                                <div style="font-size:13px; font-weight:600; color:#1d4ed8;">@sv1Name</div>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td data-label="Sinh viên 2">
                            @if (!string.IsNullOrEmpty(sv2Name))
                            {
                                <div style="font-size:13px; font-weight:600; color:#1d4ed8;">@sv2Name</div>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td data-label="Slot" class="text-center">
                            <span class="sb @(isFull ? "sb-red" : "sb-green")"
                                  style="font-size:12px; font-weight:700;">
                                @t.Registered/@t.MaxSlot
                            </span>
                        </td>
                        <td data-label="Thao tác" class="text-center">
                            @if (!isFull)
                            {
                                <form asp-area="" asp-controller="Topic" asp-action="Register" method="post" hx-boost="false">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="sheetId"    value="@Model.SheetId" />
                                    <input type="hidden" name="periodId"   value="@Model.PeriodId" />
                                    <input type="hidden" name="periodName" value="@Model.PeriodName" />
                                    <input type="hidden" name="courseName" value="@Model.CourseName" />
                                    <input type="hidden" name="rowIndex"   value="@t.RowIndex" />
                                    <input type="hidden" name="topicName"  value="@t.TopicName" />
                                    <button type="button" class="btn-act btn-act-primary"
                                            data-topic="@t.TopicName"
                                            data-row="@t.RowIndex"
                                            onclick="openRegisterModal(this)">
                                        Đăng ký
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="sb sb-gray" style="font-size:12px;">Đã đủ</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@* Modal xác nhận đăng ký *@
<div class="modal fade" id="registerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Xác nhận đăng ký đề tài</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div style="background:#f0f9ff; border:1px solid #bae6fd; border-radius:8px; padding:12px 16px; margin-bottom:16px;">
                    <div style="font-size:11px; font-weight:700; text-transform:uppercase; color:#0369a1; margin-bottom:4px;">Đề tài</div>
                    <div id="modalTopicName" style="font-size:14px; font-weight:600; color:#0c4a6e;"></div>
                </div>
                <label class="form-label fw-semibold" style="font-size:13px;">
                    MSSV sinh viên 2
                    <span class="text-muted fw-normal">(tuỳ chọn — bỏ trống nếu làm một mình)</span>
                </label>
                <input type="text" id="partnerMssvInput" class="form-control"
                       placeholder="VD: 2021001234" style="font-size:13px;" />
                <div class="form-text">Nhập đúng MSSV của thành viên thứ hai trong hệ thống.</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="confirmRegisterBtn">
                    <i class="bi bi-check-lg me-1"></i>Xác nhận đăng ký
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    (function () {
        var _activeForm = null;

        // Expose ra global vì được gọi từ onclick attribute
        window.openRegisterModal = function (btn) {
            _activeForm = btn.closest('form');
            document.getElementById('modalTopicName').textContent = btn.dataset.topic;
            document.getElementById('partnerMssvInput').value = '';
            new bootstrap.Modal(document.getElementById('registerModal')).show();
        };

        document.getElementById('confirmRegisterBtn').addEventListener('click', function () {
            if (!_activeForm) return;

            var mssv = document.getElementById('partnerMssvInput').value.trim();

            // Gắn hoặc cập nhật input partnerId (chứa MSSV)
            var partnerInput = _activeForm.querySelector('input[name="partnerId"]');
            if (!partnerInput) {
                partnerInput = document.createElement('input');
                partnerInput.type = 'hidden';
                partnerInput.name = 'partnerId';
                _activeForm.appendChild(partnerInput);
            }
            partnerInput.value = mssv;

            bootstrap.Modal.getInstance(document.getElementById('registerModal')).hide();
            _activeForm.submit();
        });
    })();
    </script>
}
