@model SE_Academic_Affairs_Support_System.Models.AppRegistrationRequest

@{
    ViewData["Title"] = "Đăng ký phát hành ứng dụng";
}

<style>
    .ar-wrap {
        max-width: 700px;
        margin: 0 auto;
    }

    .ar-page-title {
        border-left: 4px solid #2563eb;
        padding-left: 14px;
        margin-bottom: 28px;
    }

    .ar-page-title h2 {
        font-size: 22px;
        font-weight: 700;
        color: #1e3a8a;
        margin-bottom: 3px;
    }

    .ar-page-title p {
        font-size: 13px;
        color: #6b7280;
        margin: 0;
    }

    .ar-section {
        border: 1px solid #dbeafe;
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 18px;
    }

    .ar-section-head {
        background: #eff6ff;
        border-bottom: 1px solid #bfdbfe;
        padding: 10px 18px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: #1d4ed8;
    }

    .ar-section-body {
        padding: 20px 18px;
    }

    .ar-wrap .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #374151;
    }

    .ar-wrap .form-control {
        font-size: 14px;
        border-color: #d1d5db;
        border-radius: 7px;
        padding: 9px 12px;
    }

    .ar-wrap .form-control:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
    }

    .ar-wrap .form-control.is-invalid {
        border-color: #dc2626;
        background-image: none;
    }

    .ar-wrap textarea.form-control {
        resize: vertical;
        min-height: 88px;
    }

    .form-hint {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 4px;
    }

    .opt-badge {
        display: inline-block;
        font-size: 11px;
        font-weight: 500;
        background: #f3f4f6;
        color: #6b7280;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 1px 8px;
        vertical-align: middle;
        text-transform: none;
        letter-spacing: 0;
    }

    .ar-footer {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        padding-top: 18px;
        border-top: 1px solid #e5e7eb;
        margin-top: 20px;
    }

    .ar-wrap .btn-primary {
        background-color: #2563eb;
        border-color: #2563eb;
    }

    .ar-wrap .btn-primary:hover {
        background-color: #1d4ed8;
        border-color: #1d4ed8;
    }
</style>

<div class="ar-wrap">

    <div class="ar-page-title">
        <h2>Đăng ký phát hành ứng dụng</h2>
        <p>Điền đầy đủ thông tin bên dưới để gửi yêu cầu xét duyệt ứng dụng lên ban học vụ</p>
    </div>

    <form asp-action="Submit" asp-controller="AppRegistration" method="post" novalidate hx-boost="false">
        @Html.AntiForgeryToken()

        <div class="ar-section">
            <div class="ar-section-head">Thông tin ứng dụng</div>
            <div class="ar-section-body">

                <div class="mb-3">
                    <label class="form-label">Tên ứng dụng <span class="text-danger">*</span></label>
                    <input asp-for="AppName"
                           class="form-control @(ViewData.ModelState["AppName"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           placeholder="Ví dụ: StudyMate, CampusMap..." />
                    <span asp-validation-for="AppName" class="invalid-feedback d-block small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Mô tả ứng dụng <span class="text-danger">*</span></label>
                    <textarea asp-for="AppDescription"
                              class="form-control @(ViewData.ModelState["AppDescription"]?.Errors.Count > 0 ? "is-invalid" : "")"
                              rows="3"
                              placeholder="Mô tả ngắn gọn về chức năng và tính năng chính..."></textarea>
                    <span asp-validation-for="AppDescription" class="invalid-feedback d-block small"></span>
                </div>

                <div>
                    <label class="form-label">Mục đích sử dụng <span class="text-danger">*</span></label>
                    <textarea asp-for="Purpose"
                              class="form-control @(ViewData.ModelState["Purpose"]?.Errors.Count > 0 ? "is-invalid" : "")"
                              rows="3"
                              placeholder="Ứng dụng giải quyết vấn đề gì? Đối tượng người dùng là ai?"></textarea>
                    <span asp-validation-for="Purpose" class="invalid-feedback d-block small"></span>
                </div>

            </div>
        </div>

        <div class="ar-section">
            <div class="ar-section-head">Liên kết tài nguyên</div>
            <div class="ar-section-body">

                <div class="row g-3">
                    <div class="col-12 col-sm-6">
                        <label class="form-label">Link Demo <span class="text-danger">*</span></label>
                        <input asp-for="DemoLink"
                               class="form-control @(ViewData.ModelState["DemoLink"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="https://youtube.com/..." />
                        <span asp-validation-for="DemoLink" class="invalid-feedback d-block small"></span>
                        <div class="form-hint">YouTube, video demo hoặc link trực tiếp</div>
                    </div>
                    <div class="col-12 col-sm-6">
                        <label class="form-label">Link APK <span class="text-danger">*</span></label>
                        <input asp-for="ApkLink"
                               class="form-control @(ViewData.ModelState["ApkLink"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="https://drive.google.com/..." />
                        <span asp-validation-for="ApkLink" class="invalid-feedback d-block small"></span>
                        <div class="form-hint">Google Drive, Dropbox hoặc link tải trực tiếp</div>
                    </div>
                </div>

            </div>
        </div>

        <div class="ar-section">
            <div class="ar-section-head">Thông tin người thực hiện</div>
            <div class="ar-section-body">

                <div class="mb-3">
                    <label class="form-label">Thông tin sinh viên <span class="text-danger">*</span></label>
                    <input asp-for="StudentInfo"
                           class="form-control @(ViewData.ModelState["StudentInfo"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           placeholder="Họ tên – MSSV – Khoa/Lớp" />
                    <span asp-validation-for="StudentInfo" class="invalid-feedback d-block small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Email liên hệ <span class="text-danger">*</span></label>
                    <input asp-for="StudentEmail" type="email"
                           class="form-control @(ViewData.ModelState["StudentEmail"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           placeholder="example@student.uit.edu.vn" />
                    <span asp-validation-for="StudentEmail" class="invalid-feedback d-block small"></span>
                </div>

                <div>
                    <label class="form-label">
                        Giảng viên hướng dẫn
                        <span class="opt-badge">Tùy chọn</span>
                    </label>
                    <input asp-for="SupervisorInfo" class="form-control"
                           placeholder="Họ tên – Bộ môn (nếu có)" />
                </div>

                <div class="ar-footer">
                    <a asp-action="Index" asp-controller="AppRegistration"
                       class="btn btn-outline-secondary px-4">Hủy</a>
                    <button type="submit" class="btn btn-primary px-5">Gửi yêu cầu</button>
                </div>

            </div>
        </div>

    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
